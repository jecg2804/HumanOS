{
  "output": {
    "filePath": "repomix-HumanOS.xml",
    "style": "xml",
    "fileSummary": true,
    "directoryStructure": true,
    "removeComments": false,
    "removeEmptyLines": false,
    "showLineNumbers": true,
    "topFilesLength": 5
  },
  "include": [
    "src/**",
    "e2e/**",
    ".claude/**",
    "docs/**",
    "CLAUDE.md",
    "PROJECT_CONSTITUTION.md",
    "package.json",
    "tsconfig.json",
    "next.config.*",
    "repomix.config.json",
    "middleware.ts"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "node_modules/**",
      ".next/**",
      "dist/**",
      "build/**",
      "*.log",
      ".env*",
      "package-lock.json",
      "yarn.lock",
      "pnpm-lock.yaml",
      "*.test.*.snap",
      "playwright-report/**",
      "test-results/**",
      "public/**",
      "*.ico",
      "*.png",
      "*.jpg",
      "*.jpeg",
      "*.svg",
      "*.woff*",
      "repomix-output.xml",
      "repomix-HumanOS.xml",
      "*.backup-*",
      ".claude/hooks/errors.log",
      ".claude/hooks/compact.log",
      "docs/HANDOFF.json"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  }
}