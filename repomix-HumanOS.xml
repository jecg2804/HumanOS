165: export async function reportOnboardingErrorAction(
166:   _prev: FormState,
167:   formData: FormData
168: ): Promise<FormState> {
169:   const parsed = ErrorReportSchema.safeParse({
170:     severity: formData.get('severity'),
171:     description: formData.get('description'),
172:   });
173:   const personId = formData.get('person_id') as string;
174:   if (!parsed.success || !personId) {
175:     return {
176:       ok: false,
177:       errors: parsed.success ? {} : parsed.error.flatten().fieldErrors,
178:     };
179:   }
180: 
181:   const admin = createSupabaseAdminClient();
182: 
183:   const { data: person } = await admin
184:     .schema('hr')
185:     .from('people')
186:     .select('id, full_name, review_notes')
187:     .eq('id', personId)
188:     .maybeSingle();
189:   if (!person) return { ok: false, message: 'Empleado no encontrado.' };
190: 
191:   const stamp = new Date().toISOString();
192:   const newEntry = `**[${stamp}] Onboarding step 5 — Severidad: ${parsed.data.severity}**\n${parsed.data.description}`;
193:   const updated = person.review_notes ? `${person.review_notes}\n\n---\n\n${newEntry}` : newEntry;
194: 
195:   await admin
196:     .schema('hr')
197:     .from('people')
198:     .update({ needs_review: true, review_notes: updated })
199:     .eq('id', personId);
200: 
201:   const { data: hrAdmins } = await admin
202:     .schema('hr')
203:     .from('employments')
204:     .select('person_id')
205:     .eq('app_role', 'hr_admin')
206:     .eq('is_current', true);
