 768: ```ts
 769: // src/middleware.ts
 770: import { NextResponse, type NextRequest } from 'next/server';
 771: import { updateSession } from '@/lib/supabase/middleware';
 772: import { isPublicRoute } from '@/lib/auth/constants';
 773: import { userHasHumanOSAccess } from '@/lib/auth/allowed-apps';
 774: 
 775: export async function middleware(request: NextRequest) {
 776:   const { pathname } = request.nextUrl;
 777: 
 778:   if (isPublicRoute(pathname)) {
 779:     return NextResponse.next({ request });
 780:   }
 781: 
 782:   const { response, user } = await updateSession(request);
 783: 
 784:   if (!user) {
 785:     const loginUrl = new URL('/login', request.url);
 786:     loginUrl.searchParams.set('next', pathname);
 787:     return NextResponse.redirect(loginUrl);
 788:   }
 789: 
 790:   if (!userHasHumanOSAccess(user)) {
 791:     const loginUrl = new URL('/login', request.url);
 792:     loginUrl.searchParams.set('error', 'no_access');
 793:     return NextResponse.redirect(loginUrl);
 794:   }
 795: 
 796:   return response;
 797: }
 798: 
 799: export const config = {
 800:   matcher: [
 801:     // Run on all routes except _next/static, _next/image, favicon
 802:     '/((?!_next/static|_next/image|favicon.ico|.*\\.(?:svg|png|jpg|jpeg|gif|webp)$).*)',
 803:   ],
 804: };
 805: ```
