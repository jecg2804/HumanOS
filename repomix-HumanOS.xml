29: </body></html>`;
30: }
31: 
32: export function kvBlock(rows: Array<[string, string]>): string {
33:   return `<table role="presentation" cellpadding="0" cellspacing="0" style="background:#F5F5F5;padding:12px;border-radius:4px;font-family:ui-monospace,'SF Mono',Menlo,monospace;font-size:13px;width:100%">
34: ${rows
35:   .map(
36:     ([k, v]) =>
37:       `<tr><td style="padding:4px 8px;color:#5A6272">${k}:</td><td style="padding:4px 8px"><strong>${escapeHtml(v)}</strong></td></tr>`,
38:   )
39:   .join('')}
40: </table>`;
41: }
42: 
43: function escapeHtml(s: string): string {
44:   return s
45:     .replace(/&/g, '&amp;')
46:     .replace(/</g, '&lt;')
47:     .replace(/>/g, '&gt;')
48:     .replace(/"/g, '&quot;')
49:     .replace(/'/g, '&#39;');
50: }
