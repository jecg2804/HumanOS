<file path="src/middleware.ts">
 1: import { NextResponse, type NextRequest } from 'next/server';
 2: import { updateSession } from '@/lib/supabase/middleware';
 3: import { isPublicRoute } from '@/lib/auth/constants';
 4: import { userHasHumanOSAccess } from '@/lib/auth/allowed-apps';
 5: 
 6: export async function middleware(request: NextRequest) {
 7:   const { pathname } = request.nextUrl;
 8: 
 9:   if (isPublicRoute(pathname)) {
10:     return NextResponse.next({ request });
11:   }
12: 
13:   const { response, user } = await updateSession(request);
14: 
15:   if (!user) {
16:     const loginUrl = new URL('/login', request.url);
17:     loginUrl.searchParams.set('next', pathname);
18:     return NextResponse.redirect(loginUrl);
19:   }
20: 
21:   if (!userHasHumanOSAccess(user)) {
22:     const loginUrl = new URL('/login', request.url);
23:     loginUrl.searchParams.set('error', 'no_access');
24:     return NextResponse.redirect(loginUrl);
25:   }
26: 
27:   return response;
28: }
29: 
30: export const config = {
31:   matcher: [
32:     '/((?!_next/static|_next/image|favicon.ico|.*\\.(?:svg|png|jpg|jpeg|gif|webp)$).*)',
33:   ],
34: };
</file>

