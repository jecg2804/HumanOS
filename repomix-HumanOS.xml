195:             onClick={() => setFiltersOpen((v) => !v)}
196:             className="md:hidden text-sm px-3 py-1.5 rounded-md border border-neutral-300"
197:           >
198:             {filtersOpen ? 'Ocultar filtros' : 'Mostrar filtros'}
199:           </button>
200:         </div>
201:       </div>
202: 
203:       <div
204:         className={`rounded-lg border border-neutral-200 bg-white p-4 space-y-4 ${
205:           filtersOpen ? '' : 'hidden md:block'
206:         }`}
207:       >
208:         <div className="grid gap-4 md:grid-cols-2">
