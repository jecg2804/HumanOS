 440: -- Migration 034: SECURITY DEFINER lookup auth.users by email or phone.
 441: -- Documented in docs/adr/0006-service-role-admin-client-onboarding-exception.md.
 442: -- Used by onboardEmployee server action to detect multi-app users without
 443: -- exposing `auth` schema via PostgREST (enumeration attack mitigation).
 444: 
 445: CREATE OR REPLACE FUNCTION hr.find_auth_user_by_identifier(
 446:   p_field text,
 447:   p_value text
 448: )
 449: RETURNS TABLE (
 450:   id uuid,
 451:   email text,
 452:   phone text,
 453:   raw_app_meta_data jsonb,
 454:   encrypted_password text
 455: )
 456: LANGUAGE sql
 457: SECURITY DEFINER
 458: SET search_path = ''
 459: AS $$
 460:   SELECT id, email, phone, raw_app_meta_data, encrypted_password
 461:   FROM auth.users
 462:   WHERE (p_field = 'email' AND email = lower(trim(p_value)))
 463:      OR (p_field = 'phone' AND phone = p_value)
 464:   LIMIT 1;
 465: $$;
