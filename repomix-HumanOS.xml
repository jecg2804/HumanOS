 11: function H2 { param($t) Write-Host "`n--- $t ---" -ForegroundColor Yellow }
 12: function OK { param($t) Write-Host "  [OK] $t" -ForegroundColor Green }
 13: function NO { param($t) Write-Host "  [--] $t" -ForegroundColor Red }
 14: function INFO { param($t) Write-Host "  $t" }
