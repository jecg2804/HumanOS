 7: 
 8: const LoginInput = z.object({
 9:   email: z.string().email('Correo invalido'),
10:   password: z.string().min(1, 'Contrasena requerida'),
11:   next: z.string().optional(),
12: });
13: 
14: export type LoginResult = { ok: true } | { ok: false; error: string };
15: 
16: export async function loginAction(formData: FormData): Promise<LoginResult> {
17:   const parsed = LoginInput.safeParse({
18:     email: formData.get('email'),
19:     password: formData.get('password'),
20:     next: formData.get('next') ?? undefined,
21:   });
22: 
23:   if (!parsed.success) {
24:     return {
25:       ok: false,
26:       error: parsed.error.issues[0]?.message ?? 'Datos invalidos',
27:     };
28:   }
29: 
30:   const supabase = await createSupabaseServerClient();
31:   const { data, error } = await supabase.auth.signInWithPassword({
32:     email: parsed.data.email,
33:     password: parsed.data.password,
34:   });
35: 
36:   if (error || !data.user) {
37:     return { ok: false, error: 'Correo o contrasena incorrectos' };
38:   }
39: 
40:   if (!userHasHumanOSAccess(data.user)) {
41:     await supabase.auth.signOut();
42:     return {
