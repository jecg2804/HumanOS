208:   for (const row of hrAdmins ?? []) {
209:     await enqueueNotification(admin, {
210:       recipientPersonId: row.person_id,
211:       type: NotificationType.OnboardingErrorReported,
212:       subject: `Error reportado por ${person.full_name}`,
213:       body: `Severidad: ${parsed.data.severity}. ${parsed.data.description.slice(0, 200)}`,
214:       templateVariables: {
215:         employee_name: person.full_name,
216:         severity: parsed.data.severity,
217:         description: parsed.data.description,
218:         reported_at: stamp,
219:       },
220:       metadata: {
221:         person_id: personId,
222:         deep_link: `/admin/empleados/${personId}/editar`,
223:         severity: parsed.data.severity,
224:         context: 'onboarding_step_5',
225:       },
226:     });
227:   }
