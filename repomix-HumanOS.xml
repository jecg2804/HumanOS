4312: Migration `038_create_apply_employment_scd2_change`:
4313: 
4314: ```sql
4315: -- Migration 038: SCD-2 helper for hr.employments updates (R12).
4316: -- Closes the current row (sets valid_to=today) and inserts a new row if critical
4317: -- fields changed; otherwise updates the current row in place for non-critical edits.
4318: 
4319: CREATE OR REPLACE FUNCTION hr.apply_employment_scd2_change(
4320:   p_person_id uuid,
4321:   p_position_id uuid,
4322:   p_position_text text,
4323:   p_department_id uuid,
4324:   p_department_text text,
4325:   p_office_id uuid,
4326:   p_office_text text,
4327:   p_supervisor_id uuid,
4328:   p_hire_date date,
4329:   p_app_role text,
4330:   p_employment_type_id uuid,
4331:   p_actor_id uuid
4332: )
4333: RETURNS void
4334: LANGUAGE plpgsql
4335: SECURITY DEFINER
4336: SET search_path = ''
4337: AS $$
4338: DECLARE
4339:   v_current hr.employments%ROWTYPE;
4340:   v_critical_changed boolean := false;
4341: BEGIN
4342:   SELECT * INTO v_current
4343:   FROM hr.employments
4344:   WHERE person_id = p_person_id AND is_current = true;
4345: 
4346:   IF NOT FOUND THEN
4347:     INSERT INTO hr.employments (
4348:       person_id, position_id, position_text, department_id, department_text,
4349:       office_id, office_text, supervisor_id, hire_date, app_role,
4350:       employment_type_id, created_by
4351:     ) VALUES (
4352:       p_person_id, p_position_id, p_position_text, p_department_id, p_department_text,
4353:       p_office_id, p_office_text, p_supervisor_id, p_hire_date, p_app_role,
4354:       p_employment_type_id, p_actor_id
4355:     );
4356:     RETURN;
4357:   END IF;
4358: 
4359:   -- Detect critical changes: position, department, supervisor, app_role, employment_type
4360:   IF (COALESCE(v_current.position_id::text, '') IS DISTINCT FROM COALESCE(p_position_id::text, ''))
4361:      OR (COALESCE(v_current.position_text, '') IS DISTINCT FROM COALESCE(p_position_text, ''))
4362:      OR (COALESCE(v_current.department_id::text, '') IS DISTINCT FROM COALESCE(p_department_id::text, ''))
4363:      OR (COALESCE(v_current.department_text, '') IS DISTINCT FROM COALESCE(p_department_text, ''))
4364:      OR (COALESCE(v_current.supervisor_id::text, '') IS DISTINCT FROM COALESCE(p_supervisor_id::text, ''))
4365:      OR v_current.app_role IS DISTINCT FROM p_app_role
4366:      OR COALESCE(v_current.employment_type_id::text, '') IS DISTINCT FROM COALESCE(p_employment_type_id::text, '')
4367:   THEN
4368:     v_critical_changed := true;
4369:   END IF;
4370: 
4371:   IF v_critical_changed THEN
4372:     UPDATE hr.employments
4373:     SET valid_to = CURRENT_DATE
4374:     WHERE id = v_current.id;
4375: 
4376:     INSERT INTO hr.employments (
4377:       person_id, position_id, position_text, department_id, department_text,
4378:       office_id, office_text, supervisor_id, hire_date, app_role,
4379:       employment_type_id, created_by, created_from
4380:     ) VALUES (
4381:       p_person_id, p_position_id, p_position_text, p_department_id, p_department_text,
4382:       p_office_id, p_office_text, p_supervisor_id, p_hire_date, p_app_role,
4383:       p_employment_type_id, p_actor_id, 'edit'
4384:     );
4385: 
4386:     INSERT INTO audit.log (actor_id, action, record_id, metadata)
4387:     VALUES (p_actor_id, 'employment_scd2_transition', p_person_id,
4388:             jsonb_build_object('previous_employment_id', v_current.id));
4389:   ELSE
4390:     -- Non-critical update in place (office_text adjusts, hire_date typo fix, etc.)
4391:     UPDATE hr.employments
4392:     SET office_id = p_office_id,
4393:         office_text = p_office_text,
4394:         hire_date = p_hire_date,
4395:         updated_at = now()
4396:     WHERE id = v_current.id;
4397:   END IF;
4398: END;
4399: $$;
4400: 
4401: REVOKE EXECUTE ON FUNCTION hr.apply_employment_scd2_change FROM PUBLIC;
4402: GRANT EXECUTE ON FUNCTION hr.apply_employment_scd2_change TO service_role;
4403: ```
