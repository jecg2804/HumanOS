<file path="src/lib/email/send.ts">
 1: import 'server-only';
 2: import { getResend } from './client';
 3: import { renderSolicitudEnviada } from './templates/solicitud-enviada';
 4: import { renderSolicitudDecidida } from './templates/solicitud-decidida';
 5: import { renderDecisionFinal } from './templates/decision-final';
 6: import { getAppUrl } from '@/lib/utils/app-url';
 7: 
 8: export type NotificationType = 'solicitud-enviada' | 'solicitud-decidida' | 'decision-final';
 9: 
10: export type NotificationPayload = {
11:   to: string;
12:   to_name: string;
13:   request_number: string;
14:   request_id: string;
15:   request_type_label: string;
16:   requester_name: string;
17:   decision?: 'Aprobada' | 'Rechazada';
18: };
19: 
20: export type SendResult = { ok: boolean; error?: string };
21: 
22: export async function sendNotification(
23:   type: NotificationType,
24:   payload: NotificationPayload,
25: ): Promise<SendResult> {
26:   const resend = getResend();
27:   if (!resend) {
28:     console.warn('[email] RESEND_API_KEY missing, skipping send', { type, to: payload.to });
29:     return { ok: false, error: 'no-api-key' };
30:   }
31: 
32:   const testMode = process.env.NOTIFICATION_TEST_EMAIL;
33:   const toAddress = testMode || payload.to;
34:   const subjectPrefix = testMode ? `[to=${payload.to}] ` : '';
35:   const link = `${getAppUrl()}/solicitudes/${payload.request_id}`;
36: 
37:   let subject = '';
38:   let html = '';
39: 
40:   switch (type) {
41:     case 'solicitud-enviada': {
42:       const r = renderSolicitudEnviada({ ...payload, link });
43:       subject = r.subject;
44:       html = r.html;
45:       break;
46:     }
47:     case 'solicitud-decidida': {
48:       const r = renderSolicitudDecidida({ ...payload, link });
49:       subject = r.subject;
50:       html = r.html;
51:       break;
52:     }
53:     case 'decision-final': {
54:       if (!payload.decision) {
55:         console.error('[email] decision-final requires decision');
56:         return { ok: false, error: 'missing-decision' };
57:       }
58:       const r = renderDecisionFinal({ ...payload, link, decision: payload.decision });
59:       subject = r.subject;
60:       html = r.html;
61:       break;
62:     }
63:   }
64: 
65:   const { error } = await resend.emails.send({
66:     from: process.env.RESEND_FROM_EMAIL ?? 'HumanOS <noreply@rein-eisenwerk.com>',
67:     to: toAddress,
68:     subject: `${subjectPrefix}${subject}`,
69:     html,
70:   });
71: 
72:   if (error) {
73:     console.error('[email] resend error', error);
74:     return { ok: false, error: String(error) };
75:   }
76:   return { ok: true };
77: }
</file>

<file path="Docs/CHANGELOG.md">
  1: # HumanOS Changelog
  2: 
  3: Formato: cada sesión agrega una entrada con fecha. Para cambios de BD usar `[bd]` (Code aplica directo en branch).
  4: 
  5: ---
  6: 
  7: ## 2026-04-28 — Branch + schema inicial
  8: 
  9: ### [bd] Branch Supabase aislado
 10: - Creado branch `humanos-dev` en Supabase, project_ref `woonbmfmconldxbeqdnr`.
 11: - Costo: $0.01344/hr.
 12: - Aislamiento: NO comparte data con producción (`bzeoszympkkicwlfdtcn`) ni staging.
 13: 
 14: ### [bd] Schema `humanos` creado desde cero en el branch
 15: - `humanos.people` — tabla consolidada con identidad + datos personales + laborales (28 columnas). 239 empleados migrados desde `ICONSA EmployeeDatabase version datos.xlsx` (sheet "Database"): 52 activos, 187 históricos. Emails limpiados de prefijo `mailto:` residual del Excel. Duplicados por re-contratación disambiguados con sufijo numérico (Hector Pino 2, Marisa Pozza 2, Stefani Madrid 2, Jorge Torres 2, Argelia Ugarte 2, Andrés Solís 2). RLS habilitado, audit columns (`created_at`, `updated_at`, trigger).
 16:   - **Deuda técnica documentada** en `CLAUDE.md`: tabla mal normalizada (1 tabla con 28 cols mezclando 3 dominios). Aceptado para velocidad del MVP. Code puede normalizar si bloquea.
 17: - `humanos.request_types` — 12 tipos de solicitud seeded con sop_reference, approval_chain, category, icon. Tipos: VACACIONES, PERMISO, ACTUALIZACION_DATOS, CONSTANCIA_TRABAJO, HORAS_EXTRAS, PRESTAMO, ACCION_PERSONAL, RECLAMO_PAGO, LIQUIDACION, REFERENCIA_LABORAL, CAPACITACION, ENTREVISTA_SALIDA.
 18: - `humanos.requests` — solicitudes. FKs a request_types y people. form_data JSONB. Estados: Borrador → Enviada → En Revisión → Aprobada/Rechazada → Completada/Cancelada.
 19: - `humanos.request_approvals` — cadena de aprobaciones por solicitud. FK approver_id → people. decision: Pendiente/Aprobada/Rechazada/Solicita Info.
 20: - `humanos.sequences` — auto-numeración (formato HUM-YYYY-NNNN).
 21: 
 22: ### Repo
 23: - 39 SOPs y formularios de RRHH agregados a `Docs/SOPs, Formularios y Documentos/` (PDFs originales de ICONSA). Code los consulta directamente cuando trabaja en cada formulario.
 24: - `CLAUDE.md`, `humanos-mvp-spec.md`, `.claude/rules/supabase-branch.md`, `Docs/CHANGELOG.md` actualizados para reflejar arquitectura branch + DDL/DML libre en `humanos.*`.
 25: - `.claude/rules/supabase-readonly.md` REMOVIDO (reemplazado por `supabase-branch.md`).
 26: - `Docs/feature-specs/MODULE-1-SOLICITUDES.md` creado — guía priorizada de los 5 forms P1.
 27: 
 28: ---
 29: 
 30: ## 2026-04-28 — Module 1 implementación (Fase 0)
