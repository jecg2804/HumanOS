<file path="src/lib/forms/error-utils.ts">
 1: import type { FieldErrors, FieldValues } from 'react-hook-form';
 2: 
 3: /**
 4:  * Recolecta todos los mensajes de error de un objeto de errores de React Hook Form,
 5:  * caminando recursivamente por estructuras anidadas (objects + arrays). Devuelve
 6:  * mensajes únicos en el orden en que aparecen.
 7:  */
 8: export function collectErrorMessages<T extends FieldValues>(
 9:   errors: FieldErrors<T>,
10: ): string[] {
11:   const out: string[] = [];
12:   function walk(node: unknown) {
13:     if (!node || typeof node !== 'object') return;
14:     const obj = node as Record<string, unknown>;
15:     if (typeof obj.message === 'string') out.push(obj.message);
16:     for (const k of Object.keys(obj)) {
17:       if (k !== 'message' && k !== 'ref' && k !== 'type') walk(obj[k]);
18:     }
19:   }
20:   walk(errors);
21:   return Array.from(new Set(out));
22: }
</file>

