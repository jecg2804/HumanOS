1312:   v_type_id uuid; v_request_id uuid; v_number text;
1313:   v_role text; v_approver uuid; v_step int := 1; v_first uuid := NULL;
1314: BEGIN
1315:   SELECT id INTO v_type_id FROM humanos.request_types
1316:    WHERE code = p_type_code AND is_active = true;
