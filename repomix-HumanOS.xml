 23: };
 24: 
 25: export type AdminTableType = {
 26:   id: string;
 27:   code: string;
 28:   name: string;
 29: };
 30: 
 31: type Props = {
 32:   rows: AdminTableRow[];
 33:   types: AdminTableType[];
 34:   initial: {
 35:     pendientesMias: boolean;
 36:     vencidas: boolean;
 37:     desdeIso: string | null;
 38:   };
