179:             {filtered.length} {filtered.length === 1 ? 'resultado' : 'resultados'}
180:             {hasAnyFilter ? ' (filtrado)' : ''}
181:           </p>
182:         </div>
183:         <div className="flex gap-2">
184:           {hasAnyFilter ? (
185:             <button
186:               type="button"
187:               onClick={clearAll}
188:               className="text-sm text-neutral-600 underline hover:text-neutral-900"
189:             >
190:               Limpiar filtros
191:             </button>
192:           ) : null}
193:           <button
