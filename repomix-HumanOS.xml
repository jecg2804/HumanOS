5132: - [ ] **Step 21.2: Implement route handler**
5133: 
5134: Create `src/app/api/cron/process-notifications/route.ts`:
5135: 
5136: ```typescript
5137: // Vercel Cron worker. Schedule: */5 * * * * (declared in vercel.ts).
5138: // Auth: x-vercel-cron header (Vercel-signed) + Authorization: Bearer ${CRON_SECRET}.
5139: // Reads notifications.outbox WHERE channel='email' AND status='pending'.
5140: // Renders @react-email template + sends via Resend with Reply-To.
5141: //
5142: // ADR-0006 exception: uses service_role admin client (worker has no user session).
5143: 
5144: import { NextResponse } from 'next/server';
5145: import { Resend } from 'resend';
5146: import { createSupabaseAdminClient } from '@/lib/supabase/admin';
5147: import * as Templates from '@/emails';  // barrel export
5148: import type { Database } from '@/lib/supabase/database.types';
5149: 
5150: type OutboxRow = Database['notifications']['Tables']['outbox']['Row'];
5151: 
5152: const MAX_PER_TICK = 50;
5153: 
5154: export async function GET(request: Request) {
5155:   // Auth gate
5156:   const isVercelCron = request.headers.get('x-vercel-cron') === '1';
5157:   const authHeader = request.headers.get('authorization');
5158:   const expected = `Bearer ${process.env.CRON_SECRET}`;
5159:   if (!isVercelCron && authHeader !== expected) {
5160:     return NextResponse.json({ error: 'Unauthorized' }, { status: 401 });
5161:   }
5162: 
5163:   // Pre-flight env check
5164:   if (!process.env.RESEND_API_KEY || !process.env.RESEND_FROM_EMAIL) {
5165:     console.warn('[cron] RESEND_API_KEY or RESEND_FROM_EMAIL missing — skipping cycle');
5166:     return NextResponse.json({ skipped: true, reason: 'env missing' });
5167:   }
5168: 
5169:   const supabase = createSupabaseAdminClient();
5170:   const resend = new Resend(process.env.RESEND_API_KEY);
5171: 
5172:   const { data: rows, error } = await supabase
5173:     .schema('notifications')
5174:     .from('outbox')
5175:     .select('id, recipient_id, subject, body, template_code, template_variables, attempts, max_attempts')
5176:     .eq('channel', 'email')
5177:     .eq('status', 'pending')
5178:     .lt('attempts', 3)
5179:     .order('created_at', { ascending: true })
5180:     .limit(MAX_PER_TICK);
5181: 
5182:   if (error) {
5183:     console.error('[cron] fetch failed:', error);
5184:     return NextResponse.json({ error: error.message }, { status: 500 });
5185:   }
5186: 
5187:   let sent = 0;
5188:   let failed = 0;
5189: 
5190:   for (const row of (rows as OutboxRow[]) ?? []) {
5191:     try {
5192:       const { data: person } = await supabase
5193:         .schema('hr')
5194:         .from('people')
5195:         .select('auth_id, full_name')
5196:         .eq('id', row.recipient_id)
5197:         .maybeSingle();
5198: 
5199:       if (!person?.auth_id) {
5200:         await markFailed(supabase, row.id, 'No auth_id for recipient', row.attempts + 1);
5201:         failed++;
5202:         continue;
5203:       }
5204: 
5205:       const userResult = await supabase.auth.admin.getUserById(person.auth_id);
5206:       const recipientEmail = userResult.data.user?.email;
5207:       if (!recipientEmail) {
5208:         await markFailed(supabase, row.id, 'No email on auth.user', row.attempts + 1);
5209:         failed++;
5210:         continue;
5211:       }
5212: 
5213:       const Template = (Templates as Record<string, React.ComponentType<Record<string, unknown>>>)[row.template_code];
5214:       if (!Template) {
5215:         await markFailed(supabase, row.id, `Template ${row.template_code} not found`, row.attempts + 1);
5216:         failed++;
5217:         continue;
5218:       }
5219: 
5220:       // Reply-To pattern: skip for password_reset (self-service)
5221:       const replyTo = row.template_code === 'PasswordReset' ? undefined : process.env.RESEND_REPLY_TO;
5222: 
5223:       const { error: sendErr } = await resend.emails.send({
5224:         from: process.env.RESEND_FROM_EMAIL,
5225:         to: [recipientEmail],
5226:         ...(replyTo ? { reply_to: replyTo } : {}),
5227:         subject: row.subject,
5228:         react: Template((row.template_variables as Record<string, unknown>) ?? {}),
5229:       });
5230: 
5231:       if (sendErr) throw new Error(sendErr.message);
5232: 
5233:       await supabase
5234:         .schema('notifications')
5235:         .from('outbox')
5236:         .update({
5237:           status: 'sent',
5238:           sent_at: new Date().toISOString(),
5239:           attempts: row.attempts + 1,
5240:         })
5241:         .eq('id', row.id);
5242:       sent++;
5243:     } catch (err) {
5244:       await markFailed(supabase, row.id, (err as Error).message, row.attempts + 1);
5245:       failed++;
5246:     }
5247:   }
5248: 
5249:   return NextResponse.json({ processed: rows?.length ?? 0, sent, failed });
5250: }
5251: 
5252: async function markFailed(
5253:   supabase: ReturnType<typeof createSupabaseAdminClient>,
5254:   id: string,
5255:   message: string,
5256:   attempts: number
5257: ) {
5258:   await supabase
5259:     .schema('notifications')
5260:     .from('outbox')
5261:     .update({ status: 'failed', error_message: message, attempts })
5262:     .eq('id', id);
5263: }
5264: ```
