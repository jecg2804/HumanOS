183: ### 4.2 Nuevas funciones Postgres
184: 
185: ```sql
186: -- Resuelve un role semántico + requester a un person uuid (o NULL si no aplica).
187: CREATE FUNCTION humanos.resolve_approver(p_role text, p_requester_id uuid)
188: RETURNS uuid LANGUAGE plpgsql STABLE SECURITY DEFINER AS $$
189: DECLARE
190:   v_id uuid;
191: BEGIN
192:   IF p_role = 'supervisor_directo' THEN
193:     SELECT supervisor_id INTO v_id FROM humanos.people WHERE id = p_requester_id;
194:     IF v_id IS NULL THEN
195:       RAISE NOTICE 'resolve_approver: requester % has no supervisor_id, skipping step', p_requester_id;
196:     END IF;
197:     RETURN v_id;
198:   ELSIF p_role = 'hr_oficial' THEN
199:     SELECT id INTO v_id FROM humanos.people WHERE code = 'OLM206';
200:   ELSIF p_role = 'hr_planilla' THEN
201:     SELECT id INTO v_id FROM humanos.people WHERE code = 'MAN943';
202:   ELSIF p_role = 'hr_gerente' THEN
203:     SELECT id INTO v_id FROM humanos.people WHERE code = 'KOSM01';
204:   ELSIF p_role = 'presidencia' THEN
205:     SELECT id INTO v_id FROM humanos.people WHERE code = 'EIS772';
206:   ELSE
207:     RAISE EXCEPTION 'unknown role: %', p_role;
208:   END IF;
209:   RETURN v_id;
210: END;
211: $$;
212: 
213: -- Genera el siguiente request_number formato HUM-YYYY-NNNN, atómico.
214: CREATE FUNCTION humanos.next_request_number()
215: RETURNS text LANGUAGE plpgsql AS $$
216: DECLARE
217:   v_n bigint;
218: BEGIN
219:   UPDATE humanos.sequences SET current_value = current_value + 1
220:   WHERE name = 'request_number'
221:   RETURNING current_value INTO v_n;
222:   RETURN format('HUM-%s-%s', extract(year from now())::int, lpad(v_n::text, 4, '0'));
223: END;
224: $$;
225: 
226: -- Submit atómico: crea request + N approvals (skipping NULL approvers).
227: -- Retorna {request_id, request_number, first_approver_id}.
228: CREATE FUNCTION humanos.submit_request(
229:   p_type_code text,
230:   p_requester_id uuid,
231:   p_form_data jsonb,
232:   p_attachments jsonb,
233:   p_approval_chain text[]   -- chain resuelto por el caller (puede diferir del default p.ej. PRESTAMO>$250)
234: ) RETURNS TABLE(request_id uuid, request_number text, first_approver_id uuid)
235: LANGUAGE plpgsql AS $$
236: DECLARE
237:   v_type_id uuid;
238:   v_request_id uuid;
239:   v_number text;
240:   v_role text;
241:   v_approver uuid;
242:   v_step int := 1;
243:   v_first uuid := NULL;
244: BEGIN
245:   SELECT id INTO v_type_id FROM humanos.request_types WHERE code = p_type_code AND is_active = true;
246:   IF v_type_id IS NULL THEN RAISE EXCEPTION 'unknown or inactive type: %', p_type_code; END IF;
247: 
248:   v_number := humanos.next_request_number();
249: 
250:   INSERT INTO humanos.requests (request_number, type_id, requester_id, status, form_data, attachments, date_submitted)
251:   VALUES (v_number, v_type_id, p_requester_id, 'Enviada', p_form_data, p_attachments, now())
252:   RETURNING id INTO v_request_id;
253: 
254:   FOREACH v_role IN ARRAY p_approval_chain LOOP
255:     v_approver := humanos.resolve_approver(v_role, p_requester_id);
256:     IF v_approver IS NOT NULL THEN
257:       INSERT INTO humanos.request_approvals (request_id, approver_id, step_order, role_required, decision)
258:       VALUES (v_request_id, v_approver, v_step, v_role, 'Pendiente');
259:       IF v_first IS NULL THEN v_first := v_approver; END IF;
260:       v_step := v_step + 1;
261:     END IF;
262:   END LOOP;
263: 
264:   -- Si chain queda vacío (todos se omitieron) → auto-aprobada
265:   IF v_first IS NULL THEN
266:     UPDATE humanos.requests SET status = 'Aprobada', date_resolved = now() WHERE id = v_request_id;
267:   END IF;
268: 
269:   RETURN QUERY SELECT v_request_id, v_number, v_first;
270: END;
271: $$;
272: 
273: -- Decisión atómica de un step: actualiza approval, deduce siguiente paso o cierra.
274: -- Retorna {request_status, next_approver_id, is_final}.
275: CREATE FUNCTION humanos.decide_approval(
276:   p_approval_id uuid,
277:   p_decider_id uuid,    -- el caller (validar = approver_id)
278:   p_decision text,      -- 'Aprobada' | 'Rechazada' | 'Solicita Info'
279:   p_comments text
280: ) RETURNS TABLE(request_status text, next_approver_id uuid, is_final boolean)
281: LANGUAGE plpgsql AS $$
282: DECLARE
283:   v_approval humanos.request_approvals%ROWTYPE;
284:   v_request_id uuid;
285:   v_next humanos.request_approvals%ROWTYPE;
286:   v_status text;
287: BEGIN
288:   SELECT * INTO v_approval FROM humanos.request_approvals WHERE id = p_approval_id FOR UPDATE;
289:   IF v_approval.id IS NULL THEN RAISE EXCEPTION 'approval not found'; END IF;
290:   IF v_approval.approver_id != p_decider_id THEN RAISE EXCEPTION 'not your approval'; END IF;
291:   IF v_approval.decision != 'Pendiente' THEN RAISE EXCEPTION 'already decided'; END IF;
292:   IF p_decision NOT IN ('Aprobada','Rechazada','Solicita Info') THEN RAISE EXCEPTION 'bad decision'; END IF;
293: 
294:   v_request_id := v_approval.request_id;
295: 
296:   UPDATE humanos.request_approvals
297:      SET decision = p_decision, comments = p_comments, decided_at = now()
298:    WHERE id = p_approval_id;
299: 
300:   IF p_decision = 'Rechazada' THEN
301:     UPDATE humanos.requests SET status='Rechazada', date_resolved=now() WHERE id=v_request_id;
302:     RETURN QUERY SELECT 'Rechazada'::text, NULL::uuid, true;
303:     RETURN;
304:   END IF;
305: 
306:   -- 'Solicita Info': por ahora se trata igual que aprobada parcial, pero conservamos comments
307:   -- (UI v1 NO expone "Solicita Info" como acción separada — solo aprobar/rechazar).
308: 
309:   SELECT * INTO v_next
310:     FROM humanos.request_approvals
311:    WHERE request_id = v_request_id AND decision = 'Pendiente'
312:    ORDER BY step_order ASC LIMIT 1;
313: 
314:   IF v_next.id IS NULL THEN
315:     UPDATE humanos.requests SET status='Aprobada', date_resolved=now() WHERE id=v_request_id;
316:     RETURN QUERY SELECT 'Aprobada'::text, NULL::uuid, true;
317:   ELSE
318:     UPDATE humanos.requests SET status='En Revisión' WHERE id=v_request_id AND status='Enviada';
319:     RETURN QUERY SELECT 'En Revisión'::text, v_next.approver_id, false;
320:   END IF;
321: END;
322: $$;
323: ```
