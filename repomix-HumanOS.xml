 468:   'Multi-app gating helper. Returns at most 1 row matching email or phone. '
 469:   'GRANT EXECUTE only to service_role. See ADR-0006.';
 470: 
 471: REVOKE EXECUTE ON FUNCTION hr.find_auth_user_by_identifier(text, text) FROM PUBLIC;
 472: REVOKE EXECUTE ON FUNCTION hr.find_auth_user_by_identifier(text, text) FROM anon, authenticated;
 473: GRANT EXECUTE ON FUNCTION hr.find_auth_user_by_identifier(text, text) TO service_role;
