<file path="src/lib/approvals/apply-act-datos.ts">
 1: 'use server';
 2: import { revalidatePath } from 'next/cache';
 3: import { createServerClient } from '@/lib/supabase/server';
 4: import { getMe } from '@/lib/auth/getMe';
 5: 
 6: type FormDataAct = {
 7:   direccion?: { calle_barriada?: string; apartamento_casa_no?: string };
 8:   celular_personal?: string;
 9:   estado_civil?: 'Soltero(a)' | 'Casado(a)' | 'Unido(a)';
10:   dependientes?: Array<{ nombre: string; parentesco: string }>;
11: };
12: 
13: export async function applyActDatosAction(requestId: string): Promise<void> {
14:   const me = await getMe();
15:   if (me.role !== 'hr_admin') {
16:     throw new Error('No autorizado: solo Recursos Humanos puede aplicar cambios al expediente.');
17:   }
18: 
19:   const supa = await createServerClient();
20: 
21:   const { data: req, error: reqErr } = await supa
22:     .from('requests')
23:     .select('id, status, requester_id, form_data, type_id')
24:     .eq('id', requestId)
25:     .single();
26:   if (reqErr || !req) throw new Error('Solicitud no encontrada');
27:   if (req.status !== 'Aprobada') {
28:     throw new Error('Solo solicitudes Aprobadas pueden aplicarse al expediente.');
29:   }
30: 
31:   const { data: type } = await supa
32:     .from('request_types')
33:     .select('code')
34:     .eq('id', req.type_id)
35:     .single();
36:   if (type?.code !== 'ACTUALIZACION_DATOS') {
37:     throw new Error('Esta acción solo aplica a solicitudes de Actualización de Datos.');
38:   }
39: 
40:   const fd = (req.form_data ?? {}) as FormDataAct;
41:   const updates: Record<string, unknown> = {};
42: 
43:   if (fd.direccion) {
44:     const addr = [fd.direccion.calle_barriada, fd.direccion.apartamento_casa_no]
45:       .filter((x): x is string => Boolean(x && x.trim()))
46:       .join(', ');
47:     if (addr) updates.address = addr;
48:   }
49:   if (fd.celular_personal && fd.celular_personal.trim()) {
50:     updates.phone = fd.celular_personal.trim();
51:   }
52:   if (fd.estado_civil) {
53:     updates.marital_status = fd.estado_civil;
54:   }
55:   if (Array.isArray(fd.dependientes)) {
56:     updates.num_kids = fd.dependientes.length;
57:   }
58: 
59:   if (Object.keys(updates).length > 0) {
60:     const { error: upErr } = await supa.from('people').update(updates).eq('id', req.requester_id);
61:     if (upErr) throw new Error(`Error al actualizar perfil: ${upErr.message}`);
