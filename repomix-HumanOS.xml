 604: **Issue I1 resolution**: NO migration nueva para `notification_preferences`. La tabla `hr.user_settings` ya tiene columna `preferences jsonb NOT NULL DEFAULT '{}'` (verificado BD). Usaremos namespace `preferences->'notifications'` con shape `{ notifications: { email: {<type>: bool}, sms: {}, whatsapp: {} } }`. El helper `notifications.enqueue` lee de ahí. Si el usuario no tiene el namespace inicializado, fallback a defaults TRUE para todos los types email (opt-in implícito hasta que F33 settings UI permita configurar).
 605: 
 606: - [ ] **Step 4.1: Apply migration 036**
 607: 
 608: ```sql
 609: -- Migration 036: indexes for worker query + enqueue helper (Issue I1: uses preferences jsonb namespace).
 610: 
 611: CREATE INDEX IF NOT EXISTS idx_outbox_worker_pending
 612: ON notifications.outbox (channel, status, scheduled_for)
 613: WHERE status = 'pending';
 614: 
 615: CREATE INDEX IF NOT EXISTS idx_outbox_recipient_unread
 616: ON notifications.outbox (recipient_id, status, created_at DESC)
 617: WHERE channel = 'in_app' AND status IN ('pending', 'queued', 'sent');
 618: 
 619: -- Helper to insert outbox respecting user preferences from preferences->'notifications'.
 620: -- ALWAYS inserts in_app; conditionally inserts email if opted-in (default TRUE if namespace absent).
 621: CREATE OR REPLACE FUNCTION notifications.enqueue(
 622:   p_recipient_id uuid,
 623:   p_notification_type text,
 624:   p_subject text,
 625:   p_body text,
 626:   p_template_code text,
 627:   p_template_variables jsonb,
 628:   p_metadata jsonb
 629: )
 630: RETURNS void
 631: LANGUAGE plpgsql
 632: SECURITY DEFINER
 633: SET search_path = ''
 634: AS $$
 635: DECLARE
 636:   v_email_opted_in boolean;
 637:   v_pref jsonb;
 638: BEGIN
 639:   -- Always queue in-app
 640:   INSERT INTO notifications.outbox (
 641:     recipient_id, channel, status, subject, body,
 642:     template_code, template_variables, metadata, notification_type
 643:   ) VALUES (
 644:     p_recipient_id, 'in_app', 'pending', p_subject, p_body,
 645:     p_template_code, p_template_variables, p_metadata, p_notification_type
 646:   );
 647: 
 648:   -- Check email opt-in via preferences->'notifications'->'email'->>type
 649:   -- If namespace absent OR type absent in namespace → default TRUE (opt-in implicit until F33 UI)
 650:   SELECT preferences -> 'notifications' -> 'email' -> p_notification_type
 651:   INTO v_pref
 652:   FROM hr.user_settings
 653:   WHERE person_id = p_recipient_id;
 654: 
 655:   v_email_opted_in := COALESCE(v_pref::boolean, true);
 656: 
 657:   IF v_email_opted_in THEN
 658:     INSERT INTO notifications.outbox (
 659:       recipient_id, channel, status, subject, body,
 660:       template_code, template_variables, metadata, notification_type
 661:     ) VALUES (
 662:       p_recipient_id, 'email', 'pending', p_subject, p_body,
 663:       p_template_code, p_template_variables, p_metadata, p_notification_type
 664:     );
 665:   END IF;
 666: END;
 667: $$;
 668: 
 669: COMMENT ON FUNCTION notifications.enqueue IS
 670:   'Insert outbox row(s). Always in_app; email conditional on user preferences. '
 671:   'Call from within server action transaction. ADR-0008 pattern INSERT.';
