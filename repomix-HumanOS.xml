  1: 'use client';
  2: import { useMemo, useState } from 'react';
  3: import { useRouter } from 'next/navigation';
  4: import { useForm, type FieldErrors } from 'react-hook-form';
  5: import { zodResolver } from '@hookform/resolvers/zod';
  6: import {
  7:   reclamoPagoSchema,
  8:   type ReclamoPagoData,
  9:   RECLAMO_CATEGORIAS,
 10:   makeEmptyReclamoTabla,
 11: } from '@/lib/forms/schemas/reclamo-pago';
 12: import { submitRequestAction } from '@/lib/approvals/submit';
 13: import { collectErrorMessages } from '@/lib/forms/error-utils';
 14: import { createBrowserClient } from '@/lib/supabase/browser';
 15: import { Button } from '@/components/ui/button';
 16: import { Input } from '@/components/ui/input';
 17: import { Label } from '@/components/ui/label';
 18: import {
 19:   Card,
 20:   CardContent,
 21:   CardHeader,
 22:   CardTitle,
 23: } from '@/components/ui/card';
 24: 
 25: const MAX_FILES = 3;
 26: const MAX_BYTES = 10 * 1024 * 1024; // 10MB
 27: const ALLOWED_MIMES = [
 28:   'image/jpeg',
 29:   'image/png',
 30:   'image/webp',
 31:   'application/pdf',
 32: ] as const;
 33: const SIGNED_URL_TTL_SECONDS = 60 * 60 * 24 * 365; // 1 año
 34: 
 35: function computeDiferencia(
 36:   empleado: number | null,
 37:   supervisor: number | null,
 38: ): number | null {
 39:   if (empleado === null && supervisor === null) return null;
 40:   return (empleado ?? 0) - (supervisor ?? 0);
 41: }
 42: 
 43: function formatNumber(n: number | null): string {
 44:   if (n === null) return '—';
 45:   // Mostrar sin decimales si es entero, sino con 2 decimales.
 46:   return Number.isInteger(n)
 47:     ? n.toString()
 48:     : n.toLocaleString('en-US', {
 49:         minimumFractionDigits: 2,
 50:         maximumFractionDigits: 2,
 51:       });
 52: }
 53: 
 54: function formatBytes(bytes: number): string {
 55:   if (bytes < 1024) return `${bytes} B`;
 56:   if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
 57:   return `${(bytes / (1024 * 1024)).toFixed(2)} MB`;
 58: }
 59: 
 60: export function ReclamoPagoForm() {
 61:   const router = useRouter();
 62:   const [submitError, setSubmitError] = useState<string | null>(null);
 63:   const [pendingFiles, setPendingFiles] = useState<File[]>([]);
 64:   const [fileError, setFileError] = useState<string | null>(null);
 65:   const [uploadStatus, setUploadStatus] = useState<string | null>(null);
 66: 
 67:   const form = useForm<ReclamoPagoData>({
 68:     resolver: zodResolver(reclamoPagoSchema),
 69:     defaultValues: {
 70:       periodo: { desde: '', hasta: '' },
 71:       tabla: makeEmptyReclamoTabla(),
 72:       descripcion: '',
 73:     },
 74:   });
 75: 
 76:   // Watch tabla para mostrar diferencia calculada en tiempo real.
 77:   const tablaWatched = form.watch('tabla');
 78:   const diferenciasCalculadas = useMemo(
 79:     () =>
 80:       tablaWatched.map((fila) =>
 81:         computeDiferencia(fila.empleado, fila.supervisor),
 82:       ),
 83:     [tablaWatched],
 84:   );
 85: 
 86:   function handleFilesChange(e: React.ChangeEvent<HTMLInputElement>) {
 87:     setFileError(null);
 88:     const incoming = Array.from(e.target.files ?? []);
 89:     if (incoming.length === 0) return;
 90: 
 91:     const combined = [...pendingFiles];
 92:     for (const file of incoming) {
 93:       if (combined.length >= MAX_FILES) {
 94:         setFileError(`Máximo ${MAX_FILES} archivos.`);
 95:         break;
 96:       }
 97:       if (file.size > MAX_BYTES) {
 98:         setFileError(`"${file.name}" excede el límite de 10MB.`);
 99:         continue;
100:       }
101:       if (!ALLOWED_MIMES.includes(file.type as (typeof ALLOWED_MIMES)[number])) {
102:         setFileError(
103:           `"${file.name}" no es un tipo permitido (jpg, png, webp, pdf).`,
104:         );
105:         continue;
106:       }
107:       // Evitar duplicados por nombre+tamaño.
108:       if (
109:         combined.some((f) => f.name === file.name && f.size === file.size)
110:       ) {
111:         continue;
112:       }
113:       combined.push(file);
114:     }
115:     setPendingFiles(combined);
116:     // Reset input para permitir re-seleccionar el mismo archivo si lo quitas.
117:     e.target.value = '';
118:   }
119: 
120:   function removeFile(index: number) {
121:     setPendingFiles((prev) => prev.filter((_, i) => i !== index));
122:   }
123: 
124:   async function onSubmit(values: ReclamoPagoData) {
125:     setSubmitError(null);
126:     setUploadStatus(null);
127: 
128:     // Inyectar diferencia calculada en cada fila antes del submit.
129:     const tablaConDiferencia = values.tabla.map((fila) => ({
130:       ...fila,
131:       diferencia: computeDiferencia(fila.empleado, fila.supervisor),
132:     }));
133:     const formData: ReclamoPagoData = {
134:       ...values,
135:       tabla: tablaConDiferencia,
136:     };
137: 
138:     // Subir archivos si los hay.
139:     const attachments: Array<{
140:       name: string;
141:       url: string;
142:       mime: string;
143:       size: number;
144:     }> = [];
145: 
146:     if (pendingFiles.length > 0) {
147:       try {
148:         const supa = createBrowserClient();
149:         const tempUuid =
150:           typeof crypto !== 'undefined' && 'randomUUID' in crypto
151:             ? crypto.randomUUID()
152:             : `${Date.now()}-${Math.random().toString(36).slice(2)}`;
153: 
154:         for (let i = 0; i < pendingFiles.length; i++) {
155:           const file = pendingFiles[i];
156:           setUploadStatus(`Subiendo ${i + 1} de ${pendingFiles.length}…`);
157: 
158:           // Sanitizar nombre: reemplazar caracteres problemáticos.
159:           const safeName = file.name.replace(/[^a-zA-Z0-9._-]/g, '_');
160:           const path = `${tempUuid}/${safeName}`;
161: 
162:           const { error: uploadErr } = await supa.storage
163:             .from('humanos-attachments')
164:             .upload(path, file, {
165:               contentType: file.type,
166:               upsert: false,
167:             });
168:           if (uploadErr) {
169:             throw new Error(
170:               `Error subiendo ${file.name}: ${uploadErr.message}`,
171:             );
172:           }
173: 
174:           const { data: signed, error: signErr } = await supa.storage
175:             .from('humanos-attachments')
176:             .createSignedUrl(path, SIGNED_URL_TTL_SECONDS);
