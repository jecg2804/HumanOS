 58:         )}
 59:         <Field label="Celular personal" value={data.celular_personal} />
 60:       </Section>
 61: 
 62:       <Section title="Estado civil">
 63:         <Field label="Estado" value={data.estado_civil} />
 64:         {tienePareja && data.pareja && (
 65:           <>
 66:             <Field label="Nombre de pareja" value={data.pareja.nombre} />
 67:             <Field label="Teléfono de pareja" value={data.pareja.telefono} />
 68:           </>
 69:         )}
 70:       </Section>
 71: 
 72:       <Section title="Dependientes">
