30:         severity: 'leve' | 'critica';
31:         should_pause_wizard: boolean;
32:       };
33:       if (d.should_pause_wizard) {
34:         dispatch({ type: 'PAUSE_CRITICAL_ERROR' });
35:       } else {
36:         onClose();
37:         dispatch({ type: 'NEXT_STEP' });
38:       }
39:     }
40:   }, [actionState, dispatch, onClose]);
41: 
42:   return (
43:     <div className="fixed inset-0 bg-black/50 flex items-center justify-center p-4">
44:       <div className="bg-white rounded-lg p-6 max-w-md w-full">
45:         <h2 className="text-lg font-bold">Reportar error en tus datos</h2>
46:         <form action={formAction} className="space-y-4 mt-4">
47:           <input type="hidden" name="person_id" value={state.validated?.person_id ?? ''} />
48:           <div>
49:             <label className="block text-sm font-medium mb-1">Severidad</label>
50:             <select name="severity" className="w-full p-3 border rounded" defaultValue="">
51:               <option value="" disabled>
52:                 Selecciona…
53:               </option>
54:               <option value="leve">
55:                 Leve — puedo continuar (cargo levemente distinto, departamento mal categorizado)
56:               </option>
57:               <option value="critica">
58:                 Crítica — no debo continuar (nombre mal escrito, cédula incorrecta, supervisor
59:                 incorrecto)
60:               </option>
61:             </select>
62:           </div>
63:           <div>
64:             <label className="block text-sm font-medium mb-1">Describe el error</label>
65:             <textarea
66:               name="description"
67:               rows={4}
68:               required
69:               minLength={5}
70:               className="w-full p-3 border rounded"
71:               placeholder="Mi cargo dice 'Ingeniero' pero soy 'Ingeniero Civil Senior'"
72:             />
73:           </div>
74:           {actionState.errors && (
75:             <ul className="text-sm text-red-600">
76:               {Object.entries(actionState.errors).map(([k, v]) => (
77:                 <li key={k}>{v?.[0]}</li>
78:               ))}
79:             </ul>
80:           )}
81:           <div className="flex justify-end gap-2">
82:             <button type="button" onClick={onClose} className="px-4 py-2 border rounded">
83:               Cancelar
84:             </button>
85:             <button
86:               type="submit"
87:               disabled={pending}
88:               className="px-4 py-2 bg-[#1B3A5C] text-white rounded disabled:opacity-50"
89:             >
90:               {pending ? 'Enviando…' : 'Enviar reporte'}
91:             </button>
92:           </div>
93:         </form>
94:       </div>
95:     </div>
96:   );
97: }
</file>

<file path="src/components/onboarding/Step10PhotoConfirm.tsx">
  1: 'use client';
  2: import { useState } from 'react';
  3: import { useRouter } from 'next/navigation';
  4: import Image from 'next/image';
  5: import { resizeImage } from '@/lib/storage/avatars';
  6: import {
  7:   completeOnboardingAction,
  8:   uploadOnboardingAvatarAction,
  9: } from '@/lib/onboarding/actions';
 10: import type { WizardState, WizardAction } from './WizardReducer';
 11: 
 12: interface Props {
 13:   state: WizardState;
 14:   dispatch: React.Dispatch<WizardAction>;
 15: }
 16: 
 17: export function Step10PhotoConfirm({ state, dispatch }: Props) {
 18:   const [file, setFile] = useState<File | null>(null);
 19:   const [previewUrl, setPreviewUrl] = useState<string | null>(null);
 20:   const [uploading, setUploading] = useState(false);
 21:   const [uploadError, setUploadError] = useState<string | null>(null);
 22:   const [submitting, setSubmitting] = useState(false);
 23:   const [submitError, setSubmitError] = useState<string | null>(null);
 24:   const router = useRouter();
 25: 
 26:   const handleFile = (f: File) => {
 27:     setFile(f);
 28:     setPreviewUrl(URL.createObjectURL(f));
 29:     setUploadError(null);
 30:   };
 31: 
 32:   const tryUpload = async (): Promise<string | null> => {
 33:     if (!file || !state.validated) return state.photo_path;
 34:     setUploading(true);
 35:     setUploadError(null);
 36:     try {
 37:       const blob = await resizeImage(file);
 38:       const fd = new FormData();
 39:       fd.append('invite_id', state.validated.invite_id);
 40:       fd.append('person_id', state.validated.person_id);
 41:       fd.append('photo', blob, 'current.jpg');
 42:       const result = await uploadOnboardingAvatarAction(fd);
 43:       if (!result.ok || !result.path) {
 44:         throw new Error(result.error ?? 'Upload falló');
 45:       }
 46:       dispatch({ type: 'SET_PHOTO', path: result.path });
 47:       return result.path;
 48:     } catch (err) {
 49:       setUploadError((err as Error).message);
 50:       return null;
 51:     } finally {
 52:       setUploading(false);
 53:     }
 54:   };
 55: 
 56:   const handleSubmit = async () => {
 57:     if (!state.validated) return;
 58:     setSubmitting(true);
 59:     setSubmitError(null);
 60: 
 61:     let photoPath: string | null = state.photo_path;
 62:     if (file && !state.photo_path) {
 63:       photoPath = await tryUpload();
 64:       if (!photoPath && file) {
 65:         const proceed = window.confirm(
 66:           'La foto no se pudo subir. ¿Continuar sin foto o reintentar?\n' +
 67:             'Aceptar = continuar sin foto. Cancelar = volver a intentar.'
 68:         );
 69:         if (!proceed) {
 70:           setSubmitting(false);
 71:           return;
 72:         }
 73:         photoPath = null;
 74:       }
 75:     }
 76: 
 77:     const result = await completeOnboardingAction({
 78:       invite_id: state.validated.invite_id,
 79:       person_id: state.validated.person_id,
 80:       target_field: state.validated.target_field,
 81:       normalized_target: state.validated.normalized_target,
 82:       password: state.validated.existing_multi_app_user ? null : state.password,
 83:       emergency: state.emergency,
 84:       medical: state.medical,
 85:       address: state.address,
 86:       ack_ethics_at: state.ack_ethics_at!,
 87:       ack_child_labor_at: state.ack_child_labor_at!,
 88:       photo_path: photoPath,
 89:     });
 90: 
 91:     if (!result.ok) {
 92:       setSubmitError(result.message ?? 'Onboarding falló');
 93:       setSubmitting(false);
 94:       return;
 95:     }
 96: 
 97:     router.push((result.data as { redirect_to: string }).redirect_to);
 98:   };
 99: 
100:   return (
101:     <section className="space-y-4">
102:       <h1 className="text-2xl font-bold text-[#1B3A5C]">Foto de perfil (opcional)</h1>
103:       <p className="text-gray-700">
104:         Sube una foto para tu perfil interno (gafete, directorio). Puedes saltarte este paso y
105:         agregarla después desde tu perfil.
106:       </p>
107:       <div className="flex flex-col items-center gap-3">
108:         {previewUrl ? (
109:           <Image
110:             src={previewUrl}
111:             alt="Vista previa"
112:             width={128}
113:             height={128}
114:             unoptimized
115:             className="w-32 h-32 object-cover rounded-full border-2 border-gray-300"
116:           />
117:         ) : (
118:           <div className="w-32 h-32 rounded-full bg-gray-200 flex items-center justify-center text-gray-400">
119:             Sin foto
120:           </div>
121:         )}
122:         <label className="cursor-pointer text-sm text-[#0A6EBD] underline">
123:           {file ? 'Cambiar foto' : 'Subir foto'}
124:           <input
125:             type="file"
126:             accept="image/jpeg,image/png,image/webp"
127:             capture="user"
128:             onChange={(e) => e.target.files?.[0] && handleFile(e.target.files[0])}
129:             className="hidden"
130:           />
131:         </label>
132:         {uploadError && <p className="text-sm text-red-600">{uploadError}</p>}
133:       </div>
134:       {submitError && (
135:         <div className="bg-red-50 border border-red-200 rounded p-3 text-sm text-red-700">
136:           {submitError}
137:         </div>
138:       )}
139:       <div className="flex gap-2">
140:         <button
141:           onClick={() => dispatch({ type: 'PREV_STEP' })}
142:           disabled={submitting}
143:           className="px-4 py-2 border rounded"
144:         >
145:           Atrás
146:         </button>
147:         <button
148:           onClick={handleSubmit}
149:           disabled={submitting || uploading}
150:           className="flex-1 bg-[#1A7F5A] text-white py-3 rounded-md font-medium disabled:opacity-50"
151:         >
152:           {submitting ? 'Activando cuenta…' : 'Confirmar y activar mi cuenta'}
153:         </button>
154:       </div>
155:     </section>
156:   );
157: }
</file>

