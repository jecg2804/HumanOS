1305: ```sql
1306: CREATE OR REPLACE FUNCTION humanos.submit_request(
1307:   p_type_code text, p_requester_id uuid, p_form_data jsonb,
1308:   p_attachments jsonb, p_approval_chain text[]
1309: ) RETURNS TABLE(request_id uuid, request_number text, first_approver_id uuid)
