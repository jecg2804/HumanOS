 24: export interface WizardState {
 25:   step: number;
 26:   validated: ValidatedContext | null;
 27:   code: string;
 28:   cedula: string;
 29:   employee_code: string;
 30:   delivery_target: string;
 31:   password: string;
 32:   emergency: {
 33:     contact_name: string;
 34:     relationship: string;
 35:     phone: string;
 36:     phone_alt: string;
 37:   };
 38:   medical: Record<string, string>;
 39:   address: {
 40:     street: string;
 41:     neighborhood: string;
 42:     city: string;
 43:     province: string;
 44:     postal_code: string;
 45:   };
 46:   ack_ethics_at: string | null;
 47:   ack_child_labor_at: string | null;
 48:   photo_path: string | null;
 49:   pausedDueToCriticalError: boolean;
 50: }
 51: 
 52: export const initialState: WizardState = {
 53:   step: 1,
 54:   validated: null,
 55:   code: '',
 56:   cedula: '',
 57:   employee_code: '',
 58:   delivery_target: '',
 59:   password: '',
 60:   emergency: { contact_name: '', relationship: '', phone: '', phone_alt: '' },
 61:   medical: {},
 62:   address: { street: '', neighborhood: '', city: '', province: '', postal_code: '' },
 63:   ack_ethics_at: null,
 64:   ack_child_labor_at: null,
 65:   photo_path: null,
 66:   pausedDueToCriticalError: false,
 67: };
 68: 
 69: export type WizardAction =
 70:   | { type: 'SET_FIELD'; key: keyof WizardState; value: WizardState[keyof WizardState] }
 71:   | { type: 'SET_NESTED'; section: 'emergency' | 'address' | 'medical'; key: string; value: string }
 72:   | {
 73:       type: 'VALIDATED';
 74:       payload: ValidatedContext;
 75:       code: string;
 76:       cedula: string;
 77:       employee_code: string;
 78:       delivery_target: string;
 79:     }
 80:   | { type: 'NEXT_STEP' }
 81:   | { type: 'PREV_STEP' }
 82:   | { type: 'GO_TO'; step: number }
 83:   | { type: 'SET_PHOTO'; path: string }
 84:   | { type: 'ACK'; key: 'ack_ethics_at' | 'ack_child_labor_at'; at: string }
 85:   | { type: 'PAUSE_CRITICAL_ERROR' }
 86:   | { type: 'RESET' };
 87: 
 88: export function wizardReducer(state: WizardState, action: WizardAction): WizardState {
 89:   switch (action.type) {
 90:     case 'SET_FIELD':
 91:       return { ...state, [action.key]: action.value };
 92:     case 'SET_NESTED':
 93:       return {
 94:         ...state,
 95:         [action.section]: { ...state[action.section], [action.key]: action.value },
 96:       };
 97:     case 'VALIDATED':
 98:       return {
 99:         ...state,
100:         validated: action.payload,
101:         code: action.code,
102:         cedula: action.cedula,
103:         employee_code: action.employee_code,
104:         delivery_target: action.delivery_target,
105:         step: action.payload.existing_multi_app_user ? 5 : 4,
106:       };
107:     case 'NEXT_STEP': {
108:       let next = state.step + 1;
109:       if (next === 4 && state.validated?.existing_multi_app_user) next = 5;
110:       return { ...state, step: Math.min(next, 10) };
111:     }
112:     case 'PREV_STEP': {
113:       let prev = state.step - 1;
114:       if (prev === 4 && state.validated?.existing_multi_app_user) prev = 3;
115:       return { ...state, step: Math.max(prev, 1) };
116:     }
117:     case 'GO_TO':
118:       return { ...state, step: action.step };
119:     case 'SET_PHOTO':
120:       return { ...state, photo_path: action.path };
121:     case 'ACK':
122:       return { ...state, [action.key]: action.at };
123:     case 'PAUSE_CRITICAL_ERROR':
124:       return { ...state, pausedDueToCriticalError: true };
125:     case 'RESET':
126:       return initialState;
127:     default:
128:       return state;
129:   }
130: }
</file>

