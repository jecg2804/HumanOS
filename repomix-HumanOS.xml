  2: import { useState } from 'react';
  3: import { useRouter } from 'next/navigation';
  4: import { useForm, useFieldArray, type FieldErrors } from 'react-hook-form';
  5: import { zodResolver } from '@hookform/resolvers/zod';
  6: import { vacacionesSchema, type VacacionesData } from '@/lib/forms/schemas/vacaciones';
  7: import { submitRequestAction } from '@/lib/approvals/submit';
  8: import { collectErrorMessages } from '@/lib/forms/error-utils';
  9: import { Button } from '@/components/ui/button';
 10: import { Input } from '@/components/ui/input';
 11: import { Label } from '@/components/ui/label';
 12: 
 13: const PAGO_OPTS = [
 14:   'Completas',
 15:   'Adelanto sobre acumulado',
 16:   'Descuento de días solicitados',
 17: ] as const;
 18: 
 19: const TIEMPO_OPTS = ['Completas', 'Parciales'] as const;
 20: 
 21: export function VacacionesForm() {
 22:   const router = useRouter();
 23:   const [submitError, setSubmitError] = useState<string | null>(null);
 24: 
 25:   const form = useForm<VacacionesData>({
 26:     resolver: zodResolver(vacacionesSchema),
 27:     defaultValues: {
 28:       pago_vacaciones: 'Completas',
 29:       tiempo_solicitado: 'Completas',
 30:       desglose: [{ desde: '', hasta: '' }],
 31:       observaciones: '',
 32:     },
 33:   });
 34: 
 35:   const { fields, append, remove } = useFieldArray({
 36:     control: form.control,
 37:     name: 'desglose',
 38:   });
 39: 
 40:   const tiempo = form.watch('tiempo_solicitado');
 41: 
 42:   async function onSubmit(values: VacacionesData) {
 43:     setSubmitError(null);
 44:     try {
 45:       const res = await submitRequestAction({
 46:         typeCode: 'VACACIONES',
 47:         formData: values,
 48:         attachments: [],
 49:       });
 50:       router.push(`/solicitudes/${res.requestId}`);
 51:     } catch (e) {
 52:       setSubmitError(e instanceof Error ? e.message : 'Error al enviar');
 53:     }
 54:   }
 55: 
 56:   return (
 57:     <form onSubmit={form.handleSubmit(onSubmit)} className="space-y-6 max-w-2xl">
 58:       <fieldset className="space-y-2">
 59:         <Label className="text-base font-semibold">Pago de Vacaciones</Label>
 60:         <div className="space-y-1.5">
 61:           {PAGO_OPTS.map((opt) => (
 62:             <label key={opt} className="flex items-center gap-2 text-sm">
 63:               <input
 64:                 type="radio"
 65:                 value={opt}
 66:                 {...form.register('pago_vacaciones')}
 67:                 className="h-4 w-4"
 68:               />
 69:               {opt}
 70:             </label>
 71:           ))}
 72:         </div>
 73:       </fieldset>
 74: 
 75:       <fieldset className="space-y-2">
 76:         <Label className="text-base font-semibold">Tiempo Solicitado</Label>
 77:         <div className="space-y-1.5">
 78:           {TIEMPO_OPTS.map((opt) => (
 79:             <label key={opt} className="flex items-center gap-2 text-sm">
 80:               <input
 81:                 type="radio"
 82:                 value={opt}
 83:                 {...form.register('tiempo_solicitado')}
 84:                 className="h-4 w-4"
 85:               />
 86:               {opt}
 87:             </label>
 88:           ))}
 89:         </div>
 90:       </fieldset>
 91: 
 92:       <fieldset className="space-y-3">
 93:         <Label className="text-base font-semibold">Desglose del tiempo a solicitar</Label>
 94:         {fields.map((f, i) => (
 95:           <div key={f.id} className="flex flex-col sm:flex-row gap-2 sm:items-end">
 96:             <div className="flex-1">
 97:               <Label htmlFor={`desde-${i}`} className="text-xs">
 98:                 Del
 99:               </Label>
100:               <Input
101:                 id={`desde-${i}`}
102:                 type="date"
103:                 {...form.register(`desglose.${i}.desde` as const)}
104:               />
105:             </div>
106:             <div className="flex-1">
107:               <Label htmlFor={`hasta-${i}`} className="text-xs">
108:                 Al
109:               </Label>
110:               <Input
111:                 id={`hasta-${i}`}
112:                 type="date"
113:                 {...form.register(`desglose.${i}.hasta` as const)}
114:               />
115:             </div>
116:             {i > 0 && (
117:               <Button type="button" variant="outline" size="sm" onClick={() => remove(i)}>
118:                 Quitar
119:               </Button>
120:             )}
121:           </div>
122:         ))}
123:         {tiempo === 'Parciales' && fields.length < 3 && (
124:           <Button
125:             type="button"
126:             variant="outline"
127:             size="sm"
128:             onClick={() => append({ desde: '', hasta: '' })}
129:           >
130:             + Agregar rango
131:           </Button>
132:         )}
133:       </fieldset>
134: 
135:       <fieldset className="space-y-1">
136:         <Label htmlFor="observaciones">Observaciones (opcional)</Label>
137:         <textarea
138:           id="observaciones"
139:           {...form.register('observaciones')}
140:           rows={3}
141:           className="w-full border rounded px-3 py-2 text-sm"
142:         />
143:       </fieldset>
144: 
145:       <FormErrors errors={form.formState.errors} />
146:       {submitError && <p className="text-sm text-red-600">{submitError}</p>}
147: 
148:       <div className="flex gap-2 sticky bottom-0 bg-white py-3 border-t md:border-t-0 md:relative md:bg-transparent">
149:         <Button type="submit" disabled={form.formState.isSubmitting}>
150:           {form.formState.isSubmitting ? 'Enviando…' : 'Enviar solicitud'}
151:         </Button>
152:         <Button type="button" variant="outline" onClick={() => router.push('/solicitudes/nueva')}>
153:           Cancelar
154:         </Button>
155:       </div>
156:     </form>
157:   );
158: }
159: 
160: function FormErrors({ errors }: { errors: FieldErrors<VacacionesData> }) {
161:   const messages = collectErrorMessages(errors);
162:   if (messages.length === 0) return null;
163:   return (
164:     <ul className="text-sm text-red-600 space-y-0.5">
165:       {messages.map((m, i) => (
166:         <li key={i}>• {m}</li>
167:       ))}
168:     </ul>
169:   );
170: }
