368: export async function uploadOnboardingAvatarAction(formData: FormData): Promise<{
369:   ok: boolean;
370:   path?: string;
371:   error?: string;
372: }> {
373:   const inviteId = formData.get('invite_id') as string | null;
374:   const personId = formData.get('person_id') as string | null;
375:   const file = formData.get('photo') as File | null;
376:   if (!inviteId || !personId || !file) {
377:     return { ok: false, error: 'Datos faltantes para subir foto' };
378:   }
379: 
380:   const admin = createSupabaseAdminClient();
381: 
382:   const { data: invite } = await admin
383:     .schema('hr')
384:     .from('invite_codes')
385:     .select('id, person_id, consumed_at, expires_at')
386:     .eq('id', inviteId)
387:     .maybeSingle();
388: 
389:   if (!invite || invite.person_id !== personId) {
390:     return { ok: false, error: 'Invitación no válida para este empleado' };
391:   }
392:   if (invite.consumed_at) {
393:     return { ok: false, error: 'Invitación ya consumida' };
394:   }
395:   if (new Date(invite.expires_at) < new Date()) {
396:     return { ok: false, error: 'Invitación expirada' };
397:   }
398: 
399:   const mimeToExt: Record<string, string> = {
400:     'image/jpeg': 'jpg',
401:     'image/png': 'png',
402:     'image/webp': 'webp',
403:   };
404:   const ext = mimeToExt[file.type];
405:   if (!ext) {
406:     return { ok: false, error: 'Formato no soportado. Usa JPG, PNG o WebP.' };
407:   }
408: 
409:   const path = `${personId}/current.${ext}`;
410:   const buffer = await file.arrayBuffer();
411:   const { error: uploadErr } = await admin.storage
412:     .from('avatars')
413:     .upload(path, new Uint8Array(buffer), {
414:       contentType: file.type,
415:       upsert: true,
416:     });
417: 
418:   if (uploadErr) {
419:     return { ok: false, error: `Upload falló: ${uploadErr.message}` };
420:   }
421: 
422:   return { ok: true, path: `avatars/${path}` };
423: }
</file>

<file path="src/lib/storage/avatars.ts">
 1: import type { SupabaseClient } from '@supabase/supabase-js';
 2: import type { Database } from '@/lib/supabase/database.types';
 3: 
 4: type AnySchemaClient =
 5:   | SupabaseClient
 6:   | SupabaseClient<Database, keyof Omit<Database, '__InternalSupabase'>>;
 7: 
 8: export const ALLOWED_MIME = ['image/jpeg', 'image/png', 'image/webp'] as const;
 9: export const MAX_FILE_SIZE_BYTES = 5 * 1024 * 1024;
10: export const TARGET_DIMENSION = 800;
11: export const JPEG_QUALITY = 0.85;
12: export const POST_RESIZE_LIMIT_BYTES = 1024 * 1024;
13: 
14: export function validateMime(mime: string): boolean {
15:   return (ALLOWED_MIME as readonly string[]).includes(mime);
16: }
17: 
18: export async function resizeImage(file: File): Promise<Blob> {
19:   if (!validateMime(file.type)) {
20:     throw new Error('Formato no soportado. Usa JPG, PNG o WebP.');
21:   }
22:   if (file.size > MAX_FILE_SIZE_BYTES) {
23:     throw new Error('Archivo muy grande. Máximo 5MB antes de procesar.');
24:   }
25:   const img = await loadImage(file);
26:   const canvas = document.createElement('canvas');
27:   const ratio = Math.min(TARGET_DIMENSION / img.width, TARGET_DIMENSION / img.height, 1);
28:   canvas.width = Math.round(img.width * ratio);
29:   canvas.height = Math.round(img.height * ratio);
30:   const ctx = canvas.getContext('2d');
31:   if (!ctx) throw new Error('Canvas context no disponible');
32:   ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
33:   const blob = await new Promise<Blob>((resolve, reject) => {
34:     canvas.toBlob(
35:       (b) => (b ? resolve(b) : reject(new Error('Canvas toBlob failed'))),
36:       'image/jpeg',
37:       JPEG_QUALITY
38:     );
39:   });
40:   if (blob.size > POST_RESIZE_LIMIT_BYTES) {
41:     throw new Error(
42:       `Imagen demasiado grande después de procesar (${Math.round(blob.size / 1024)}KB). Intenta una foto más pequeña.`
43:     );
44:   }
45:   return blob;
46: }
47: 
48: function loadImage(file: File): Promise<HTMLImageElement> {
49:   return new Promise((resolve, reject) => {
50:     const img = new Image();
51:     img.onload = () => resolve(img);
52:     img.onerror = () => reject(new Error('No se pudo leer la imagen'));
53:     img.src = URL.createObjectURL(file);
54:   });
55: }
56: 
57: // Use for F5 admin edit + F33 self-service. Wizard step 10 must use
58: // uploadOnboardingAvatarAction (server action) because user is not yet authenticated.
59: export async function uploadAvatar(
60:   client: AnySchemaClient,
61:   personId: string,
62:   blob: Blob
63: ): Promise<string> {
64:   const path = `${personId}/current.jpg`;
65:   const { error } = await client.storage
66:     .from('avatars')
67:     .upload(path, blob, { contentType: 'image/jpeg', upsert: true });
68:   if (error) throw new Error(`Upload falló: ${error.message}`);
69:   return `avatars/${path}`;
70: }
71: 
72: export async function getAvatarSignedUrl(
73:   client: AnySchemaClient,
74:   path: string,
75:   ttlSeconds = 3600
76: ): Promise<string> {
77:   const cleanPath = path.startsWith('avatars/') ? path.slice('avatars/'.length) : path;
78:   const { data, error } = await client.storage.from('avatars').createSignedUrl(cleanPath, ttlSeconds);
79:   if (error || !data) throw new Error(`Signed URL falló: ${error?.message}`);
80:   return data.signedUrl;
81: }
</file>

