 14: import { decideApprovalAction } from '@/lib/approvals/decide';
 15: import type { AppRole, RequestStatus } from '@/types/database';
 16: 
 17: export type RequestActionsContext = {
 18:   request: {
 19:     id: string;
 20:     status: RequestStatus;
 21:     requester_id: string;
 22:     type_code: string;
 23:   };
 24:   me: {
 25:     id: string;
 26:     role: AppRole;
 27:   };
 28:   myPendingApprovalId: string | null;
 29: };
 30: 
 31: export function RequestActions({ ctx }: { ctx: RequestActionsContext }) {
 32:   const { request, me, myPendingApprovalId } = ctx;
 33: 
 34:   const isRequester = request.requester_id === me.id;
 35:   const isHr = me.role === 'hr_admin';
 36:   const canApply =
 37:     isHr && request.status === 'Aprobada' && request.type_code === 'ACTUALIZACION_DATOS';
 38:   const canDecide = myPendingApprovalId !== null;
 39: 
 40:   if (!canApply && !canDecide) {
 41:     if (isRequester && request.status === 'Borrador') {
 42:       return <p className="text-sm text-neutral-500">Acciones de borrador próximamente.</p>;
 43:     }
 44:     return null;
 45:   }
 46: 
 47:   return (
 48:     <div className="flex flex-wrap gap-2">
 49:       {canDecide && myPendingApprovalId && (
 50:         <DecideButtons approvalId={myPendingApprovalId} />
 51:       )}
 52:       {canApply && <ApplyButton requestId={request.id} />}
 53:     </div>
 54:   );
 55: }
 56: 
 57: function DecideButtons({ approvalId }: { approvalId: string }) {
 58:   const [isPending, startTransition] = useTransition();
 59:   const [open, setOpen] = useState<null | 'Aprobada' | 'Rechazada'>(null);
 60:   const [comments, setComments] = useState('');
 61:   const [error, setError] = useState<string | null>(null);
 62: 
 63:   function submit() {
 64:     if (!open) return;
 65:     setError(null);
 66:     const decision = open;
 67:     startTransition(async () => {
 68:       try {
 69:         await decideApprovalAction({ approvalId, decision, comments });
 70:         setOpen(null);
 71:         setComments('');
 72:       } catch (e) {
 73:         setError(e instanceof Error ? e.message : 'Error al decidir');
 74:       }
 75:     });
 76:   }
 77: 
 78:   return (
 79:     <>
 80:       <Button onClick={() => setOpen('Aprobada')} disabled={isPending}>
 81:         Aprobar
 82:       </Button>
 83:       <Button variant="outline" onClick={() => setOpen('Rechazada')} disabled={isPending}>
 84:         Rechazar
 85:       </Button>
 86:       <Dialog open={open !== null} onOpenChange={(v) => !v && setOpen(null)}>
 87:         <DialogContent>
 88:           <DialogHeader>
 89:             <DialogTitle>{open === 'Aprobada' ? 'Aprobar solicitud' : 'Rechazar solicitud'}</DialogTitle>
 90:             <DialogDescription>
 91:               {open === 'Aprobada'
 92:                 ? 'Confirma la aprobación. Puedes agregar un comentario opcional.'
 93:                 : 'Indica el motivo del rechazo. El solicitante recibirá tu comentario.'}
 94:             </DialogDescription>
 95:           </DialogHeader>
 96:           <textarea
 97:             value={comments}
 98:             onChange={(e) => setComments(e.target.value)}
 99:             rows={4}
100:             placeholder={open === 'Aprobada' ? 'Comentario (opcional)' : 'Motivo del rechazo'}
101:             className="w-full border rounded px-3 py-2 text-sm"
102:           />
103:           {error && <p className="text-sm text-red-600">{error}</p>}
104:           <DialogFooter>
105:             <Button variant="outline" onClick={() => setOpen(null)} disabled={isPending}>
106:               Cancelar
107:             </Button>
108:             <Button
109:               onClick={submit}
110:               disabled={isPending || (open === 'Rechazada' && comments.trim().length < 5)}
111:             >
112:               {isPending ? 'Procesando…' : 'Confirmar'}
113:             </Button>
114:           </DialogFooter>
115:         </DialogContent>
116:       </Dialog>
117:     </>
118:   );
119: }
120: 
121: function ApplyButton({ requestId }: { requestId: string }) {
122:   const router = useRouter();
123:   const [isPending, startTransition] = useTransition();
124:   const [open, setOpen] = useState(false);
125:   const [error, setError] = useState<string | null>(null);
126: 
127:   function apply() {
128:     setError(null);
129:     startTransition(async () => {
130:       try {
131:         await applyActDatosAction(requestId);
132:         setOpen(false);
133:         router.refresh();
134:       } catch (e) {
135:         setError(e instanceof Error ? e.message : 'Error al aplicar');
136:       }
137:     });
138:   }
139: 
140:   return (
141:     <>
142:       <Button onClick={() => setOpen(true)} disabled={isPending} style={{ background: '#1A7F5A' }}>
143:         Aplicar al expediente
144:       </Button>
145:       <Dialog open={open} onOpenChange={(v) => !v && setOpen(false)}>
146:         <DialogContent>
147:           <DialogHeader>
148:             <DialogTitle>Aplicar cambios al expediente</DialogTitle>
149:             <DialogDescription>
150:               Esto actualizará el perfil del empleado en <code>humanos.people</code> con los nuevos
151:               datos: dirección, celular, estado civil y número de dependientes. Los detalles de
152:               pareja y dependientes individuales se conservan en el historial de la solicitud pero
153:               no se aplican al expediente.
154:             </DialogDescription>
155:           </DialogHeader>
156:           {error && <p className="text-sm text-red-600">{error}</p>}
157:           <DialogFooter>
158:             <Button variant="outline" onClick={() => setOpen(false)} disabled={isPending}>
159:               Cancelar
160:             </Button>
161:             <Button onClick={apply} disabled={isPending} style={{ background: '#1A7F5A' }}>
162:               {isPending ? 'Aplicando…' : 'Confirmar y aplicar'}
163:             </Button>
164:           </DialogFooter>
165:         </DialogContent>
166:       </Dialog>
167:     </>
168:   );
169: }
</file>

