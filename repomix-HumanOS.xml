<file path="src/lib/onboarding/normalize.ts">
 1: export function normalizeNationalId(input: string): string {
 2:   return input.trim().replace(/[^0-9A-Za-z]/g, '').toUpperCase();
 3: }
 4: 
 5: export function normalizePhone(input: string): string {
 6:   const stripped = input.replace(/[^\d+]/g, '');
 7:   if (stripped.startsWith('+507') && stripped.length === 12) return stripped;
 8:   if (/^\d{8}$/.test(stripped)) return `+507${stripped}`;
 9:   throw new Error('Teléfono inválido. Usa formato +507XXXXXXXX o 8 dígitos.');
10: }
</file>

