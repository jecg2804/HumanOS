 529:       setAll: (cookiesToSet) => {
 530:         cookiesToSet.forEach(({ name, value }) => request.cookies.set(name, value));
 531:         response = NextResponse.next({ request });
 532:         cookiesToSet.forEach(({ name, value, options }) =>
 533:           response.cookies.set(name, value, options)
 534:         );
 535:       },
 536:     },
 537:   });
 538: 
 539:   const { data: { user } } = await supabase.auth.getUser();
 540:   return { supabase, response, user };
