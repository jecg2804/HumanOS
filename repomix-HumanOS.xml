 18: # ============================================================
 19: H1 "1. CLAUDE CODE CLI"
 20: # ============================================================
 21: $claudeVer = (claude --version 2>&1 | Out-String).Trim()
 22: INFO "Version: $claudeVer"
 23: 
 24: # ============================================================
 25: H1 "2. CONFIG FILES USER-LEVEL"
 26: # ============================================================
 27: 
 28: H2 "~/.claude.json (mcpServers manuales, enabledMcpjsonServers)"
 29: $ucj = "$HOME\.claude.json"
 30: if (Test-Path $ucj) {
 31:     try {
 32:         $j = Get-Content $ucj -Raw | ConvertFrom-Json
 33:         $sz = (Get-Item $ucj).Length
 34:         OK "Existe ($sz bytes, JSON valido)"
 35:         if ($j.mcpServers) {
 36:             $servers = $j.mcpServers.PSObject.Properties
 37:             INFO "  mcpServers configurados: $($servers.Count)"
 38:             $servers | ForEach-Object { INFO "    - $($_.Name)" }
 39:         } else { NO "  Sin mcpServers" }
 40:     } catch { NO "JSON invalido: $($_.Exception.Message)" }
 41: } else { NO "No existe" }
 42: 
 43: H2 "~/.claude/settings.json (enabledPlugins)"
 44: $ucs = "$HOME\.claude\settings.json"
 45: if (Test-Path $ucs) {
 46:     try {
 47:         $s = Get-Content $ucs -Raw | ConvertFrom-Json
 48:         $sz = (Get-Item $ucs).Length
 49:         OK "Existe ($sz bytes, JSON valido)"
 50:         if ($s.enabledPlugins) {
 51:             $enabled = $s.enabledPlugins.PSObject.Properties | Where-Object Value -eq $true
 52:             INFO "  enabledPlugins: $($enabled.Count)"
 53:             $enabled | Select-Object -First 5 | ForEach-Object { INFO "    - $($_.Name)" }
 54:             if ($enabled.Count -gt 5) { INFO "    ... y $($enabled.Count - 5) mas" }
 55:         } else { NO "  Sin enabledPlugins" }
 56:     } catch { NO "JSON invalido: $($_.Exception.Message)" }
 57: } else { NO "No existe (este es el archivo que se borro)" }
 58: 
 59: H2 "BOM check en archivos config"
 60: @($ucj, $ucs) | ForEach-Object {
 61:     if (Test-Path $_) {
 62:         $bytes = [System.IO.File]::ReadAllBytes($_) | Select-Object -First 3
 63:         $hasBOM = ($bytes.Count -ge 3 -and $bytes[0] -eq 0xEF -and $bytes[1] -eq 0xBB -and $bytes[2] -eq 0xBF)
 64:         $name = ($_ -split '\\')[-1]
 65:         if ($hasBOM) { NO "$name TIENE BOM (problematico)" } else { OK "$name sin BOM" }
 66:     }
 67: }
