1391: 
1392: (Copia exacta del bloque `decide_approval` en spec §4.2 + smoke al final que crea un request dummy con 2 approvals, decide ambos, y verifica transiciones.)
1393: 
1394: ```sql
1395: CREATE OR REPLACE FUNCTION humanos.decide_approval(
1396:   p_approval_id uuid, p_decider_id uuid, p_decision text, p_comments text
1397: ) RETURNS TABLE(request_status text, next_approver_id uuid, is_final boolean)
1398: LANGUAGE plpgsql AS $$
1399: DECLARE
1400:   v_approval humanos.request_approvals%ROWTYPE;
1401:   v_request_id uuid;
1402:   v_next humanos.request_approvals%ROWTYPE;
1403: BEGIN
1404:   SELECT * INTO v_approval FROM humanos.request_approvals WHERE id = p_approval_id FOR UPDATE;
1405:   IF v_approval.id IS NULL THEN RAISE EXCEPTION 'approval not found'; END IF;
1406:   IF v_approval.approver_id != p_decider_id THEN RAISE EXCEPTION 'not your approval'; END IF;
1407:   IF v_approval.decision != 'Pendiente' THEN RAISE EXCEPTION 'already decided'; END IF;
1408:   IF p_decision NOT IN ('Aprobada','Rechazada','Solicita Info') THEN RAISE EXCEPTION 'bad decision'; END IF;
1409: 
1410:   v_request_id := v_approval.request_id;
1411: 
1412:   UPDATE humanos.request_approvals SET decision=p_decision, comments=p_comments, decided_at=now()
1413:   WHERE id = p_approval_id;
1414: 
1415:   IF p_decision = 'Rechazada' THEN
1416:     UPDATE humanos.requests SET status='Rechazada', date_resolved=now() WHERE id=v_request_id;
1417:     RETURN QUERY SELECT 'Rechazada'::text, NULL::uuid, true;
1418:     RETURN;
1419:   END IF;
1420: 
1421:   SELECT * INTO v_next FROM humanos.request_approvals
1422:    WHERE request_id = v_request_id AND decision = 'Pendiente'
1423:    ORDER BY step_order ASC LIMIT 1;
1424: 
1425:   IF v_next.id IS NULL THEN
1426:     UPDATE humanos.requests SET status='Aprobada', date_resolved=now() WHERE id=v_request_id;
1427:     RETURN QUERY SELECT 'Aprobada'::text, NULL::uuid, true;
1428:   ELSE
1429:     UPDATE humanos.requests SET status='En Revisión' WHERE id=v_request_id AND status='Enviada';
1430:     RETURN QUERY SELECT 'En Revisión'::text, v_next.approver_id, false;
1431:   END IF;
1432: END;
1433: $$;
