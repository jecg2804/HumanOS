  3: type DetailData = ActualizacionDatosData & { _changes?: string[] };
  4: 
  5: const PATH_LABELS: Record<string, string> = {
  6:   'direccion.calle_barriada': 'Calle / barriada',
  7:   'direccion.apartamento_casa_no': 'Apartamento / casa No.',
  8:   telefono_casa: 'Teléfono de casa',
  9:   celular_personal: 'Celular personal',
 10:   estado_civil: 'Estado civil',
 11:   pareja: 'Datos de pareja',
 12:   'pareja.nombre': 'Nombre de pareja',
 13:   'pareja.telefono': 'Teléfono de pareja',
 14:   dependientes: 'Dependientes',
 15: };
 16: 
 17: function labelForPath(path: string): string {
 18:   if (PATH_LABELS[path]) return PATH_LABELS[path];
 19:   // Match prefix labels like 'dependientes.0.nombre' -> 'Dependientes'
 20:   for (const key of Object.keys(PATH_LABELS)) {
 21:     if (path.startsWith(`${key}.`)) return PATH_LABELS[key];
 22:   }
 23:   return path;
 24: }
