 71: # ============================================================
 72: $mp = claude plugin marketplace list 2>&1 | Out-String
 73: INFO $mp
 74: 
 75: # ============================================================
 76: H1 "4. PLUGINS DATA FOLDER"
 77: # ============================================================
 78: $pdData = "$HOME\.claude\plugins\data"
 79: if (Test-Path $pdData) {
 80:     $plugins = Get-ChildItem $pdData -Directory
 81:     OK "$pdData existe con $($plugins.Count) plugin dirs"
 82:     $plugins | ForEach-Object { INFO "    - $($_.Name)" }
 83: } else { NO "$pdData no existe" }
 84: 
 85: # ============================================================
 86: H1 "5. CLI TOOLS EXTERNOS"
 87: # ============================================================
 88: $clis = @(
 89:     @{ name = "git"; cmd = "git --version" },
 90:     @{ name = "gh (GitHub CLI)"; cmd = "gh --version" },
 91:     @{ name = "node"; cmd = "node --version" },
 92:     @{ name = "npm"; cmd = "npm --version" },
 93:     @{ name = "vercel"; cmd = "vercel --version" },
 94:     @{ name = "supabase"; cmd = "supabase --version" },
 95:     @{ name = "gemini"; cmd = "gemini --version" }
 96: )
 97: 
 98: foreach ($cli in $clis) {
 99:     try {
100:         $output = Invoke-Expression $cli.cmd 2>&1 | Out-String
101:         if ($LASTEXITCODE -eq 0) {
102:             OK "$($cli.name): $($output.Trim().Split([Environment]::NewLine)[0])"
103:         } else {
104:             NO "$($cli.name): no instalado"
105:         }
106:     } catch { NO "$($cli.name): no instalado" }
107: }
108: 
109: # ============================================================
110: H1 "6. PROJECT REPO STATE"
111: # ============================================================
112: Set-Location $repo
113: 
114: H2 "Project files raiz"
115: @("CLAUDE.md", "PROJECT_CONSTITUTION.md", "package.json", "tsconfig.json", "next.config.ts", "repomix.config.json", "src/app/globals.css") | ForEach-Object {
116:     if (Test-Path $_) {
117:         $sz = (Get-Item $_).Length
118:         OK "$_ ($sz bytes)"
119:     } else { NO "$_ falta" }
120: }
121: 
122: H2 "Project docs (14 esperados)"
123: $docs = Get-ChildItem "docs/*.md" -ErrorAction SilentlyContinue | Where-Object { $_.Name -match "^\d{2}-" }
124: INFO "Total numerados: $($docs.Count)"
125: $docs | ForEach-Object { INFO "    - $($_.Name)" }
126: 
127: H2 ".claude/ del proyecto"
128: if (Test-Path .claude) {
129:     Get-ChildItem .claude -Recurse | ForEach-Object {
130:         $rel = $_.FullName.Replace((Get-Location).Path + "\", "")
131:         if ($_.PSIsContainer) {
132:             Write-Host "  [DIR] $rel" -ForegroundColor Yellow
133:         } else {
134:             $sz = $_.Length
135:             # BOM check para .json y .ps1
136:             $hasBOM = $false
137:             if ($_.Extension -in @(".json", ".ps1")) {
138:                 $bytes = [System.IO.File]::ReadAllBytes($_.FullName) | Select-Object -First 3
139:                 $hasBOM = ($bytes.Count -ge 3 -and $bytes[0] -eq 0xEF -and $bytes[1] -eq 0xBB -and $bytes[2] -eq 0xBF)
140:             }
141:             $bomTag = if ($hasBOM) { " [BOM!]" } else { "" }
142:             Write-Host "        $rel ($sz bytes)$bomTag"
143:         }
144:     }
145: } else { NO ".claude/ no existe" }
146: 
147: H2 ".claude.QUARANTINE-*"
148: Get-ChildItem .claude.QUARANTINE-* -Directory -ErrorAction SilentlyContinue | ForEach-Object {
149:     INFO "  $($_.Name) (preservado)"
150: }
151: 
152: # ============================================================
153: H1 "7. SKILLS EN PROJECT"
154: # ============================================================
155: H2 ".claude/skills/ del proyecto"
156: if (Test-Path ".claude/skills") {
157:     Get-ChildItem ".claude/skills" -Directory | ForEach-Object {
158:         $skillMd = Join-Path $_.FullName "SKILL.md"
159:         if (Test-Path $skillMd) {
160:             $sz = (Get-Item $skillMd).Length
161:             OK "$($_.Name) (SKILL.md: $sz bytes)"
162:         } else {
163:             NO "$($_.Name) sin SKILL.md"
164:         }
165:     }
166: } else {
167:     NO ".claude/skills/ no existe (los matt-pocock se perdieron?)"
168: }
169: 
170: H2 ".agents/ (legacy matt-pocock location)"
171: if (Test-Path ".agents") {
172:     INFO "Existe .agents/ - James menciono que borro"
173: } else {
174:     OK ".agents/ borrado (correcto, movido a .claude/skills/)"
175: }
176: 
177: # ============================================================
178: H1 "8. RESUMEN EJECUTIVO"
179: # ============================================================
180: INFO ""
181: INFO "Estado de Claude Code system:"
182: INFO "- Marketplaces:        ver Seccion 3"
183: INFO "- Plugins instalados:  ver Seccion 4"
184: INFO "- Plugins habilitados: ver Seccion 2 (enabledPlugins)"
185: INFO "- MCPs manuales:       ver Seccion 2 (mcpServers)"
186: INFO ""
187: INFO "Estado del proyecto:"
188: INFO "- Project files: ver Seccion 6"
189: INFO "- Hooks repo:    ver Seccion 6 (.claude/hooks)"
190: INFO "- Skills repo:   ver Seccion 7"
191: INFO ""
192: INFO "ACCION REQUERIDA:"
193: INFO "Si Seccion 3 dice 'No marketplaces configured' o Seccion 4 falta,"
194: INFO "ejecuta el script de reinstall (marketplaces + 19 plugins)."
</file>

<file path=".claude/hooks/post-tool-use.ps1">
 1: # PostToolUse hook - auto-validation after Edit/Write
 2: # Fires AFTER tool execution. Outputs to stdout flow back as additional context.
 3: #
 4: # Validates:
 5: # - .ts/.tsx files modified -> run `npx tsc --noEmit` and report status
 6: # - .sql migrations applied -> remind about COMMENT and RLS checks
 7: 
 8: $ErrorActionPreference = "Continue"
 9: 
10: try {
11:     $input_raw = [Console]::In.ReadToEnd()
12:     if (-not $input_raw) { exit 0 }
13: 
14:     $payload = $input_raw | ConvertFrom-Json -ErrorAction Stop
15:     $toolName = $payload.tool_name
16:     $toolInput = $payload.tool_input
17: 
18:     if (-not $toolName) { exit 0 }
19: 
20:     # TypeScript validation after Edit/Write
21:     if ($toolName -eq "Edit" -or $toolName -eq "Write") {
22:         $filePath = ""
23:         if ($toolInput.file_path) { $filePath = $toolInput.file_path.ToString() }
24: 
25:         if ($filePath -match "\.(ts|tsx)$") {
26:             # Run tsc --noEmit in background-style check
27:             $tscOutput = ""
28:             try {
29:                 $tscOutput = (& npx tsc --noEmit 2>&1 | Out-String).Trim()
30:             } catch {
31:                 $tscOutput = "tsc check failed to run: $($_.Exception.Message)"
32:             }
33: 
34:             if ($tscOutput -match "error TS") {
35:                 $errCount = ([regex]::Matches($tscOutput, "error TS")).Count
36:                 Write-Output ""
37:                 Write-Output "<typescript_check>"
38:                 Write-Output "After editing $($filePath -replace '.*[\\/]','')  tsc --noEmit reports $errCount error(s):"
39:                 Write-Output ""
40:                 $tscOutput.Split("`n") | Where-Object { $_ -match "error TS" } | Select-Object -First 10 | ForEach-Object {
41:                     Write-Output "  $_"
42:                 }
43:                 Write-Output ""
44:                 Write-Output "Fix these before continuing."
45:                 Write-Output "</typescript_check>"
46:             }
47:         }
48:     }
49: 
50:     # SQL migration reminders
51:     if ($toolName -eq "mcp__supabase__apply_migration") {
52:         Write-Output ""
53:         Write-Output "<post_migration_reminders>"
54:         Write-Output "After applying migration, verify:"
55:         Write-Output "1. RLS habilitada en cada tabla nueva (ALTER TABLE ... ENABLE ROW LEVEL SECURITY)"
56:         Write-Output "2. COMMENT ON TABLE + COMMENT ON COLUMN poblados"
57:         Write-Output "3. Golden record: external_ids table + _source column si aplica"
58:         Write-Output "4. Run mcp__supabase__get_advisors to catch policy issues"
59:         Write-Output "</post_migration_reminders>"
60:     }
61: 
62:     exit 0
63: }
64: catch {
65:     $errPath = Join-Path $PSScriptRoot "errors.log"
66:     "[$(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')] post-tool-use error: $($_.Exception.Message)" | Out-File -FilePath $errPath -Append -Encoding utf8NoBOM -ErrorAction SilentlyContinue
67:     exit 0
68: }
</file>

<file path=".claude/hooks/pre-compact.ps1">
 1: # PreCompact hook - preserve state before auto-compaction
 2: # Fires when /compact is invoked. Writes HANDOFF.json with session state.
 3: #
 4: # Why: when conversation compacts, model loses detail. HANDOFF.json provides
 5: # structured state so next turn can recover quickly.
 6: 
 7: $ErrorActionPreference = "Continue"
 8: 
 9: try {
10:     $input_raw = [Console]::In.ReadToEnd()
11:     $payload = $null
12:     if ($input_raw) {
13:         try { $payload = $input_raw | ConvertFrom-Json -ErrorAction Stop } catch {}
14:     }
15: 
16:     # Build handoff snapshot
17:     $handoff = @{
18:         timestamp = (Get-Date -Format "yyyy-MM-ddTHH:mm:ssZ")
19:         cwd = (Get-Location).Path
20:         compact_trigger = if ($payload.trigger) { $payload.trigger.ToString() } else { "manual_or_auto" }
21:     }
22: 
23:     # Git state
24:     try {
25:         $branch = (& git rev-parse --abbrev-ref HEAD 2>&1).Trim()
26:         $lastCommit = (& git log -1 --format="%h %s" 2>&1).Trim()
27:         $status = (& git status --porcelain 2>&1) -split "`n" | Where-Object { $_ } | Select-Object -First 20
28: 
29:         $handoff.git = @{
30:             branch = $branch
31:             last_commit = $lastCommit
32:             uncommitted_changes = $status
33:         }
34:     } catch {
35:         $handoff.git_error = $_.Exception.Message
36:     }
37: 
38:     # Recent files modified
39:     try {
40:         $recent = Get-ChildItem -Recurse -File -Include *.ts,*.tsx,*.sql,*.md -ErrorAction SilentlyContinue |
41:             Where-Object { $_.LastWriteTime -gt (Get-Date).AddHours(-2) -and $_.FullName -notmatch 'node_modules|\.next|\.git' } |
42:             Sort-Object LastWriteTime -Descending |
43:             Select-Object -First 15 -ExpandProperty FullName |
44:             ForEach-Object { $_ -replace [regex]::Escape((Get-Location).Path + "\"), "" }
45:         $handoff.recent_files = $recent
46:     } catch {}
47: 
48:     # Write to Docs/HANDOFF.json (lowercase docs)
49:     $docsDir = Join-Path (Get-Location).Path "docs"
50:     if (-not (Test-Path $docsDir)) {
51:         New-Item -Path $docsDir -ItemType Directory -Force | Out-Null
52:     }
53:     $outPath = Join-Path $docsDir "HANDOFF.json"
54: 
55:     $json = $handoff | ConvertTo-Json -Depth 10
56: 
57:     # Write WITHOUT BOM using .NET (PS 5.1 compatible)
58:     [System.IO.File]::WriteAllText($outPath, $json, [System.Text.UTF8Encoding]::new($false))
59: 
60:     Write-Output ""
61:     Write-Output "<compact_handoff>"
62:     Write-Output "Session state preserved to docs/HANDOFF.json before compaction."
63:     Write-Output "Next turn: read it to recover state."
64:     Write-Output "</compact_handoff>"
65: 
66:     exit 0
67: }
68: catch {
69:     $errPath = Join-Path $PSScriptRoot "errors.log"
70:     "[$(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')] pre-compact error: $($_.Exception.Message)" | Out-File -FilePath $errPath -Append -Encoding utf8NoBOM -ErrorAction SilentlyContinue
71:     exit 0
72: }
</file>

<file path=".claude/hooks/pre-tool-use.ps1">
  1: # PreToolUse hook - deterministic guardrails for HumanOS / ICONSA Database
  2: # Fires BEFORE any tool call executes. Can block by exit 2 + stderr.
  3: #
  4: # Input: JSON via stdin { "tool_name": "...", "tool_input": {...} }
  5: # Output: exit 0 = allow. exit 2 = block (stderr message shown to model).
  6: 
  7: $ErrorActionPreference = "Continue"
  8: 
  9: try {
 10:     $input_raw = [Console]::In.ReadToEnd()
 11:     if (-not $input_raw) { exit 0 }
 12: 
 13:     $payload = $input_raw | ConvertFrom-Json -ErrorAction Stop
 14:     $toolName = $payload.tool_name
 15:     $toolInput = $payload.tool_input
 16: 
 17:     if (-not $toolName) { exit 0 }
 18: 
 19:     # ============================================================
 20:     # CHECK 1: Supabase MCP writes
 21:     # ============================================================
 22:     if ($toolName -match "mcp__(plugin_supabase_supabase|supabase)__(apply_migration|execute_sql|deploy_edge_function)") {
 23:         $sql = ""
 24:         if ($toolInput.query) { $sql = $toolInput.query.ToString() }
 25:         if ($toolInput.body) { $sql = $sql + " " + $toolInput.body.ToString() }
 26:         $sqlLower = $sql.ToLower()
 27: 
 28:         # ----------------------------------------------------------
 29:         # CHECK 1a: Writes to prohibited schemas
 30:         # ----------------------------------------------------------
 31:         $prohibitedSchemas = @("public", "payroll", "humanos")
 32:         $writeKeywords = @(
 33:             "create table",
 34:             "alter table",
 35:             "drop table",
 36:             "create policy",
 37:             "drop policy",
 38:             "alter policy",
 39:             "create function",
 40:             "drop function",
 41:             "create trigger",
 42:             "drop trigger",
 43:             "insert into",
 44:             "update ",
 45:             "delete from",
 46:             "truncate"
 47:         )
 48: 
 49:         foreach ($schema in $prohibitedSchemas) {
 50:             foreach ($kw in $writeKeywords) {
 51:                 $pattern = "$kw\s+(if\s+(not\s+)?exists\s+)?$schema\."
 52:                 if ($sqlLower -match $pattern) {
 53:                     $msg = "BLOCKED: Write to prohibited schema '$schema.*' detected.`n"
 54:                     $msg += "Matched pattern: '$kw $schema.'`n"
 55:                     $msg += "Tool: $toolName`n`n"
 56:                     $msg += "Schemas allowed for HumanOS writes:`n"
 57:                     $msg += "  hr, requests, docs, workflows, audit, notifications, files,`n"
 58:                     $msg += "  performance, learning, mdm, etl, backup`n`n"
 59:                     $msg += "Schemas prohibited (NEVER write):`n"
 60:                     $msg += "  public (MovimientOS production)`n"
 61:                     $msg += "  payroll (compania de Jaime)`n"
 62:                     $msg += "  humanos (legacy v1 demo)`n`n"
 63:                     $msg += "Reads (SELECT) from prohibited schemas are allowed.`n"
 64:                     $msg += "See docs/07-SCHEMAS-PERMISOS.md and docs/05-BUSINESS-RULES.md R1.`n"
 65:                     [Console]::Error.WriteLine($msg)
 66:                     exit 2
 67:                 }
 68:             }
 69:         }
 70: 
 71:         # ----------------------------------------------------------
 72:         # CHECK 1b: Destructive ops on auth.users without filter (R22)
 73:         # Incident 2026-05-25: DELETE FROM auth.users without WHERE
 74:         # erased 17 daily MovimientOS users.
 75:         # ----------------------------------------------------------
 76:         $authDestructivePatterns = @(
 77:             "delete\s+from\s+auth\.users",
 78:             "delete\s+from\s+auth\.identities",
 79:             "truncate\s+(table\s+)?auth\.users",
 80:             "truncate\s+(table\s+)?auth\.identities",
 81:             "drop\s+table\s+(if\s+exists\s+)?auth\.users",
 82:             "drop\s+table\s+(if\s+exists\s+)?auth\.identities"
 83:         )
 84: 
 85:         foreach ($pattern in $authDestructivePatterns) {
 86:             if ($sqlLower -match $pattern) {
 87:                 $hasWhere = $sqlLower -match "where\s+"
 88:                 $hasProperFilter = $sqlLower -match "(app_metadata|allowed_apps|auth_id\s+in\s*\(|id\s+in\s*\(|email\s*=)"
 89: 
 90:                 if (-not $hasWhere) {
 91:                     $msg = "BLOCKED: Destructive operation on auth.users/auth.identities without WHERE clause.`n"
 92:                     $msg += "Matched: '$pattern'`n"
 93:                     $msg += "Tool: $toolName`n`n"
 94:                     $msg += "This is the exact pattern that caused incident 2026-05-25:`n"
 95:                     $msg += "DELETE FROM auth.users; erased 17 daily MovimientOS users.`n`n"
 96:                     $msg += "Required (R22 in docs/05-BUSINESS-RULES.md):`n"
 97:                     $msg += "1. Snapshot first: CREATE TABLE backup.auth_users_YYYYMMDD AS SELECT * FROM auth.users WHERE <filter>;`n"
 98:                     $msg += "2. SELECT preview shown to human BEFORE destructive op`n"
 99:                     $msg += "3. Explicit filter by app_metadata->'allowed_apps' or id IN (explicit_list)`n"
100:                     [Console]::Error.WriteLine($msg)
101:                     exit 2
102:                 }
103: 
104:                 if (-not $hasProperFilter) {
105:                     $msg = "BLOCKED: Destructive op on auth.users has WHERE but no acceptable filter.`n"
106:                     $msg += "Matched: '$pattern'`n`n"
107:                     $msg += "R22 requires filter by one of:`n"
108:                     $msg += "- app_metadata->'allowed_apps' (preferred)`n"
109:                     $msg += "- auth_id IN (explicit list of UUIDs)`n"
110:                     $msg += "- id IN (explicit list)`n"
111:                     $msg += "- email = '...' (single user)`n"
112:                     [Console]::Error.WriteLine($msg)
113:                     exit 2
114:                 }
115:             }
116:         }
117: 
118:         # ----------------------------------------------------------
119:         # CHECK 1c: Destructive ops on golden records without WHERE
120:         # ----------------------------------------------------------
121:         $goldenRecordTables = @(
122:             "hr\.people",
123:             "hr\.employments",
124:             "hr\.org_units",
125:             "hr\.positions",
126:             "requests\.tickets",
127:             "requests\.types"
128:         )
129: 
130:         foreach ($table in $goldenRecordTables) {
131:             $deletePattern = "delete\s+from\s+$table"
132:             $truncatePattern = "truncate\s+(table\s+)?$table"
133:             $updatePattern = "update\s+$table\s+set"
134: 
135:             if (($sqlLower -match $deletePattern) -or ($sqlLower -match $truncatePattern)) {
136:                 if (-not ($sqlLower -match "where\s+")) {
137:                     $tableDisplay = $table -replace "\\", ""
138:                     $msg = "BLOCKED: Destructive op on golden record '$tableDisplay' without WHERE.`n"
139:                     $msg += "Tool: $toolName`n`n"
140:                     $msg += "Required: snapshot + WHERE filter + SELECT preview.`n"
141:                     [Console]::Error.WriteLine($msg)
142:                     exit 2
143:                 }
144:             }
145: 
146:             if ($sqlLower -match $updatePattern) {
147:                 if (-not ($sqlLower -match "where\s+")) {
148:                     $tableDisplay = $table -replace "\\", ""
149:                     $msg = "BLOCKED: Mass UPDATE on golden record '$tableDisplay' without WHERE.`n"
150:                     [Console]::Error.WriteLine($msg)
151:                     exit 2
152:                 }
153:             }
154:         }
155:     }
156: 
157:     # ============================================================
158:     # CHECK 2: Bash dangerous commands
159:     # ============================================================
160:     if ($toolName -eq "Bash") {
161:         $cmd = ""
162:         if ($toolInput.command) { $cmd = $toolInput.command.ToString() }
163:         $cmdLower = $cmd.ToLower()
164: 
165:         $dangerousPatterns = @{
166:             "git push --force"   = "Use --force-with-lease instead"
167:             "git push -f "       = "Use --force-with-lease instead"
168:             "git reset --hard"   = "Stash changes or create backup branch first"
169:             "git clean -fd"      = "Review with --dry-run first"
170:             "rm -rf /"           = "Catastrophic. Never run on root"
171:             "rm -rf ~"           = "Catastrophic. Never run on home"
172:             "rm -rf .git"        = "Catastrophic. Would destroy repo history"
173:         }
174: 
175:         foreach ($pattern in $dangerousPatterns.Keys) {
176:             if ($cmdLower.Contains($pattern.ToLower())) {
177:                 $reason = $dangerousPatterns[$pattern]
178:                 $msg = "BLOCKED: Dangerous command '$pattern' detected. Reason: $reason"
179:                 [Console]::Error.WriteLine($msg)
180:                 exit 2
181:             }
182:         }
183:     }
184: 
185:     # ============================================================
186:     # CHECK 3: Edit/Write to .env.local
187:     # ============================================================
188:     if ($toolName -eq "Edit" -or $toolName -eq "Write") {
189:         $filePath = ""
190:         if ($toolInput.file_path) { $filePath = $toolInput.file_path.ToString() }
191: 
192:         if ($filePath -match "\.env\.local$") {
193:             $msg = "BLOCKED: Modifying .env.local is not allowed.`n"
194:             $msg += ".env.local secrets must be managed manually by James and via Vercel Dashboard."
195:             [Console]::Error.WriteLine($msg)
196:             exit 2
197:         }
198:     }
199: 
200:     exit 0
201: }
202: catch {
203:     $errPath = Join-Path $PSScriptRoot "errors.log"
204:     "[$(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')] pre-tool-use error: $($_.Exception.Message)" | Out-File -FilePath $errPath -Append -Encoding utf8NoBOM -ErrorAction SilentlyContinue
205:     exit 0
206: }
</file>

<file path=".claude/hooks/session-start.ps1">
 1: # SessionStart hook - authority framing for HumanOS
 2: # Fires at start of every Claude Code session.
 3: # Output to stdout becomes additional context for the model.
 4: 
 5: $ErrorActionPreference = "Continue"
 6: 
 7: try {
 8:     $framing = @"
 9: 
10: <EXTREMELY_IMPORTANT>
11: 
12: You are working on HumanOS - internal HR app for ICONSA (construction Panama).
13: This codebase has hard rules. Read these BEFORE any tool call:
14: 
15: [SCHEMAS PROHIBIDOS - Hook PreToolUse will block writes]
16: - public.*       (MovimientOS production, owner: dev MovimientOS)
17: - payroll.*      (compania de Jaime payroll system)
18: - humanos.*      (legacy v1 demo, archived)
19: 
20: [SCHEMAS TOCABLES - HumanOS canonical]
21: - hr.*, requests.*, docs.*, workflows.*, audit.*, notifications.*,
22:   files.*, performance.*, learning.*
23: - Future MDM/ETL: mdm.*, etl.*, backup.* (when first external integration arrives)
24: 
25: [AUTH.USERS - SHARED across apps - R22 enforced]
26: auth.users is SHARED between MovimientOS, HumanOS and future apps.
27: NEVER DELETE/UPDATE auth.users without filter by app_metadata.allowed_apps.
28: Incident 2026-05-25 documented in docs/05-BUSINESS-RULES.md R22.
29: 
30: [OBLIGATORIO en toda CREATE TABLE]
31: 1. ALTER TABLE ... ENABLE ROW LEVEL SECURITY + min 1 policy
32: 2. COMMENT ON TABLE + COMMENT ON COLUMN
33: 3. If golden record (cross-app entity): {entity}_external_ids + _source column
34: 
35: [HELPER FUNCTIONS - NO redefinir]
36: - hr.current_person_id(), hr.current_app_role()
37: - hr.is_hr_admin(), hr.is_president_or_admin()
38: - hr.is_supervisor_of(uuid), requests.can_view_ticket(uuid)
39: - hr.touch_updated_at()
40: 
41: [IDIOMA UI]
42: Espanol neutro Panama. NUNCA voseo (vos, tenes, podes, registra-tilde).
43: SI: tu, tienes, puedes, registra, verifica.
44: 
45: [NO ESTIMAR TIEMPO]
46: NO days/weeks/months. Solo P1/P2/P3 + trivial/no-trivial/alta-complejidad.
47: 
48: [ENCODING - LESSON 2026-05-25]
49: - All config files (.json, .ps1, .ts, .tsx, .md, .css): UTF-8 SIN BOM.
50: - ASCII only in .ps1 hook source (avoid em-dash, accents, special chars).
51: - Never PowerShell Set-Content / Out-File for config without -Encoding utf8NoBOM.
52: 
53: Read @docs/00-INDEX.md first when in doubt.
54: 
55: </EXTREMELY_IMPORTANT>
56: 
57: "@
58: 
59:     Write-Output $framing
60:     exit 0
61: }
62: catch {
63:     $errPath = Join-Path $PSScriptRoot "errors.log"
64:     "[$(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')] session-start error: $($_.Exception.Message)" | Out-File -FilePath $errPath -Append -Encoding utf8NoBOM -ErrorAction SilentlyContinue
65:     exit 0
66: }
</file>

<file path=".claude/hooks/user-prompt-submit.ps1">
  1: # UserPromptSubmit hook - skill router for HumanOS
  2: # Fires before each user prompt is processed.
  3: # Reads .claude/skill-rules.json and outputs <skill_router> block with matched skills.
  4: 
  5: $ErrorActionPreference = "Continue"
  6: 
  7: try {
  8:     $input_raw = [Console]::In.ReadToEnd()
  9:     if (-not $input_raw) { exit 0 }
 10: 
 11:     $payload = $input_raw | ConvertFrom-Json -ErrorAction Stop
 12:     $userPrompt = ""
 13:     if ($payload.user_prompt) { $userPrompt = $payload.user_prompt.ToString() }
 14:     elseif ($payload.prompt) { $userPrompt = $payload.prompt.ToString() }
 15: 
 16:     if (-not $userPrompt) { exit 0 }
 17: 
 18:     $promptLower = $userPrompt.ToLower()
 19: 
 20:     # Load skill rules
 21:     $rulesPath = Join-Path $PSScriptRoot "..\skill-rules.json"
 22:     if (-not (Test-Path $rulesPath)) { exit 0 }
 23: 
 24:     $rules = Get-Content $rulesPath -Raw | ConvertFrom-Json
 25:     if (-not $rules.skills) { exit 0 }
 26: 
 27:     $matched = @()
 28: 
 29:     foreach ($skill in $rules.skills) {
 30:         $isMatch = $false
 31:         $reason = ""
 32: 
 33:         # Match by keywords
 34:         if ($skill.keywords) {
 35:             foreach ($kw in $skill.keywords) {
 36:                 if ($promptLower.Contains($kw.ToLower())) {
 37:                     $isMatch = $true
 38:                     $reason = "keyword: $kw"
 39:                     break
 40:                 }
 41:             }
 42:         }
 43: 
 44:         # Match by intent_patterns (regex)
 45:         if (-not $isMatch -and $skill.intent_patterns) {
 46:             foreach ($pattern in $skill.intent_patterns) {
 47:                 if ($promptLower -match $pattern.ToLower()) {
 48:                     $isMatch = $true
 49:                     $reason = "pattern: $pattern"
 50:                     break
 51:                 }
 52:             }
 53:         }
 54: 
 55:         if ($isMatch) {
 56:             $matched += [PSCustomObject]@{
 57:                 Name        = $skill.name
 58:                 Description = $skill.description
 59:                 Enforcement = $skill.enforcement
 60:                 Priority    = $skill.priority
 61:                 Reason      = $reason
 62:             }
 63:         }
 64:     }
 65: 
 66:     if ($matched.Count -eq 0) { exit 0 }
 67: 
 68:     # Sort by priority (critical > high > medium > low)
 69:     $priorityOrder = @{ "critical" = 1; "high" = 2; "medium" = 3; "low" = 4 }
 70:     $sorted = $matched | Sort-Object { $priorityOrder[$_.Priority.ToString()] }
 71: 
 72:     # Build output
 73:     $output = @()
 74:     $output += ""
 75:     $output += "<skill_router>"
 76:     $output += "The following skills match keywords/intent in your prompt. CRITICAL and HIGH priority skills should be invoked or referenced when relevant:"
 77:     $output += ""
 78: 
 79:     foreach ($skill in $sorted) {
 80:         $marker = switch ($skill.Enforcement) {
 81:             "critical" { "[CRITICAL - YOU MUST FOLLOW]" }
 82:             "high"     { "[HIGH PRIORITY]" }
 83:             default    { "[suggested]" }
 84:         }
 85:         $output += "$marker $($skill.Name)"
 86:         if ($skill.Description) {
 87:             $output += "  $($skill.Description)"
 88:         }
 89:         $output += ""
 90:     }
 91: 
 92:     $output += "</skill_router>"
 93: 
 94:     $output -join "`n" | Write-Output
 95:     exit 0
 96: }
 97: catch {
 98:     $errPath = Join-Path $PSScriptRoot "errors.log"
 99:     "[$(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')] user-prompt-submit error: $($_.Exception.Message)" | Out-File -FilePath $errPath -Append -Encoding utf8NoBOM -ErrorAction SilentlyContinue
100:     exit 0
101: }
</file>

