 91:           </div>
 92:         )}
 93:         {me.department && (
 94:           <div>
 95:             <span className="text-neutral-500">Departamento:</span> {me.department}
 96:           </div>
 97:         )}
 98:         {me.position && (
 99:           <div className="col-span-2">
100:             <span className="text-neutral-500">Cargo:</span> {me.position}
101:           </div>
102:         )}
103:         {me.office && (
104:           <div className="col-span-2">
105:             <span className="text-neutral-500">Oficina:</span> {me.office}
106:           </div>
107:         )}
108:       </div>
109:     </div>
110:   );
111: }
112: 
113: async function loadSubordinates(
114:   supa: Awaited<ReturnType<typeof createServerClient>>,
115:   meId: string,
116: ): Promise<Array<{ id: string; name: string; code: string }>> {
117:   const { data } = await supa
118:     .from('people')
119:     .select('id, name, code')
120:     .eq('supervisor_id', meId)
121:     .eq('status', 'Activo')
122:     .order('name');
123:   return (data ?? []) as Array<{ id: string; name: string; code: string }>;
124: }
125: 
126: function buildActDatosInitial(me: Person): ActualizacionDatosData {
127:   const [calle, apto] = splitAddress(me.address ?? '');
128:   const estadoCivil: EstadoCivil = (ESTADOS_CIVILES as readonly string[]).includes(me.marital_status ?? '')
129:     ? (me.marital_status as EstadoCivil)
130:     : 'Soltero(a)';
131: 
132:   return {
133:     direccion: {
134:       calle_barriada: calle,
135:       apartamento_casa_no: apto,
136:     },
137:     telefono_casa: '',
138:     celular_personal: me.phone ?? '',
139:     estado_civil: estadoCivil,
140:     pareja: undefined,
141:     dependientes: [],
142:   };
143: }
144: 
145: function splitAddress(addr: string): [string, string] {
146:   if (!addr) return ['', ''];
147:   const idx = addr.indexOf(',');
148:   if (idx === -1) return [addr, ''];
149:   return [addr.slice(0, idx).trim(), addr.slice(idx + 1).trim()];
150: }
