1680: export const MAX_FILE_SIZE_BYTES = 5 * 1024 * 1024;
1681: export const TARGET_DIMENSION = 800;
1682: export const JPEG_QUALITY = 0.85;
1683: export const POST_RESIZE_LIMIT_BYTES = 1024 * 1024; // 1MB
1684: 
1685: export function validateMime(mime: string): boolean {
1686:   return (ALLOWED_MIME as readonly string[]).includes(mime);
1687: }
1688: 
1689: export async function resizeImage(file: File): Promise<Blob> {
1690:   if (!validateMime(file.type)) {
1691:     throw new Error('Formato no soportado. Usa JPG, PNG o WebP.');
1692:   }
1693:   if (file.size > MAX_FILE_SIZE_BYTES) {
1694:     throw new Error('Archivo muy grande. Máximo 5MB antes de procesar.');
1695:   }
1696:   const img = await loadImage(file);
1697:   const canvas = document.createElement('canvas');
1698:   const ratio = Math.min(TARGET_DIMENSION / img.width, TARGET_DIMENSION / img.height, 1);
1699:   canvas.width = Math.round(img.width * ratio);
1700:   canvas.height = Math.round(img.height * ratio);
1701:   const ctx = canvas.getContext('2d');
1702:   if (!ctx) throw new Error('Canvas context no disponible');
1703:   ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
1704:   const blob = await new Promise<Blob>((resolve, reject) => {
1705:     canvas.toBlob(
1706:       (b) => (b ? resolve(b) : reject(new Error('Canvas toBlob failed'))),
1707:       'image/jpeg',
1708:       JPEG_QUALITY
1709:     );
1710:   });
1711:   if (blob.size > POST_RESIZE_LIMIT_BYTES) {
1712:     throw new Error(`Imagen demasiado grande después de procesar (${Math.round(blob.size / 1024)}KB). Intenta una foto más pequeña.`);
1713:   }
1714:   return blob;
1715: }
