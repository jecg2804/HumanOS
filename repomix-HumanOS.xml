1797: ### Task 19: apply ACT_DATOS al expediente — server action
1798: 
1799: **Files:**
1800: - Create: `src/lib/approvals/apply-act-datos.ts`
1801: 
1802: **Acceptance Criteria:**
1803: - [ ] Solo HR puede ejecutar.
1804: - [ ] Solo si type='ACTUALIZACION_DATOS' Y status='Aprobada'.
1805: - [ ] Aplica mapeo del spec §6.4: address, phone, marital_status, num_kids.
1806: - [ ] UPDATE `requests.status='Completada'`.
1807: 
1808: **Steps:**
1809: 
1810: - [ ] **Code:**
1811: 
1812: ```ts
1813: // src/lib/approvals/apply-act-datos.ts
1814: 'use server';
1815: import { createServerClient } from '@/lib/supabase/server';
1816: import { getMe } from '@/lib/auth/getMe';
1817: import { revalidatePath } from 'next/cache';
1818: 
1819: type FormDataAct = {
1820:   direccion?: { calle_barriada?: string; apartamento_casa_no?: string };
1821:   celular_personal?: string;
1822:   estado_civil?: 'Soltero(a)' | 'Casado(a)' | 'Unido(a)';
1823:   dependientes?: Array<{ nombre: string; parentesco: string }>;
1824: };
1825: 
1826: export async function applyActDatosAction(requestId: string): Promise<void> {
1827:   const me = await getMe();
1828:   if (me.role !== 'hr_admin') throw new Error('No autorizado');
1829:   const supa = await createServerClient();
1830: 
1831:   const { data: req } = await supa.from('requests')
1832:     .select('id, status, requester_id, form_data, request_types!inner(code)')
1833:     .eq('id', requestId).single();
1834:   if (!req) throw new Error('Solicitud no encontrada');
1835:   if ((req.request_types as unknown as { code: string }).code !== 'ACTUALIZACION_DATOS') throw new Error('Tipo no aplica');
1836:   if (req.status !== 'Aprobada') throw new Error('Solo solicitudes Aprobadas pueden aplicarse');
1837: 
1838:   const fd = req.form_data as FormDataAct;
1839:   const updates: Record<string, unknown> = {};
1840:   if (fd.direccion) {
1841:     const addr = [fd.direccion.calle_barriada, fd.direccion.apartamento_casa_no].filter(Boolean).join(', ');
1842:     if (addr) updates.address = addr;
1843:   }
1844:   if (fd.celular_personal) updates.phone = fd.celular_personal;
1845:   if (fd.estado_civil) updates.marital_status = fd.estado_civil;
1846:   if (Array.isArray(fd.dependientes)) updates.num_kids = fd.dependientes.length;
1847: 
1848:   if (Object.keys(updates).length > 0) {
1849:     const { error } = await supa.from('people').update(updates).eq('id', req.requester_id);
1850:     if (error) throw new Error(`apply failed: ${error.message}`);
1851:   }
1852: 
1853:   await supa.from('requests').update({ status: 'Completada', date_resolved: new Date().toISOString() }).eq('id', requestId);
1854:   revalidatePath(`/solicitudes/${requestId}`);
1855:   revalidatePath('/admin');
1856: }
1857: ```
1858: 
