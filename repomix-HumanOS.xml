<file path="src/lib/forms/schemas/vacaciones.ts">
 1: import { z } from 'zod';
 2: 
 3: const isFutureOrToday = (d: string): boolean => {
 4:   if (!d) return false;
 5:   const today = new Date(new Date().toDateString());
 6:   return new Date(d) >= today;
 7: };
 8: 
 9: export const vacacionesSchema = z
10:   .object({
11:     pago_vacaciones: z.enum([
12:       'Completas',
13:       'Adelanto sobre acumulado',
14:       'Descuento de días solicitados',
15:     ]),
16:     tiempo_solicitado: z.enum(['Completas', 'Parciales']),
17:     desglose: z
18:       .array(
19:         z.object({
20:           desde: z.string().min(1, 'Fecha desde requerida'),
21:           hasta: z.string().min(1, 'Fecha hasta requerida'),
22:         }),
23:       )
24:       .min(1, 'Al menos un rango')
25:       .max(3, 'Máximo 3 rangos'),
26:     observaciones: z.string().optional(),
27:   })
28:   .refine(
29:     (d) => d.desglose.every((r) => isFutureOrToday(r.desde)),
30:     { message: 'Las fechas deben ser hoy o futuras', path: ['desglose'] },
31:   )
32:   .refine(
33:     (d) => d.desglose.every((r) => new Date(r.hasta) >= new Date(r.desde)),
34:     { message: 'Fecha hasta debe ser mayor o igual a desde', path: ['desglose'] },
35:   )
36:   .refine(
37:     (d) => d.tiempo_solicitado !== 'Completas' || d.desglose.length === 1,
38:     { message: 'Vacaciones completas: solo 1 rango', path: ['desglose'] },
39:   )
40:   .refine(
41:     (d) => {
42:       const sorted = [...d.desglose].sort((a, b) => a.desde.localeCompare(b.desde));
43:       for (let i = 1; i < sorted.length; i++) {
44:         if (sorted[i].desde <= sorted[i - 1].hasta) return false;
45:       }
46:       return true;
47:     },
48:     { message: 'Los rangos no pueden traslaparse', path: ['desglose'] },
49:   );
50: 
51: export type VacacionesData = z.infer<typeof vacacionesSchema>;
</file>

