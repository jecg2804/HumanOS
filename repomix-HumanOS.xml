 56: function computeMyPendingApprovalId(
 57:   approvals: ApprovalRow[],
 58:   myId: string,
 59: ): string | null {
 60:   const sorted = [...approvals].sort((a, b) => a.step_order - b.step_order);
 61:   for (const a of sorted) {
 62:     const decision: ApprovalDecision = a.decision ?? 'Pendiente';
 63:     if (decision === 'Pendiente') {
 64:       // First pending row in order: must be mine.
 65:       return a.approver_id === myId ? a.id : null;
 66:     }
 67:     if (decision !== 'Aprobada') {
 68:       // Rechazada or Solicita Info: chain is broken; nobody else can decide.
 69:       return null;
 70:     }
 71:   }
 72:   return null;
 73: }
