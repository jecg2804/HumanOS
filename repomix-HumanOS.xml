 43: // Lunes 00:00:00 hora local Panamá (UTC-5, sin DST).
 44: // Construimos la fecha en UTC restando 5 horas para representar el inicio del lunes en hora Panamá.
 45: function startOfWeekPanamaIso(): string {
 46:   const PANAMA_OFFSET_HOURS = -5;
 47:   const now = new Date();
 48:   // "now" en hora Panamá:
 49:   const nowPanamaMs = now.getTime() + PANAMA_OFFSET_HOURS * 60 * 60 * 1000;
 50:   const nowPanama = new Date(nowPanamaMs);
 51:   // Día de la semana en Panamá (0=Dom, 1=Lun, ... 6=Sáb)
 52:   const dow = nowPanama.getUTCDay();
 53:   // Cuántos días retroceder para llegar al lunes
 54:   const daysSinceMonday = (dow + 6) % 7;
 55:   // Construir lunes 00:00 hora Panamá expresado en UTC
 56:   const mondayPanamaUTC = Date.UTC(
 57:     nowPanama.getUTCFullYear(),
 58:     nowPanama.getUTCMonth(),
 59:     nowPanama.getUTCDate() - daysSinceMonday,
 60:     0,
 61:     0,
 62:     0,
 63:   );
 64:   // Convertir de "00:00 Panamá" a UTC real: 00:00 Panamá = 05:00 UTC
 65:   const mondayUtcMs = mondayPanamaUTC - PANAMA_OFFSET_HOURS * 60 * 60 * 1000;
 66:   return new Date(mondayUtcMs).toISOString();
 67: }
 68: 
 69: function fiveDaysAgoIsoNow(): string {
 70:   return new Date(Date.now() - 5 * 24 * 60 * 60 * 1000).toISOString();
 71: }
 72: 
 73: export default async function AdminPage({
 74:   searchParams,
 75: }: {
 76:   searchParams: Promise<{
 77:     pendientes?: string;
 78:     desde?: string;
 79:     vencidas?: string;
 80:   }>;
 81: }) {
 82:   const me = await getMe();
 83:   if (me.role !== 'hr_admin') {
 84:     redirect('/inicio');
 85:   }
 86: 
 87:   const sp = await searchParams;
 88:   const initial = {
 89:     pendientesMias: sp.pendientes === 'mias',
 90:     vencidas: sp.vencidas === '1',
 91:     desdeIso: typeof sp.desde === 'string' && sp.desde.length > 0 ? sp.desde : null,
 92:   };
 93: 
 94:   const supa = await createServerClient();
 95:   const weekStartIso = startOfWeekPanamaIso();
 96:   const fiveDaysAgoIso = fiveDaysAgoIsoNow();
 97: 
 98:   // Fetch all requests (excluding Borradores), with types and requesters in parallel.
 99:   const [
100:     requestsRes,
101:     typesRes,
102:     pendingApprovalsRes,
103:     weekCountRes,
104:     overdueCountRes,
105:   ] = await Promise.all([
106:     supa
107:       .from('requests')
108:       .select(
109:         'id, request_number, type_id, requester_id, status, date_submitted, created_at',
110:       )
111:       .neq('status', 'Borrador')
112:       .order('date_submitted', { ascending: false, nullsFirst: false })
113:       .order('created_at', { ascending: false }),
114:     supa.from('request_types').select('id, code, name, icon').eq('is_active', true),
115:     supa
116:       .from('request_approvals')
117:       .select('request_id, approver_id, decision')
118:       .eq('approver_id', me.id)
119:       .eq('decision', 'Pendiente'),
120:     supa
121:       .from('requests')
122:       .select('id', { count: 'exact', head: true })
123:       .gte('date_submitted', weekStartIso),
124:     supa
125:       .from('requests')
126:       .select('id', { count: 'exact', head: true })
127:       .in('status', ['Enviada', 'En Revisión'])
128:       .lt('date_submitted', fiveDaysAgoIso),
129:   ]);
130: 
131:   const requests = (requestsRes.data ?? []) as RawRequest[];
132:   const types = (typesRes.data ?? []) as RawType[];
133:   const pendingApprovals = (pendingApprovalsRes.data ?? []) as RawApproval[];
134:   const semana = weekCountRes.count ?? 0;
135:   const vencidas = overdueCountRes.count ?? 0;
136:   const pendientesMias = pendingApprovals.length;
137: 
138:   // Fetch the requesters referenced in `requests` (and ensure `me` is included so we can resolve names).
139:   const requesterIds = Array.from(new Set(requests.map((r) => r.requester_id)));
140:   let peopleById = new Map<string, RawPerson>();
141:   if (requesterIds.length > 0) {
142:     const { data: people } = await supa
143:       .from('people')
144:       .select('id, code, name')
145:       .in('id', requesterIds);
146:     peopleById = new Map(((people ?? []) as RawPerson[]).map((p) => [p.id, p]));
147:   }
148: 
149:   const typesById = new Map(types.map((t) => [t.id, t]));
150:   const pendingRequestIds = new Set(pendingApprovals.map((a) => a.request_id));
151: 
152:   // Top 5 tipos activos (Enviada / En Revisión)
153:   const activeCounts = new Map<string, number>();
154:   for (const r of requests) {
155:     if (r.status === 'Enviada' || r.status === 'En Revisión') {
156:       activeCounts.set(r.type_id, (activeCounts.get(r.type_id) ?? 0) + 1);
157:     }
158:   }
159:   const topTypes: KPITypeBreakdown[] = Array.from(activeCounts.entries())
160:     .map(([typeId, count]) => {
161:       const t = typesById.get(typeId);
162:       return {
163:         type_name: t?.name ?? 'Desconocido',
164:         type_icon: t?.icon ?? null,
165:         count,
166:       };
167:     })
168:     .sort((a, b) => b.count - a.count)
169:     .slice(0, 5);
170: 
171:   const tableRows: AdminTableRow[] = requests.map((r) => {
172:     const t = typesById.get(r.type_id);
173:     const p = peopleById.get(r.requester_id);
174:     return {
175:       id: r.id,
176:       request_number: r.request_number,
177:       type_id: r.type_id,
178:       type_name: t?.name ?? 'Desconocido',
179:       type_icon: t?.icon ?? null,
180:       type_code: t?.code ?? '',
181:       requester_id: r.requester_id,
182:       requester_name: p?.name ?? 'Desconocido',
183:       requester_code: p?.code ?? '',
184:       status: r.status,
185:       date_submitted: r.date_submitted,
186:       created_at: r.created_at,
187:       pending_for_me: pendingRequestIds.has(r.id),
188:     };
189:   });
190: 
191:   const tableTypes: AdminTableType[] = types
192:     .map((t) => ({ id: t.id, code: t.code, name: t.name }))
193:     .sort((a, b) => a.name.localeCompare(b.name, 'es'));
194: 
195:   return (
196:     <div className="space-y-6 max-w-6xl">
197:       <header>
198:         <h1 className="text-2xl md:text-3xl font-semibold">Panel de Recursos Humanos</h1>
199:         <p className="text-neutral-500 mt-1 text-sm md:text-base">
200:           Tienes acceso a todas las solicitudes y aprobaciones pendientes.
201:         </p>
202:       </header>
203: 
204:       <AdminKPICards
205:         kpis={{
206:           pendientesMias,
207:           semana,
208:           vencidas,
209:           weekStartIso,
210:           topTypes,
211:         }}
212:       />
213: 
214:       <AdminRequestsTable rows={tableRows} types={tableTypes} initial={initial} />
215:     </div>
216:   );
217: }
