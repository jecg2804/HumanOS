<file path="src/lib/notifications/realtime.ts">
  1: 'use client';
  2: 
  3: import { useEffect, useState, useCallback } from 'react';
  4: import { createSupabaseBrowserClient } from '@/lib/supabase/browser';
  5: import type { Database } from '@/lib/supabase/database.types';
  6: 
  7: type OutboxRow = Database['notifications']['Tables']['outbox']['Row'];
  8: 
  9: interface UseNotificationsRealtime {
 10:   notifications: OutboxRow[];
 11:   unreadCount: number;
 12:   markAsRead: (id: string) => Promise<void>;
 13:   markAllAsRead: () => Promise<void>;
 14: }
 15: 
 16: export function useNotificationsRealtime(
 17:   currentPersonId: string | null
 18: ): UseNotificationsRealtime {
 19:   const [notifications, setNotifications] = useState<OutboxRow[]>([]);
 20:   const client = createSupabaseBrowserClient();
 21: 
 22:   useEffect(() => {
 23:     if (!currentPersonId) return;
 24:     const personId = currentPersonId;
 25:     let active = true;
 26: 
 27:     async function loadInitial() {
 28:       const { data } = await client
 29:         .schema('notifications')
 30:         .from('outbox')
 31:         .select('*')
 32:         .eq('recipient_id', personId)
 33:         .eq('channel', 'in_app')
 34:         .in('status', ['pending', 'queued', 'sent'])
 35:         .order('created_at', { ascending: false })
 36:         .limit(50);
 37:       if (active && data) setNotifications(data as OutboxRow[]);
 38:     }
 39: 
 40:     loadInitial();
 41: 
 42:     const channel = client
 43:       .channel(`notifications-${personId}`)
 44:       .on(
 45:         'postgres_changes',
 46:         {
 47:           event: '*',
 48:           schema: 'notifications',
 49:           table: 'outbox',
 50:           filter: `recipient_id=eq.${personId}`,
 51:         },
 52:         (payload) => {
 53:           if (!active) return;
 54:           if (payload.eventType === 'INSERT' && (payload.new as OutboxRow).channel === 'in_app') {
 55:             setNotifications((prev) => [payload.new as OutboxRow, ...prev]);
 56:           } else if (payload.eventType === 'UPDATE') {
 57:             setNotifications((prev) =>
 58:               prev.map((n) =>
 59:                 n.id === (payload.new as OutboxRow).id ? (payload.new as OutboxRow) : n
 60:               )
 61:             );
 62:           } else if (payload.eventType === 'DELETE') {
 63:             setNotifications((prev) => prev.filter((n) => n.id !== (payload.old as OutboxRow).id));
 64:           }
 65:         }
 66:       )
 67:       .subscribe();
 68: 
 69:     return () => {
 70:       active = false;
 71:       client.removeChannel(channel);
 72:     };
 73:   }, [currentPersonId, client]);
 74: 
 75:   const unreadCount = notifications.filter(
 76:     (n) => n.channel === 'in_app' && n.status !== 'read' && n.status !== 'dismissed'
 77:   ).length;
 78: 
 79:   const markAsRead = useCallback(
 80:     async (id: string) => {
 81:       await client
 82:         .schema('notifications')
 83:         .from('outbox')
 84:         .update({ status: 'read', read_at: new Date().toISOString() })
 85:         .eq('id', id);
 86:     },
 87:     [client]
 88:   );
 89: 
 90:   const markAllAsRead = useCallback(async () => {
 91:     if (!currentPersonId) return;
 92:     await client
 93:       .schema('notifications')
 94:       .from('outbox')
 95:       .update({ status: 'read', read_at: new Date().toISOString() })
 96:       .eq('recipient_id', currentPersonId)
 97:       .eq('channel', 'in_app')
 98:       .in('status', ['pending', 'queued', 'sent']);
 99:   }, [client, currentPersonId]);
100: 
101:   return { notifications, unreadCount, markAsRead, markAllAsRead };
102: }
</file>

