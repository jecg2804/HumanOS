263: export async function completeOnboardingAction(
264:   input: CompleteOnboardingInput & { ip_address?: string; user_agent?: string }
265: ): Promise<FormState> {
266:   const admin = createSupabaseAdminClient();
267: 
268:   let authId: string;
269:   let originalAppMetadata: Record<string, unknown> | null = null;
270:   const { data: existingRows } = await admin.schema('hr').rpc('find_auth_user_by_identifier', {
271:     p_field: input.target_field,
272:     p_value: input.normalized_target,
273:   });
274:   const existing = (existingRows as unknown as Array<{
275:     id: string;
276:     raw_app_meta_data: Record<string, unknown>;
277:   }> | null)?.[0];
278: 
279:   if (existing) {
280:     originalAppMetadata = { ...existing.raw_app_meta_data };
281:     const currentApps =
282:       (existing.raw_app_meta_data as { allowed_apps?: string[] })?.allowed_apps ?? [];
283:     if (!currentApps.includes('humanOS')) {
284:       const newApps = Array.from(new Set([...currentApps, 'humanOS']));
285:       const { error } = await admin.auth.admin.updateUserById(existing.id, {
286:         app_metadata: {
287:           ...existing.raw_app_meta_data,
288:           allowed_apps: newApps,
289:         },
290:       });
291:       if (error) {
292:         return { ok: false, message: translateAuthError(error) };
293:       }
294:     }
295:     authId = existing.id;
296:   } else {
297:     if (!input.password) {
298:       return { ok: false, message: 'Password requerido para crear nueva cuenta.' };
299:     }
300:     const { data: newUser, error } = await admin.auth.admin.createUser({
301:       [input.target_field]: input.normalized_target,
302:       password: input.password,
303:       email_confirm: input.target_field === 'email',
304:       app_metadata: { allowed_apps: ['humanOS'] },
305:     });
306:     if (error || !newUser?.user) {
307:       return {
308:         ok: false,
309:         message: translateAuthError(
310:           error ?? { code: 'unknown', message: 'createUser failed' }
311:         ),
312:       };
313:     }
314:     authId = newUser.user.id;
315:   }
316: 
317:   const { error: rpcErr } = await admin.schema('hr').rpc('complete_onboarding_writes', {
318:     p_invite_id: input.invite_id,
319:     p_person_id: input.person_id,
320:     p_auth_id: authId,
321:     p_photo_path: input.photo_path,
322:     p_emergency: input.emergency,
323:     p_medical: input.medical,
324:     p_address: input.address,
325:     p_ack_ethics_at: input.ack_ethics_at,
326:     p_ack_child_labor_at: input.ack_child_labor_at,
327:     p_ip_address: input.ip_address ?? null,
328:     p_user_agent: input.user_agent ?? null,
329:   });
330: 
331:   if (rpcErr) {
332:     if (!existing) {
333:       await admin.auth.admin.deleteUser(authId);
334:     } else if (originalAppMetadata) {
335:       await admin.auth.admin.updateUserById(authId, {
336:         app_metadata: originalAppMetadata,
337:       });
338:     }
339:     return { ok: false, message: `Onboarding falló: ${rpcErr.message}` };
340:   }
341: 
342:   const { data: person } = await admin
343:     .schema('hr')
344:     .from('people')
345:     .select('full_name')
346:     .eq('id', input.person_id)
347:     .maybeSingle();
348: 
349:   await enqueueNotification(admin, {
350:     recipientPersonId: input.person_id,
351:     type: NotificationType.WelcomeEmployee,
352:     subject: 'Bienvenido a HumanOS',
353:     body: `Tu cuenta está lista, ${person?.full_name ?? ''}.`,
354:     templateVariables: {
355:       employee_name: person?.full_name ?? '',
356:       perfil_url: `${process.env.NEXT_PUBLIC_APP_URL ?? ''}/perfil`,
357:     },
358:     metadata: { person_id: input.person_id, deep_link: '/perfil' },
359:   });
360: 
361:   return { ok: true, data: { auth_id: authId, redirect_to: '/perfil' } };
362: }
