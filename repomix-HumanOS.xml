<file path="src/components/onboarding/WizardLayout.tsx">
 1: 'use client';
 2: import { useEffect, useState } from 'react';
 3: import { useRouter } from 'next/navigation';
 4: 
 5: interface Props {
 6:   step: number;
 7:   totalSteps: number;
 8:   children: React.ReactNode;
 9:   onCancel: () => void;
10:   showCancel?: boolean;
11: }
12: 
13: export function WizardLayout({ step, totalSteps, children, onCancel, showCancel = true }: Props) {
14:   const [confirmingCancel, setConfirmingCancel] = useState(false);
15:   const router = useRouter();
16: 
17:   useEffect(() => {
18:     const handler = (e: BeforeUnloadEvent) => {
19:       e.preventDefault();
20:       e.returnValue = '';
21:     };
22:     window.addEventListener('beforeunload', handler);
23:     return () => window.removeEventListener('beforeunload', handler);
24:   }, []);
25: 
26:   const pct = Math.round((step / totalSteps) * 100);
27: 
28:   return (
29:     <div className="min-h-screen bg-gray-50">
30:       <header className="bg-[#1B3A5C] text-white px-6 py-4 flex items-center justify-between">
31:         <div>
32:           <div className="font-bold">HumanOS · Configuración inicial</div>
33:           <div className="text-xs opacity-80">
34:             Paso {step} de {totalSteps}
35:           </div>
36:         </div>
37:         {showCancel && (
38:           <button
39:             onClick={() => setConfirmingCancel(true)}
40:             className="text-sm underline hover:opacity-80"
41:           >
42:             Cancelar y reiniciar
43:           </button>
44:         )}
45:       </header>
46:       <div className="h-2 bg-gray-200">
47:         <div
48:           className="h-full bg-[#F0A500] transition-all"
49:           style={{ width: `${pct}%` }}
50:         />
51:       </div>
52:       <main className="max-w-2xl mx-auto p-6">{children}</main>
53:       {confirmingCancel && (
54:         <div className="fixed inset-0 bg-black/50 flex items-center justify-center p-4">
55:           <div className="bg-white rounded-lg p-6 max-w-md">
56:             <h2 className="text-lg font-bold">¿Salir del onboarding?</h2>
57:             <p className="text-sm text-gray-600 mt-2">
58:               Perderás todo el progreso. Tendrás que iniciar desde el primer paso la próxima vez.
59:             </p>
60:             <div className="flex justify-end gap-2 mt-4">
61:               <button
62:                 onClick={() => setConfirmingCancel(false)}
63:                 className="px-4 py-2 border rounded"
64:               >
65:                 Continuar
66:               </button>
67:               <button
68:                 onClick={() => {
69:                   onCancel();
70:                   router.push('/');
71:                 }}
72:                 className="px-4 py-2 bg-red-600 text-white rounded"
73:               >
74:                 Sí, salir
75:               </button>
76:             </div>
77:           </div>
78:         </div>
79:       )}
80:     </div>
81:   );
82: }
</file>

