<file path="src/lib/approvals/chains.ts">
 1: import type { ApprovalRole } from './roles';
 2: 
 3: export type RequestTypeCode =
 4:   | 'VACACIONES'
 5:   | 'ACCION_PERSONAL'
 6:   | 'PRESTAMO'
 7:   | 'ACTUALIZACION_DATOS'
 8:   | 'RECLAMO_PAGO';
 9: 
10: /**
11:  * Calcula el chain efectivo de approval para un submit, partiendo del chain base
12:  * que viene en humanos.request_types.approval_chain. Solo PRESTAMO con monto > $250
13:  * extiende el chain agregando 'presidencia' al final (regla del IC-RH-D-02).
14:  */
15: export function effectiveChain(
16:   typeCode: RequestTypeCode,
17:   formData: Record<string, unknown>,
18:   baseChain: ApprovalRole[],
19: ): ApprovalRole[] {
20:   if (typeCode === 'PRESTAMO') {
21:     const monto = Number(formData.monto_solicitado);
22:     if (Number.isFinite(monto) && monto > 250 && !baseChain.includes('presidencia')) {
23:       return [...baseChain, 'presidencia'];
24:     }
25:   }
26:   return baseChain;
27: }
</file>

<file path="src/lib/approvals/decide.ts">
 1: 'use server';
 2: import { revalidatePath } from 'next/cache';
 3: import { createServerClient } from '@/lib/supabase/server';
 4: import { getMe } from '@/lib/auth/getMe';
 5: import { sendNotification } from '@/lib/email/send';
 6: 
 7: export type DecideInput = {
 8:   approvalId: string;
 9:   decision: 'Aprobada' | 'Rechazada';
10:   comments: string;
11: };
12: 
13: type DecideRpcRow = {
14:   request_status: string;
15:   next_approver_id: string | null;
16:   is_final: boolean;
17: };
18: 
19: export async function decideApprovalAction(input: DecideInput): Promise<void> {
20:   const me = await getMe();
21:   const supa = await createServerClient();
22: 
23:   const { data, error } = await supa.rpc('decide_approval', {
24:     p_approval_id: input.approvalId,
25:     p_decider_id: me.id,
26:     p_decision: input.decision,
27:     p_comments: input.comments,
28:   });
29:   if (error) throw new Error(`Error al decidir: ${error.message}`);
30: 
31:   const rows = (data ?? []) as DecideRpcRow[];
32:   const row = rows[0];
33:   if (!row) throw new Error('decide_approval did not return a row');
34: 
35:   // Lookup request_id desde el approval, luego request + tipo + requester en queries separadas.
36:   const { data: appr } = await supa
37:     .from('request_approvals')
38:     .select('request_id')
39:     .eq('id', input.approvalId)
40:     .single();
41:   if (!appr) return;
42: 
43:   const { data: req } = await supa
44:     .from('requests')
45:     .select('id, request_number, requester_id, type_id')
46:     .eq('id', appr.request_id)
47:     .single();
48:   if (!req) return;
49: 
50:   const [{ data: requester }, { data: type }] = await Promise.all([
51:     supa.from('people').select('email, name').eq('id', req.requester_id).single(),
52:     supa.from('request_types').select('name').eq('id', req.type_id).single(),
53:   ]);
54: 
55:   const typeLabel = type?.name ?? 'Solicitud';
56: 
57:   if (row.is_final) {
58:     if (requester?.email) {
59:       await sendNotification('decision-final', {
60:         to: requester.email,
61:         to_name: requester.name.split(' ')[0],
62:         request_number: req.request_number ?? '',
63:         request_id: req.id,
64:         request_type_label: typeLabel,
65:         requester_name: requester.name,
66:         decision: row.request_status === 'Aprobada' ? 'Aprobada' : 'Rechazada',
67:       });
68:     }
69:   } else if (row.next_approver_id) {
70:     const { data: nextApprover } = await supa
71:       .from('people')
72:       .select('email, name')
73:       .eq('id', row.next_approver_id)
74:       .single();
75:     if (nextApprover?.email) {
76:       await sendNotification('solicitud-decidida', {
77:         to: nextApprover.email,
78:         to_name: nextApprover.name.split(' ')[0],
79:         request_number: req.request_number ?? '',
80:         request_id: req.id,
81:         request_type_label: typeLabel,
82:         requester_name: requester?.name ?? '',
83:       });
84:     }
85:   }
86: 
87:   revalidatePath('/solicitudes');
88:   revalidatePath(`/solicitudes/${req.id}`);
89:   revalidatePath('/admin');
90: }
</file>

