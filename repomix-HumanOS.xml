<file path="supabase/migrations/20260428_001_helper_functions.sql">
 1: -- Module 1 — Task 11: Funciones auxiliares para auth, role resolution y numeración atómica.
 2: -- Aplicado via Supabase MCP el 2026-04-28. Smoke tests al final emitieron NOTICEs OK.
 3: 
 4: CREATE OR REPLACE FUNCTION humanos.me() RETURNS uuid LANGUAGE sql STABLE AS $$
 5:   SELECT id FROM humanos.people WHERE auth_id = auth.uid()
 6: $$;
 7: 
 8: CREATE OR REPLACE FUNCTION humanos.is_hr() RETURNS boolean LANGUAGE sql STABLE AS $$
 9:   SELECT EXISTS (
10:     SELECT 1 FROM humanos.people WHERE auth_id = auth.uid()
11:     AND code IN ('KOSM01','OLM206','MAN943','MEN943')
12:   )
13: $$;
14: 
15: -- Resolución de roles semánticos a person uuid. supervisor_directo retorna NULL si el requester no
16: -- tiene supervisor_id (fallback A del spec §4.1.1) y emite RAISE NOTICE para trazabilidad.
17: CREATE OR REPLACE FUNCTION humanos.resolve_approver(p_role text, p_requester_id uuid)
18: RETURNS uuid LANGUAGE plpgsql STABLE SECURITY DEFINER AS $$
19: DECLARE v_id uuid;
20: BEGIN
21:   IF p_role = 'supervisor_directo' THEN
22:     SELECT supervisor_id INTO v_id FROM humanos.people WHERE id = p_requester_id;
23:     IF v_id IS NULL THEN
24:       RAISE NOTICE 'resolve_approver: requester % has no supervisor_id, skipping step', p_requester_id;
25:     END IF;
26:   ELSIF p_role = 'hr_oficial' THEN
27:     SELECT id INTO v_id FROM humanos.people WHERE code='OLM206';
28:   ELSIF p_role = 'hr_planilla' THEN
29:     SELECT id INTO v_id FROM humanos.people WHERE code='MAN943';
30:   ELSIF p_role = 'hr_gerente' THEN
31:     SELECT id INTO v_id FROM humanos.people WHERE code='KOSM01';
32:   ELSIF p_role = 'presidencia' THEN
33:     SELECT id INTO v_id FROM humanos.people WHERE code='EIS772';
34:   ELSE
35:     RAISE EXCEPTION 'unknown role: %', p_role;
36:   END IF;
37:   RETURN v_id;
38: END;
39: $$;
40: 
41: -- Numerador atómico: HUM-YYYY-NNNN.
42: CREATE OR REPLACE FUNCTION humanos.next_request_number() RETURNS text LANGUAGE plpgsql AS $$
43: DECLARE v_n bigint;
44: BEGIN
45:   UPDATE humanos.sequences SET current_value = current_value + 1
46:   WHERE name='request_number' RETURNING current_value INTO v_n;
47:   RETURN format('HUM-%s-%s', extract(year from now())::int, lpad(v_n::text, 4, '0'));
48: END;
49: $$;
50: 
51: -- Smoke
52: DO $$
53: DECLARE r1 uuid; r2 uuid; r3 text;
54: BEGIN
55:   SELECT humanos.resolve_approver('hr_gerente', NULL) INTO r1;
56:   RAISE NOTICE 'resolve(hr_gerente)=%', r1;
57: 
58:   SELECT humanos.resolve_approver('supervisor_directo',
59:     (SELECT id FROM humanos.people WHERE code='KOSM01')) INTO r2;
60:   RAISE NOTICE 'resolve(supervisor_directo of KOSM01)=%', r2;
61: 
62:   SELECT humanos.next_request_number() INTO r3;
63:   RAISE NOTICE 'next_request_number=%', r3;
64:   UPDATE humanos.sequences SET current_value = current_value - 1 WHERE name='request_number';
65: END $$;
</file>

<file path="supabase/migrations/20260428_002_submit_request.sql">
 1: -- Module 1 — Task 12: submit_request RPC atómica.
 2: -- Crea humanos.requests + N humanos.request_approvals según chain resuelto.
 3: -- Steps con approver=NULL se saltean (fallback A). Si todo el chain queda vacío, request → Aprobada inmediata.
 4: -- Aplicado via MCP el 2026-04-28; smoke OK.
 5: 
 6: CREATE OR REPLACE FUNCTION humanos.submit_request(
 7:   p_type_code text,
 8:   p_requester_id uuid,
 9:   p_form_data jsonb,
10:   p_attachments jsonb,
11:   p_approval_chain text[]
12: ) RETURNS TABLE(request_id uuid, request_number text, first_approver_id uuid)
13: LANGUAGE plpgsql AS $$
14: DECLARE
15:   v_type_id uuid;
16:   v_request_id uuid;
17:   v_number text;
18:   v_role text;
19:   v_approver uuid;
20:   v_step int := 1;
21:   v_first uuid := NULL;
22: BEGIN
23:   SELECT id INTO v_type_id FROM humanos.request_types
24:    WHERE code = p_type_code AND is_active = true;
25:   IF v_type_id IS NULL THEN
26:     RAISE EXCEPTION 'unknown or inactive type: %', p_type_code;
27:   END IF;
28: 
29:   v_number := humanos.next_request_number();
30: 
31:   INSERT INTO humanos.requests (request_number, type_id, requester_id, status, form_data, attachments, date_submitted)
32:   VALUES (v_number, v_type_id, p_requester_id, 'Enviada', p_form_data, p_attachments, now())
33:   RETURNING id INTO v_request_id;
34: 
35:   FOREACH v_role IN ARRAY p_approval_chain LOOP
36:     v_approver := humanos.resolve_approver(v_role, p_requester_id);
37:     IF v_approver IS NOT NULL THEN
38:       INSERT INTO humanos.request_approvals (request_id, approver_id, step_order, role_required, decision)
39:       VALUES (v_request_id, v_approver, v_step, v_role, 'Pendiente');
40:       IF v_first IS NULL THEN v_first := v_approver; END IF;
41:       v_step := v_step + 1;
42:     END IF;
43:   END LOOP;
44: 
45:   IF v_first IS NULL THEN
46:     UPDATE humanos.requests SET status='Aprobada', date_resolved=now() WHERE id = v_request_id;
47:   END IF;
48: 
49:   RETURN QUERY SELECT v_request_id, v_number, v_first;
50: END;
51: $$;
52: 
53: -- Smoke
54: DO $$
55: DECLARE r RECORD;
56: BEGIN
57:   SELECT * INTO r FROM humanos.submit_request(
58:     'VACACIONES',
59:     (SELECT id FROM humanos.people WHERE code='KOSM01'),
60:     '{"smoke_test": true}'::jsonb,
61:     '[]'::jsonb,
62:     ARRAY['hr_oficial','hr_gerente']
63:   );
64:   RAISE NOTICE 'submit_request smoke: id=%, number=%, first=%', r.request_id, r.request_number, r.first_approver_id;
65:   DELETE FROM humanos.request_approvals WHERE request_id = r.request_id;
66:   DELETE FROM humanos.requests WHERE id = r.request_id;
67:   UPDATE humanos.sequences SET current_value = current_value - 1 WHERE name='request_number';
68: END $$;
</file>

<file path="supabase/migrations/20260428_003_decide_approval.sql">
 1: -- Module 1 — Task 13: decide_approval RPC atómica.
 2: -- Verifica ownership del approval, aplica decisión, cierra o avanza el flujo.
 3: -- Aplicado via MCP el 2026-04-28; smoke OK (2 NOTICEs: step 1 partial, step 2 final).
 4: 
 5: CREATE OR REPLACE FUNCTION humanos.decide_approval(
 6:   p_approval_id uuid,
 7:   p_decider_id uuid,
 8:   p_decision text,
 9:   p_comments text
10: ) RETURNS TABLE(request_status text, next_approver_id uuid, is_final boolean)
11: LANGUAGE plpgsql AS $$
12: DECLARE
13:   v_approval humanos.request_approvals%ROWTYPE;
14:   v_request_id uuid;
15:   v_next humanos.request_approvals%ROWTYPE;
16: BEGIN
17:   SELECT * INTO v_approval FROM humanos.request_approvals WHERE id = p_approval_id FOR UPDATE;
18:   IF v_approval.id IS NULL THEN RAISE EXCEPTION 'approval not found'; END IF;
19:   IF v_approval.approver_id != p_decider_id THEN RAISE EXCEPTION 'not your approval'; END IF;
20:   IF v_approval.decision != 'Pendiente' THEN RAISE EXCEPTION 'already decided'; END IF;
21:   IF p_decision NOT IN ('Aprobada','Rechazada','Solicita Info') THEN RAISE EXCEPTION 'bad decision'; END IF;
22: 
23:   v_request_id := v_approval.request_id;
24: 
25:   UPDATE humanos.request_approvals
26:      SET decision=p_decision, comments=p_comments, decided_at=now()
27:    WHERE id = p_approval_id;
28: 
29:   IF p_decision = 'Rechazada' THEN
30:     UPDATE humanos.requests SET status='Rechazada', date_resolved=now() WHERE id=v_request_id;
31:     RETURN QUERY SELECT 'Rechazada'::text, NULL::uuid, true;
32:     RETURN;
33:   END IF;
34: 
35:   -- Solicita Info: por ahora se trata igual que Aprobada parcial (UI v1 solo expone Aprobar/Rechazar).
36:   SELECT * INTO v_next FROM humanos.request_approvals
37:    WHERE request_id = v_request_id AND decision = 'Pendiente'
38:    ORDER BY step_order ASC LIMIT 1;
39: 
40:   IF v_next.id IS NULL THEN
41:     UPDATE humanos.requests SET status='Aprobada', date_resolved=now() WHERE id=v_request_id;
42:     RETURN QUERY SELECT 'Aprobada'::text, NULL::uuid, true;
43:   ELSE
44:     UPDATE humanos.requests SET status='En Revisión' WHERE id=v_request_id AND status='Enviada';
45:     RETURN QUERY SELECT 'En Revisión'::text, v_next.approver_id, false;
46:   END IF;
47: END;
48: $$;
