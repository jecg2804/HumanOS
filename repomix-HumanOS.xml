 956:     index[code] = `/sops/${sanitized}`;
 957:   }
 958: }
 959: writeFileSync(join(DST, 'index.json'), JSON.stringify(index, null, 2));
 960: console.log(`Copied ${files.length} PDFs, indexed ${Object.keys(index).length}`);
