<file path="src/app/api/cron/process-notifications/route.ts">
  1: // Vercel Cron worker. Schedule: */5 * * * * (declared in vercel.ts).
  2: // Auth: x-vercel-cron header (Vercel-signed) + Authorization: Bearer ${CRON_SECRET}.
  3: // Reads notifications.outbox WHERE channel='email' AND status='pending'.
  4: // Renders @react-email template + sends via Resend with Reply-To.
  5: //
  6: // ADR-0006 exception: uses service_role admin client (worker has no user session).
  7: 
  8: import { NextResponse } from 'next/server';
  9: import { Resend } from 'resend';
 10: import { createSupabaseAdminClient } from '@/lib/supabase/admin';
 11: import * as Templates from '@/emails';
 12: import type { Database } from '@/lib/supabase/database.types';
 13: 
 14: type OutboxRow = Database['notifications']['Tables']['outbox']['Row'];
 15: 
 16: const MAX_PER_TICK = 50;
 17: 
 18: type AdminClient = ReturnType<typeof createSupabaseAdminClient>;
 19: 
 20: export async function GET(request: Request) {
 21:   const isVercelCron = request.headers.get('x-vercel-cron') === '1';
 22:   const authHeader = request.headers.get('authorization');
 23:   const expected = `Bearer ${process.env.CRON_SECRET}`;
 24:   if (!isVercelCron && authHeader !== expected) {
 25:     return NextResponse.json({ error: 'Unauthorized' }, { status: 401 });
 26:   }
 27: 
 28:   if (!process.env.RESEND_API_KEY || !process.env.RESEND_FROM_EMAIL) {
 29:     console.warn('[cron] RESEND_API_KEY or RESEND_FROM_EMAIL missing — skipping cycle');
 30:     return NextResponse.json({ skipped: true, reason: 'env missing' });
 31:   }
 32: 
 33:   const supabase = createSupabaseAdminClient();
 34:   const resend = new Resend(process.env.RESEND_API_KEY);
 35: 
 36:   const { data: rows, error } = await supabase
 37:     .schema('notifications')
 38:     .from('outbox')
 39:     .select(
 40:       'id, recipient_id, subject, body, template_code, template_variables, attempts, max_attempts'
 41:     )
 42:     .eq('channel', 'email')
 43:     .eq('status', 'pending')
 44:     .lt('attempts', 3)
 45:     .order('created_at', { ascending: true })
 46:     .limit(MAX_PER_TICK);
 47: 
 48:   if (error) {
 49:     console.error('[cron] fetch failed:', error);
 50:     return NextResponse.json({ error: error.message }, { status: 500 });
 51:   }
 52: 
 53:   let sent = 0;
 54:   let failed = 0;
 55: 
 56:   for (const row of (rows ?? []) as OutboxRow[]) {
 57:     try {
 58:       const { data: person } = await supabase
 59:         .schema('hr')
 60:         .from('people')
 61:         .select('auth_id, full_name')
 62:         .eq('id', row.recipient_id)
 63:         .maybeSingle();
 64: 
 65:       if (!person?.auth_id) {
 66:         await markFailed(supabase, row.id, 'No auth_id for recipient', row.attempts + 1);
 67:         failed++;
 68:         continue;
 69:       }
 70: 
 71:       const userResult = await supabase.auth.admin.getUserById(person.auth_id);
 72:       const recipientEmail = userResult.data.user?.email;
 73:       if (!recipientEmail) {
 74:         await markFailed(supabase, row.id, 'No email on auth.user', row.attempts + 1);
 75:         failed++;
 76:         continue;
 77:       }
 78: 
 79:       const templateCode = row.template_code ?? '';
 80:       const Template = (
 81:         Templates as unknown as Record<
 82:           string,
 83:           (props: Record<string, unknown>) => React.ReactElement
 84:         >
 85:       )[templateCode];
 86:       if (!Template) {
 87:         await markFailed(
 88:           supabase,
 89:           row.id,
 90:           `Template ${templateCode} not found`,
 91:           row.attempts + 1
 92:         );
 93:         failed++;
 94:         continue;
 95:       }
 96: 
 97:       const replyTo =
 98:         templateCode === 'PasswordReset' ? undefined : process.env.RESEND_REPLY_TO;
 99: 
100:       const { error: sendErr } = await resend.emails.send({
101:         from: process.env.RESEND_FROM_EMAIL,
102:         to: [recipientEmail],
103:         ...(replyTo ? { replyTo } : {}),
104:         subject: row.subject ?? '',
105:         react: Template((row.template_variables as Record<string, unknown>) ?? {}),
106:       });
107: 
108:       if (sendErr) throw new Error(sendErr.message);
109: 
110:       await supabase
111:         .schema('notifications')
112:         .from('outbox')
113:         .update({
114:           status: 'sent',
115:           sent_at: new Date().toISOString(),
116:           attempts: row.attempts + 1,
117:         })
118:         .eq('id', row.id);
119:       sent++;
120:     } catch (err) {
121:       await markFailed(supabase, row.id, (err as Error).message, row.attempts + 1);
122:       failed++;
123:     }
124:   }
125: 
126:   return NextResponse.json({ processed: rows?.length ?? 0, sent, failed });
127: }
128: 
129: async function markFailed(
130:   supabase: AdminClient,
131:   id: string,
132:   message: string,
133:   attempts: number
134: ) {
135:   await supabase
136:     .schema('notifications')
137:     .from('outbox')
138:     .update({ status: 'failed', error_message: message, attempts })
139:     .eq('id', id);
140: }
</file>

