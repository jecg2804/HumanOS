<file path="e2e/lib/sql-helpers.ts">
 1: import { createClient, type SupabaseClient } from '@supabase/supabase-js';
 2: 
 3: export function adminClient(): SupabaseClient {
 4:   return createClient(
 5:     process.env.NEXT_PUBLIC_SUPABASE_URL!,
 6:     process.env.SUPABASE_SERVICE_ROLE_KEY!,
 7:     { auth: { persistSession: false } }
 8:   );
 9: }
10: 
11: export async function getAuthUserSnapshot(email: string) {
12:   const c = adminClient();
13:   const { data } = await c
14:     .schema('hr')
15:     .rpc('find_auth_user_by_identifier', { p_field: 'email', p_value: email });
16:   return (
17:     (data as unknown as Array<{
18:       id: string;
19:       raw_app_meta_data: Record<string, unknown>;
20:       encrypted_password: string;
21:     }>)?.[0] ?? null
22:   );
23: }
24: 
25: export async function countAuthUsers(): Promise<number> {
26:   const c = adminClient();
27:   const { data, error } = await c.rpc('count_auth_users');
28:   if (error) throw error;
29:   return data as number;
30: }
31: 
32: export async function cleanupTestEmployee(personId: string) {
33:   const c = adminClient();
34:   await c.schema('hr').from('invite_codes').delete().eq('person_id', personId);
35:   await c.schema('hr').from('addresses').delete().eq('person_id', personId);
36:   await c.schema('hr').from('contacts').delete().eq('person_id', personId);
37:   await c.schema('hr').from('medical_info').delete().eq('person_id', personId);
38:   await c.schema('hr').from('user_settings').delete().eq('person_id', personId);
39:   await c.schema('hr').from('employments').delete().eq('person_id', personId);
40:   await c.schema('hr').from('people').delete().eq('id', personId);
41: }
</file>

