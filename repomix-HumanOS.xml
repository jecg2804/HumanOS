 933: **Steps:**
 934: 
 935: - [ ] **Step 1: Script**
 936: 
 937: ```ts
 938: // scripts/copy-sops-to-public.ts
 939: import { readdirSync, mkdirSync, copyFileSync, writeFileSync } from 'node:fs';
 940: import { join } from 'node:path';
 941: 
 942: const SRC = 'Docs/SOPs, Formularios y Documentos';
 943: const DST = 'public/sops';
 944: 
 945: mkdirSync(DST, { recursive: true });
 946: const files = readdirSync(SRC).filter(f => f.toLowerCase().endsWith('.pdf'));
 947: const index: Record<string, string> = {};
 948: 
 949: for (const f of files) {
 950:   const sanitized = f.replace(/\s+/g, '_').replace(/[(),]/g, '');
 951:   copyFileSync(join(SRC, f), join(DST, sanitized));
 952:   // Extraer sop_reference: "IC-RH-F-05-03 Solicitud..." → "ICRHF0503"
 953:   const m = f.match(/^IC-([A-Z]{2})-([A-Z])-(\d+)-(\d+)/);
