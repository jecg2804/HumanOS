<file path="src/lib/auth/getMe.ts">
 1: import 'server-only';
 2: import { cache } from 'react';
 3: import { redirect } from 'next/navigation';
 4: import { createServerClient, createServerClientPublic } from '@/lib/supabase/server';
 5: import type { AppRole, Person } from '@/types/database';
 6: 
 7: const HR_CODES = new Set(['KOSM01', 'OLM206', 'MAN943', 'MEN943']);
 8: 
 9: export type Me = Person & { role: AppRole };
10: 
11: export class NoLinkedProfileError extends Error {
12:   constructor() {
13:     super('NO_LINKED_PROFILE');
14:     this.name = 'NoLinkedProfileError';
15:   }
16: }
17: 
18: export const getMe = cache(async (): Promise<Me> => {
19:   const supaPub = await createServerClientPublic();
20:   const {
21:     data: { user },
22:   } = await supaPub.auth.getUser();
23:   if (!user) redirect('/login');
24: 
25:   const supa = await createServerClient();
26:   const { data: person } = await supa
27:     .from('people')
28:     .select('*')
29:     .eq('auth_id', user.id)
30:     .maybeSingle();
31: 
32:   if (!person) {
33:     throw new NoLinkedProfileError();
34:   }
35: 
36:   let role: AppRole = 'employee';
37:   if (person.app_role && ['employee', 'supervisor', 'hr_admin'].includes(person.app_role)) {
38:     role = person.app_role as AppRole;
39:   } else if (HR_CODES.has(person.code)) {
40:     role = 'hr_admin';
41:   } else {
42:     const { count } = await supa
43:       .from('people')
44:       .select('id', { count: 'exact', head: true })
45:       .eq('supervisor_id', person.id);
46:     if ((count ?? 0) > 0) role = 'supervisor';
47:   }
48: 
49:   return { ...(person as Person), role };
50: });
</file>

