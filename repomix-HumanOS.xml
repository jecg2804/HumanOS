<file path="supabase/migrations/20260428_005_seed_supervisor_ids.sql">
 1: -- Module 1 — Task 10: Plan B del spec §4.1.1 — asignación por departamento.
 2: -- Aplicado via Supabase MCP el 2026-04-28 en 2 pasos:
 3: --   1) Mapeo principal por dept (KOSM01/VAL130/AVE629/RIO806/EIS772 + CUC166/EIS809→EIS772).
 4: --   2) Fix: Denise Marciaga (Construcción) está Inactivo, así que Construcción → Franklin Marciaga (Ing, Activo)
 5: --      per nota de James: "Si no es claro, reportan a Franklin Marciaga (Director de Ingeniería y Const.)".
 6: --
 7: -- Resultado: 35/52 activos con supervisor_id. Cumplimiento/Seguridad/Presupuesto/Movilizaciones/Admin general
 8: -- + top-tier (EIS772) quedan NULL → fallback A en humanos.resolve_approver los cubre (skip step + RAISE NOTICE).
 9: 
10: -- Paso 1: mapeo principal
11: WITH mgr AS (
12:   SELECT
13:     (SELECT id FROM humanos.people WHERE code='KOSM01') AS kosm01,
14:     (SELECT id FROM humanos.people WHERE code='VAL130') AS val130,
15:     (SELECT id FROM humanos.people WHERE code='AVE629') AS ave629,
16:     (SELECT id FROM humanos.people WHERE code='RIO806') AS rio806,
17:     (SELECT id FROM humanos.people WHERE code='EIS772') AS eis772
18: )
19: UPDATE humanos.people p
20: SET supervisor_id = CASE
21:   WHEN p.department = 'Recursos Humanos' AND p.code != 'KOSM01' THEN (SELECT kosm01 FROM mgr)
22:   WHEN p.department = 'Equipo' AND p.code != 'VAL130' THEN (SELECT val130 FROM mgr)
23:   WHEN p.department = 'Ingeniería' AND p.code != 'AVE629' AND p.name != 'Franklin Marciaga' THEN (SELECT ave629 FROM mgr)
24:   WHEN p.department = 'Contabilidad' AND p.code != 'RIO806' THEN (SELECT rio806 FROM mgr)
25:   WHEN p.code IN ('CUC166','EIS809') THEN (SELECT eis772 FROM mgr)
26:   WHEN p.code IN ('KOSM01','VAL130','AVE629','RIO806') THEN (SELECT eis772 FROM mgr)
27:   WHEN p.name = 'Franklin Marciaga' AND p.department = 'Ingeniería' THEN (SELECT eis772 FROM mgr)
28:   ELSE p.supervisor_id
29: END
30: WHERE p.status = 'Activo';
31: 
32: -- Paso 2: Construcción → Franklin (Denise está Inactivo)
33: WITH mgr AS (
34:   SELECT (SELECT id FROM humanos.people WHERE name='Franklin Marciaga' AND status='Activo' LIMIT 1) AS franklin
35: )
36: UPDATE humanos.people p
37: SET supervisor_id = (SELECT franklin FROM mgr)
38: WHERE p.status = 'Activo'
39:   AND p.department = 'Construcción'
40:   AND p.supervisor_id IS NULL;
41: 
42: -- Smoke
43: DO $$
44: DECLARE
45:   n_with_sup int; n_total int; n_self int;
46: BEGIN
47:   SELECT
48:     COUNT(*) FILTER (WHERE supervisor_id IS NOT NULL),
49:     COUNT(*)
50:   INTO n_with_sup, n_total
51:   FROM humanos.people WHERE status='Activo';
52: 
53:   SELECT COUNT(*) INTO n_self FROM humanos.people WHERE supervisor_id = id;
54: 
55:   RAISE NOTICE 'seed_supervisors: % de % activos con supervisor (% reportan a sí mismos — debe ser 0)',
56:     n_with_sup, n_total, n_self;
57: 
58:   IF n_self > 0 THEN RAISE EXCEPTION 'self-reporting detected'; END IF;
59: END $$;
</file>

<file path="supabase/migrations/20260428_006_replace_rls_policies.sql">
 1: -- Module 1 — Task 15: reemplazar policies permisivas (USING true) con policies por rol.
 2: -- Aplicado via MCP el 2026-04-28. INSERT/UPDATE de requests y request_approvals queda exclusivamente
 3: -- via RPCs SECURITY DEFINER (submit_request, decide_approval) o service-role; por eso no hay policy
 4: -- de WRITE para usuarios authenticated en esas tablas.
 5: 
 6: DROP POLICY IF EXISTS authenticated_all_people ON humanos.people;
 7: DROP POLICY IF EXISTS authenticated_all_request_types ON humanos.request_types;
 8: DROP POLICY IF EXISTS authenticated_all_requests ON humanos.requests;
 9: DROP POLICY IF EXISTS authenticated_all_approvals ON humanos.request_approvals;
10: DROP POLICY IF EXISTS authenticated_all_sequences ON humanos.sequences;
11: 
12: -- people
13: CREATE POLICY people_select_authenticated
14:   ON humanos.people FOR SELECT TO authenticated USING (true);
15: 
16: CREATE POLICY people_update_hr
17:   ON humanos.people FOR UPDATE TO authenticated
18:   USING (humanos.is_hr())
19:   WITH CHECK (humanos.is_hr());
20: 
21: -- request_types
22: CREATE POLICY request_types_select_authenticated
23:   ON humanos.request_types FOR SELECT TO authenticated USING (true);
24: 
25: -- requests: visibility por relación
26: CREATE POLICY requests_select_visible
27:   ON humanos.requests FOR SELECT TO authenticated USING (
28:     requester_id = humanos.me()
29:     OR humanos.is_hr()
30:     OR EXISTS (
31:       SELECT 1 FROM humanos.request_approvals ra
32:        WHERE ra.request_id = humanos.requests.id AND ra.approver_id = humanos.me()
33:     )
34:   );
35: 
36: -- request_approvals: misma visibilidad
37: CREATE POLICY approvals_select_visible
38:   ON humanos.request_approvals FOR SELECT TO authenticated USING (
39:     approver_id = humanos.me()
40:     OR humanos.is_hr()
41:     OR EXISTS (
42:       SELECT 1 FROM humanos.requests r
43:        WHERE r.id = humanos.request_approvals.request_id
44:          AND r.requester_id = humanos.me()
45:     )
46:   );
47: 
48: -- sequences: 0 policies + RLS habilitado = denegado a authenticated. Solo RPCs SECURITY DEFINER.
49: 
50: DO $$
51: DECLARE n_pol int;
52: BEGIN
53:   SELECT COUNT(*) INTO n_pol FROM pg_policy p
54:    JOIN pg_class c ON p.polrelid = c.oid
55:    JOIN pg_namespace n ON c.relnamespace = n.oid
56:    WHERE n.nspname = 'humanos';
57:   RAISE NOTICE 'rls policies installed: %', n_pol;
58: END $$;
</file>

