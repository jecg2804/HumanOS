 1: 'use server';
 2: import { createSupabaseServerClient } from '@/lib/supabase/server';
 3: import { translateAuthError } from '@/lib/auth/errors';
 4: import { z } from 'zod';
 5: 
 6: const Schema = z.object({
 7:   identifier: z.string().min(1, 'Ingresa tu correo o teléfono'),
 8: });
 9: 
10: type FormState = { ok: boolean; message?: string };
11: 
12: export async function resetPasswordForEmailAction(
13:   _prev: FormState,
14:   formData: FormData
15: ): Promise<FormState> {
16:   const parsed = Schema.safeParse({ identifier: formData.get('identifier') });
17:   if (!parsed.success) {
18:     return { ok: false, message: parsed.error.issues[0]?.message ?? 'Inválido' };
19:   }
20:   const identifier = parsed.data.identifier.trim();
21:   if (!identifier.includes('@')) {
22:     return {
23:       ok: true,
24:       message:
25:         'Si te registraste con teléfono, contacta a tu Oficial de RRHH (Samantha Kosmas o Rocío Olmedo) para recuperar tu contraseña. SMS recovery estará disponible en próxima versión.',
26:     };
27:   }
28:   const supabase = await createSupabaseServerClient();
29:   const { error } = await supabase.auth.resetPasswordForEmail(identifier.toLowerCase(), {
30:     redirectTo: `${process.env.NEXT_PUBLIC_APP_URL ?? ''}/reset-password`,
31:   });
32:   if (error && error.code !== 'over_email_send_rate_limit' && error.code !== 'user_not_found') {
33:     return { ok: false, message: translateAuthError(error) };
34:   }
35:   return {
36:     ok: true,
37:     message: 'Si esa cuenta existe, te enviamos un enlace de recuperación a tu correo.',
38:   };
39: }
</file>

