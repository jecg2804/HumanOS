 39: export async function createEmployeeAction(
 40:   _prev: FormState,
 41:   formData: FormData
 42: ): Promise<FormState> {
 43:   const parsed = EmployeeSchema.safeParse(Object.fromEntries(formData));
 44:   if (!parsed.success) return { ok: false, errors: parsed.error.flatten().fieldErrors };
 45: 
 46:   if (!parsed.data.position_id && !parsed.data.position_text) {
 47:     return { ok: false, message: 'Cargo requerido (catálogo o texto libre)' };
 48:   }
 49:   if (!parsed.data.department_id && !parsed.data.department_text) {
 50:     return { ok: false, message: 'Departamento requerido' };
 51:   }
 52:   if (!parsed.data.office_id && !parsed.data.office_text) {
 53:     return { ok: false, message: 'Ubicación requerida' };
 54:   }
 55: 
 56:   const userClient = await createSupabaseServerClient();
 57:   const {
 58:     data: { user },
 59:   } = await userClient.auth.getUser();
 60:   if (!user) return { ok: false, message: 'No autenticado' };
 61: 
 62:   const admin = createSupabaseAdminClient();
 63: 
 64:   const { data: person, error: personErr } = await admin
 65:     .schema('hr')
 66:     .from('people')
 67:     .insert({
 68:       full_name: parsed.data.full_name,
 69:       national_id: parsed.data.national_id,
 70:       employee_code: parsed.data.employee_code || null,
 71:       status: 'Activo',
 72:       created_from: 'manual',
 73:     })
 74:     .select('id, full_name')
 75:     .single();
 76:   if (personErr || !person) {
 77:     return { ok: false, message: `Insert hr.people falló: ${personErr?.message}` };
 78:   }
 79: 
 80:   const { error: empErr } = await admin
 81:     .schema('hr')
 82:     .from('employments')
 83:     .insert({
 84:       person_id: person.id,
 85:       position_id: parsed.data.position_id || null,
 86:       position_text: parsed.data.position_text || null,
 87:       department_id: parsed.data.department_id || null,
 88:       department_text: parsed.data.department_text || null,
 89:       office_id: parsed.data.office_id || null,
 90:       office_text: parsed.data.office_text || null,
 91:       supervisor_id: parsed.data.supervisor_id || null,
 92:       hire_date: parsed.data.hire_date,
 93:       app_role: parsed.data.app_role,
 94:       employment_type_id: parsed.data.employment_type_id,
 95:       created_from: 'manual',
 96:     });
 97:   if (empErr) return { ok: false, message: `Insert hr.employments falló: ${empErr.message}` };
 98: 
 99:   await admin.schema('hr').from('user_settings').insert({ person_id: person.id });
100: 
101:   const code = generateInviteCode();
102:   const { data: invite, error: invErr } = await admin
103:     .schema('hr')
104:     .from('invite_codes')
105:     .insert({
106:       code,
107:       person_id: person.id,
108:       generated_by: user.id,
109:       invite_method: parsed.data.delivery_target.includes('@') ? 'email' : 'whatsapp',
110:       delivery_target: parsed.data.delivery_target,
111:     })
112:     .select('id, code, expires_at')
113:     .single();
114:   if (invErr || !invite) {
115:     return { ok: false, message: `Insert invite falló: ${invErr?.message}` };
116:   }
117: 
118:   return {
119:     ok: true,
120:     data: {
121:       person_id: person.id,
122:       invite_code: invite.code,
123:       expires_at: invite.expires_at,
124:       delivery_target: parsed.data.delivery_target,
