 12: 
 13: // El schema usa `.default([])` en dependientes, así que el tipo de entrada
 14: // (lo que el form maneja antes de validar) y el de salida (lo que usa el server)
 15: // difieren. Para que `useForm` y `zodResolver` cuadren tipamos por separado.
 16: type ActualizacionDatosInput = z.input<typeof actualizacionDatosSchema>;
 17: import { submitRequestAction } from '@/lib/approvals/submit';
 18: import { collectErrorMessages } from '@/lib/forms/error-utils';
 19: import { Button } from '@/components/ui/button';
 20: import { Input } from '@/components/ui/input';
 21: import { Label } from '@/components/ui/label';
 22: import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
 23: 
 24: type Props = {
 25:   initialValues: ActualizacionDatosData;
 26: };
 27: 
 28: /**
 29:  * Compara recursivamente dos valores y devuelve la lista de paths (notación con
 30:  * puntos) que difieren. Para arrays/objetos compara por JSON.stringify.
 31:  */
 32: export function computeChanges(
 33:   initial: ActualizacionDatosData,
 34:   current: ActualizacionDatosData,
 35: ): string[] {
 36:   const changes: string[] = [];
 37: 
 38:   function diff(a: unknown, b: unknown, path: string) {
 39:     // Tratamos undefined y '' como equivalentes para campos opcionales tipo string.
 40:     const aNorm = a === undefined ? '' : a;
 41:     const bNorm = b === undefined ? '' : b;
 42: 
 43:     if (
 44:       aNorm !== null &&
 45:       bNorm !== null &&
 46:       typeof aNorm === 'object' &&
 47:       typeof bNorm === 'object' &&
 48:       !Array.isArray(aNorm) &&
 49:       !Array.isArray(bNorm)
 50:     ) {
 51:       const keys = new Set([
 52:         ...Object.keys(aNorm as Record<string, unknown>),
 53:         ...Object.keys(bNorm as Record<string, unknown>),
 54:       ]);
 55:       for (const k of keys) {
 56:         diff(
 57:           (aNorm as Record<string, unknown>)[k],
 58:           (bNorm as Record<string, unknown>)[k],
 59:           path ? `${path}.${k}` : k,
 60:         );
 61:       }
 62:       return;
 63:     }
 64: 
 65:     if (Array.isArray(aNorm) || Array.isArray(bNorm)) {
 66:       if (JSON.stringify(aNorm) !== JSON.stringify(bNorm)) {
 67:         changes.push(path);
 68:       }
 69:       return;
 70:     }
 71: 
 72:     if (aNorm !== bNorm) {
 73:       changes.push(path);
 74:     }
 75:   }
 76: 
 77:   diff(initial, current, '');
 78:   return changes;
 79: }
 80: 
 81: export function ActualizacionDatosForm({ initialValues }: Props) {
 82:   const router = useRouter();
 83:   const [submitError, setSubmitError] = useState<string | null>(null);
 84: 
 85:   const form = useForm<
 86:     ActualizacionDatosInput,
 87:     unknown,
 88:     ActualizacionDatosData
 89:   >({
 90:     resolver: zodResolver(actualizacionDatosSchema),
