 4: import { sendNotification } from '@/lib/email/send';
 5: import { effectiveChain, type RequestTypeCode } from './chains';
 6: import type { ApprovalRole } from './roles';
 7: 
 8: export type SubmitInput = {
 9:   typeCode: RequestTypeCode;
10:   formData: Record<string, unknown>;
11:   attachments: Array<{ name: string; url: string; mime: string; size: number }>;
12: };
13: 
14: export type SubmitResult = {
15:   requestId: string;
16:   requestNumber: string;
17: };
18: 
19: type SubmitRpcRow = {
20:   request_id: string;
21:   request_number: string;
22:   first_approver_id: string | null;
23: };
24: 
25: export async function submitRequestAction(input: SubmitInput): Promise<SubmitResult> {
26:   const me = await getMe();
27:   const supa = await createServerClient();
28: 
29:   const { data: type, error: typeErr } = await supa
30:     .from('request_types')
31:     .select('id, name, approval_chain')
32:     .eq('code', input.typeCode)
33:     .single();
34:   if (typeErr || !type) {
35:     throw new Error(`Tipo de solicitud no encontrado: ${input.typeCode}`);
36:   }
37: 
38:   const baseChain = (type.approval_chain ?? []) as ApprovalRole[];
39:   const chain = effectiveChain(input.typeCode, input.formData, baseChain);
40: 
41:   const { data, error } = await supa.rpc('submit_request', {
42:     p_type_code: input.typeCode,
43:     p_requester_id: me.id,
44:     p_form_data: input.formData,
45:     p_attachments: input.attachments,
46:     p_approval_chain: chain,
47:   });
48:   if (error) throw new Error(`Error al enviar solicitud: ${error.message}`);
49: 
50:   const rows = (data ?? []) as SubmitRpcRow[];
51:   const row = rows[0];
52:   if (!row) throw new Error('submit_request did not return a row');
53: 
54:   if (row.first_approver_id) {
55:     const { data: approver } = await supa
56:       .from('people')
57:       .select('email, name')
58:       .eq('id', row.first_approver_id)
59:       .single();
60:     if (approver?.email) {
61:       await sendNotification('solicitud-enviada', {
62:         to: approver.email,
63:         to_name: approver.name.split(' ')[0],
64:         request_number: row.request_number,
65:         request_id: row.request_id,
66:         request_type_label: type.name,
67:         requester_name: me.name,
68:       });
69:     }
70:   }
71: 
72:   return { requestId: row.request_id, requestNumber: row.request_number };
73: }
