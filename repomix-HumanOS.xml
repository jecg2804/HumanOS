 32: function generateInviteCode(): string {
 33:   const alphabet = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
 34:   return Array.from({ length: 8 }, () =>
 35:     alphabet[Math.floor(Math.random() * alphabet.length)]
 36:   ).join('');
