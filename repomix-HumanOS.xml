 40: 
 41: const ALL_STATUSES: RequestStatus[] = [
 42:   'Enviada',
 43:   'En Revisión',
 44:   'Aprobada',
 45:   'Rechazada',
 46:   'Completada',
 47:   'Cancelada',
 48: ];
 49: 
 50: const PAGE_SIZE = 20;
 51: 
 52: function formatDate(s: string | null): string {
 53:   if (!s) return '—';
 54:   const d = new Date(s);
 55:   if (isNaN(d.getTime())) return '—';
 56:   return d.toLocaleDateString('es-PA', {
 57:     day: '2-digit',
 58:     month: '2-digit',
 59:     year: 'numeric',
 60:   });
 61: }
 62: 
 63: function daysInStatus(s: string | null): string {
 64:   if (!s) return '—';
 65:   const d = new Date(s);
 66:   if (isNaN(d.getTime())) return '—';
 67:   const diffMs = Date.now() - d.getTime();
 68:   if (diffMs < 0) return 'hoy';
 69:   const days = Math.floor(diffMs / (1000 * 60 * 60 * 24));
 70:   if (days <= 0) return 'hoy';
 71:   return `${days} ${days === 1 ? 'día' : 'días'}`;
 72: }
 73: 
 74: function nowMinusFiveDaysMs(): number {
 75:   return Date.now() - 5 * 24 * 60 * 60 * 1000;
 76: }
 77: 
 78: function toDateInputValue(iso: string | null): string {
 79:   if (!iso) return '';
 80:   const d = new Date(iso);
 81:   if (isNaN(d.getTime())) return '';
 82:   const yyyy = d.getFullYear();
 83:   const mm = String(d.getMonth() + 1).padStart(2, '0');
 84:   const dd = String(d.getDate()).padStart(2, '0');
 85:   return `${yyyy}-${mm}-${dd}`;
 86: }
 87: 
 88: export function AdminRequestsTable({ rows, types, initial }: Props) {
 89:   // Defaults: all statuses except Borrador (server already excludes Borrador, this just affects UI checkboxes)
 90:   const [statuses, setStatuses] = useState<Set<RequestStatus>>(
 91:     new Set(ALL_STATUSES),
 92:   );
 93:   const [typeIds, setTypeIds] = useState<Set<string>>(new Set());
 94:   const [search, setSearch] = useState('');
 95:   const [dateFrom, setDateFrom] = useState<string>(toDateInputValue(initial.desdeIso));
 96:   const [dateTo, setDateTo] = useState<string>('');
 97:   const [pendientesMias, setPendientesMias] = useState<boolean>(initial.pendientesMias);
 98:   const [vencidas, setVencidas] = useState<boolean>(initial.vencidas);
 99:   const [filtersOpen, setFiltersOpen] = useState(false);
100:   const [page, setPage] = useState(1);
101: 
102:   const filtered = useMemo(() => {
103:     const searchLower = search.trim().toLowerCase();
104:     const fromTs = dateFrom ? new Date(dateFrom + 'T00:00:00').getTime() : null;
105:     const toTs = dateTo ? new Date(dateTo + 'T23:59:59').getTime() : null;
106:     const fiveDaysAgo = nowMinusFiveDaysMs();
107: 
108:     return rows.filter((r) => {
109:       if (statuses.size > 0 && !statuses.has(r.status)) return false;
110:       if (typeIds.size > 0 && !typeIds.has(r.type_id)) return false;
111:       if (pendientesMias && !r.pending_for_me) return false;
112:       if (vencidas) {
113:         if (r.status !== 'Enviada' && r.status !== 'En Revisión') return false;
114:         if (!r.date_submitted) return false;
115:         if (new Date(r.date_submitted).getTime() >= fiveDaysAgo) return false;
116:       }
117:       if (searchLower) {
118:         const hay = (r.requester_name + ' ' + r.requester_code).toLowerCase();
119:         if (!hay.includes(searchLower)) return false;
120:       }
121:       if (fromTs !== null) {
122:         if (!r.date_submitted) return false;
123:         if (new Date(r.date_submitted).getTime() < fromTs) return false;
124:       }
125:       if (toTs !== null) {
126:         if (!r.date_submitted) return false;
127:         if (new Date(r.date_submitted).getTime() > toTs) return false;
128:       }
129:       return true;
130:     });
131:   }, [rows, statuses, typeIds, search, dateFrom, dateTo, pendientesMias, vencidas]);
132: 
133:   const totalPages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
134:   const safePage = Math.min(page, totalPages);
135:   const paged = filtered.slice((safePage - 1) * PAGE_SIZE, safePage * PAGE_SIZE);
136: 
137:   function toggleStatus(s: RequestStatus) {
138:     const next = new Set(statuses);
