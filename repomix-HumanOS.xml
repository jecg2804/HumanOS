2370:   IF v_ethics_version_id IS NULL OR v_child_labor_version_id IS NULL THEN
2371:     RAISE EXCEPTION 'SOPs IC-RH-M-01 o IC-RH-D-07 no encontrados o sin versión current. Aplicar migration 033 primero.';
2372:   END IF;
2373: 
2374:   -- Idempotent link auth_id (Issue I3 fix)
2375:   SELECT auth_id INTO v_existing_auth FROM hr.people WHERE id = p_person_id;
2376:   IF v_existing_auth IS NULL THEN
2377:     UPDATE hr.people
2378:     SET auth_id = p_auth_id,
2379:         photo_url = COALESCE(p_photo_path, photo_url),
2380:         updated_at = now()
2381:     WHERE id = p_person_id;
2382:   ELSIF v_existing_auth <> p_auth_id THEN
2383:     RAISE EXCEPTION 'hr.people.auth_id ya está linkeado a otro auth.user; aborting onboarding';
2384:   ELSE
