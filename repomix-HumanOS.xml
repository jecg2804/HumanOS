142:       className="border-l-4 p-4 rounded text-sm"
143:       style={{ borderColor: '#F5A623', background: '#FEF6E7' }}
144:     >
145:       <p className="font-semibold mb-1">{title}</p>
146:       <p className="text-neutral-700">{body}</p>
147:     </div>
148:   );
149: }
150: 
151: function groupByCategory(rows: RequestTypeRow[]): Array<{ category: string; items: RequestTypeRow[] }> {
152:   const map = new Map<string, RequestTypeRow[]>();
153:   for (const r of rows) {
154:     const cat = r.category ?? 'Otros';
155:     const arr = map.get(cat) ?? [];
156:     arr.push(r);
157:     map.set(cat, arr);
158:   }
159:   return Array.from(map.entries())
160:     .sort(([a], [b]) => a.localeCompare(b))
161:     .map(([category, items]) => ({ category, items }));
162: }
163: 
164: const ROLE_LABELS_SHORT: Record<string, string> = {
165:   supervisor_directo: 'Tu jefe',
166:   hr_oficial: 'Rocío (RRHH)',
167:   hr_planilla: 'Milagros (Planillas)',
168:   hr_gerente: 'Samantha (Gerente RRHH)',
169:   presidencia: 'Rodrigo (Presidencia)',
170:   supervisor: 'Tu jefe',
171:   hr_admin: 'RRHH',
172:   admin: 'Presidencia',
173: };
174: 
175: function readableP2Chain(chain: string[]): string {
176:   return chain.map((r) => ROLE_LABELS_SHORT[r] ?? r).join(' → ') || 'Sin aprobación requerida';
177: }
