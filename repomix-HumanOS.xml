 395: ```ts
 396: import { NextRequest, NextResponse } from 'next/server';
 397: import { createServerClient } from '@supabase/ssr';
 398: 
 399: const PUBLIC_PATHS = ['/login', '/_next', '/favicon.ico', '/sops'];
 400: 
 401: export async function middleware(req: NextRequest) {
 402:   const isPublic = PUBLIC_PATHS.some(p => req.nextUrl.pathname.startsWith(p));
 403:   if (isPublic) return NextResponse.next();
 404: 
 405:   const res = NextResponse.next({ request: { headers: req.headers } });
 406:   const supabase = createServerClient(
 407:     process.env.NEXT_PUBLIC_SUPABASE_URL!,
 408:     process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY!,
 409:     {
 410:       cookies: {
 411:         getAll: () => req.cookies.getAll(),
 412:         setAll: (toSet) => { for (const { name, value, options } of toSet) res.cookies.set(name, value, options); },
 413:       },
 414:     },
 415:   );
 416: 
 417:   const { data: { user } } = await supabase.auth.getUser();
 418:   if (!user) {
 419:     const url = new URL('/login', req.url);
 420:     url.searchParams.set('next', req.nextUrl.pathname);
 421:     return NextResponse.redirect(url);
 422:   }
 423: 
 424:   if (req.nextUrl.pathname.startsWith('/admin')) {
 425:     // Verificar role en server-side; getMe() en /admin/page.tsx hará redirect si no es HR.
 426:   }
 427: 
 428:   return res;
 429: }
 430: 
 431: export const config = { matcher: ['/((?!_next|sops|favicon.ico).*)'] };
 432: ```
