  5: import { RequestList, type RequestListRow } from '@/components/solicitudes/RequestList';
  6: import type { RequestStatus } from '@/types/database';
  7: 
  8: export const metadata = { title: 'Mis solicitudes — HumanOS' };
  9: 
 10: type Filter = 'todas' | 'pendientes' | 'aprobadas' | 'rechazadas';
 11: 
 12: const FILTER_LABELS: Record<Filter, string> = {
 13:   todas: 'Todas',
 14:   pendientes: 'Pendientes',
 15:   aprobadas: 'Aprobadas',
 16:   rechazadas: 'Rechazadas',
 17: };
 18: 
 19: const FILTER_STATUSES: Record<Filter, RequestStatus[] | null> = {
 20:   todas: null,
 21:   pendientes: ['Enviada', 'En Revisión'],
 22:   aprobadas: ['Aprobada', 'Completada'],
 23:   rechazadas: ['Rechazada'],
 24: };
 25: 
 26: function parseFilter(v: string | string[] | undefined): Filter {
 27:   const s = Array.isArray(v) ? v[0] : v;
 28:   if (s === 'pendientes' || s === 'aprobadas' || s === 'rechazadas') return s;
 29:   return 'todas';
 30: }
 31: 
 32: type RawRequest = {
 33:   id: string;
 34:   request_number: string | null;
 35:   status: RequestStatus;
 36:   date_submitted: string | null;
 37:   created_at: string;
 38:   type_id: string;
 39: };
 40: 
 41: type RawType = {
 42:   id: string;
 43:   code: string;
 44:   name: string;
 45:   icon: string | null;
 46: };
 47: 
 48: export default async function MisSolicitudesPage({
 49:   searchParams,
 50: }: {
 51:   searchParams: Promise<{ estado?: string }>;
 52: }) {
 53:   const { estado } = await searchParams;
 54:   const filter = parseFilter(estado);
 55:   const me = await getMe();
 56:   const supa = await createServerClient();
 57: 
 58:   let query = supa
 59:     .from('requests')
 60:     .select('id, request_number, status, date_submitted, created_at, type_id')
 61:     .eq('requester_id', me.id)
 62:     .order('created_at', { ascending: false });
 63: 
 64:   const statuses = FILTER_STATUSES[filter];
 65:   if (statuses) {
 66:     query = query.in('status', statuses);
 67:   }
 68: 
 69:   const { data: rawRequests } = await query;
 70:   const requests = (rawRequests ?? []) as RawRequest[];
 71: 
 72:   const typeIds = Array.from(new Set(requests.map((r) => r.type_id)));
 73:   let typesById = new Map<string, RawType>();
 74:   if (typeIds.length > 0) {
 75:     const { data: types } = await supa
 76:       .from('request_types')
 77:       .select('id, code, name, icon')
 78:       .in('id', typeIds);
 79:     typesById = new Map(((types ?? []) as RawType[]).map((t) => [t.id, t]));
 80:   }
 81: 
 82:   const rows: RequestListRow[] = requests.map((r) => {
 83:     const t = typesById.get(r.type_id);
 84:     return {
 85:       id: r.id,
 86:       request_number: r.request_number,
 87:       type_name: t?.name ?? 'Desconocido',
 88:       type_icon: t?.icon ?? null,
 89:       type_code: t?.code ?? '',
 90:       status: r.status,
 91:       date_submitted: r.date_submitted,
 92:       created_at: r.created_at,
 93:     };
 94:   });
 95: 
 96:   return (
 97:     <div className="space-y-6 max-w-5xl">
 98:       <header className="flex flex-wrap items-start justify-between gap-3">
 99:         <div>
100:           <h1 className="text-2xl md:text-3xl font-semibold">Mis solicitudes</h1>
101:           <p className="text-neutral-500 mt-1 text-sm md:text-base">
102:             Consulta el estado de tus solicitudes activas e históricas.
103:           </p>
104:         </div>
105:         <Link href="/solicitudes/nueva">
106:           <Button style={{ background: '#1B3A5C', color: 'white' }}>Nueva solicitud</Button>
107:         </Link>
108:       </header>
109: 
110:       <nav className="flex gap-2 flex-wrap" aria-label="Filtrar solicitudes por estado">
111:         {(Object.keys(FILTER_LABELS) as Filter[]).map((f) => {
112:           const active = filter === f;
113:           const href = f === 'todas' ? '/solicitudes' : `/solicitudes?estado=${f}`;
114:           return (
115:             <Link
116:               key={f}
117:               href={href}
118:               className={`inline-flex items-center px-3 py-1.5 rounded-full border text-sm transition ${
119:                 active
120:                   ? 'border-transparent text-white'
121:                   : 'border-neutral-300 text-neutral-700 hover:bg-neutral-50'
122:               }`}
123:               style={active ? { background: '#1B3A5C' } : undefined}
124:             >
125:               {FILTER_LABELS[f]}
126:             </Link>
127:           );
128:         })}
129:       </nav>
130: 
131:       {rows.length === 0 ? (
132:         <EmptyState filter={filter} />
133:       ) : (
134:         <RequestList rows={rows} />
135:       )}
136:     </div>
137:   );
138: }
139: 
140: function EmptyState({ filter }: { filter: Filter }) {
141:   const message =
142:     filter === 'todas'
143:       ? 'Aún no has creado ninguna solicitud.'
144:       : `No tienes solicitudes ${FILTER_LABELS[filter].toLowerCase()}.`;
145:   return (
146:     <div className="rounded-lg border border-dashed border-neutral-300 bg-white p-10 text-center">
147:       <p className="text-neutral-600">{message}</p>
148:       <div className="mt-4">
149:         <Link href="/solicitudes/nueva">
150:           <Button style={{ background: '#1B3A5C', color: 'white' }}>Nueva solicitud</Button>
151:         </Link>
152:       </div>
153:     </div>
154:   );
155: }
</file>

