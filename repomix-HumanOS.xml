129: export async function regenerateInviteCodeAction(
130:   _prev: FormState,
131:   formData: FormData
132: ): Promise<FormState> {
133:   const personId = formData.get('person_id') as string | null;
134:   const deliveryTarget = formData.get('delivery_target') as string | null;
135:   if (!personId || !deliveryTarget) return { ok: false, message: 'Datos faltantes' };
136: 
137:   const userClient = await createSupabaseServerClient();
138:   const {
139:     data: { user },
140:   } = await userClient.auth.getUser();
141:   if (!user) return { ok: false, message: 'No autenticado' };
142: 
143:   const admin = createSupabaseAdminClient();
144: 
145:   await admin
146:     .schema('hr')
147:     .from('invite_codes')
148:     .update({ expires_at: new Date().toISOString() })
149:     .eq('person_id', personId)
150:     .is('consumed_at', null);
151: 
152:   const code = generateInviteCode();
153:   const { data: invite, error } = await admin
154:     .schema('hr')
155:     .from('invite_codes')
156:     .insert({
157:       code,
158:       person_id: personId,
159:       generated_by: user.id,
160:       invite_method: deliveryTarget.includes('@') ? 'email' : 'whatsapp',
161:       delivery_target: deliveryTarget,
162:     })
163:     .select('id, code, expires_at')
164:     .single();
165:   if (error || !invite) return { ok: false, message: error?.message };
166: 
167:   await admin.schema('audit').from('log').insert({
168:     actor_id: user.id,
169:     action: 'invite_code_regenerated',
170:     record_id: personId,
171:     schema_name: 'hr',
172:     table_name: 'invite_codes',
173:     metadata: { new_code: invite.code },
174:   });
175: 
176:   return { ok: true, data: { code: invite.code, expires_at: invite.expires_at } };
177: }
