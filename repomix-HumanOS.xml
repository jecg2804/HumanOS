 860:     email: formData.get('email'),
 861:     password: formData.get('password'),
 862:     next: formData.get('next') ?? undefined,
 863:   });
 864: 
 865:   if (!parsed.success) {
 866:     return { ok: false, error: parsed.error.issues[0]?.message ?? 'Datos invalidos' };
 867:   }
 868: 
 869:   const supabase = await createSupabaseServerClient();
 870:   const { data, error } = await supabase.auth.signInWithPassword({
 871:     email: parsed.data.email,
 872:     password: parsed.data.password,
 873:   });
 874: 
 875:   if (error || !data.user) {
 876:     return { ok: false, error: 'Correo o contrasena incorrectos' };
 877:   }
 878: 
 879:   if (!userHasHumanOSAccess(data.user)) {
 880:     await supabase.auth.signOut();
 881:     return { ok: false, error: 'Tu cuenta no tiene acceso a HumanOS. Solicita un invite code a RRHH.' };
 882:   }
 883: 
 884:   redirect(parsed.data.next ?? '/dashboard');
 885: }
