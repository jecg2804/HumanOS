 19: const CODE_BY_SLUG: Record<string, RequestTypeCode> = {
 20:   vacaciones: 'VACACIONES',
 21:   accion_personal: 'ACCION_PERSONAL',
 22:   prestamo: 'PRESTAMO',
 23:   actualizacion_datos: 'ACTUALIZACION_DATOS',
