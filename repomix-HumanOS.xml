 75: export default async function SolicitudDetailPage({
 76:   params,
 77: }: {
 78:   params: Promise<{ id: string }>;
 79: }) {
 80:   const { id } = await params;
 81:   const me = await getMe();
 82:   const supa = await createServerClient();
 83: 
 84:   const { data: req } = await supa
 85:     .from('requests')
 86:     .select(
 87:       'id, request_number, type_id, requester_id, status, form_data, attachments, date_submitted, date_resolved, notes, created_at, updated_at',
 88:     )
 89:     .eq('id', id)
 90:     .maybeSingle();
 91:   if (!req) notFound();
 92:   const request = req as RequestRow;
 93: 
 94:   const [{ data: typeData }, { data: requesterData }, { data: approvalRows }] =
 95:     await Promise.all([
 96:       supa
 97:         .from('request_types')
 98:         .select('id, code, name, icon, approval_chain, sop_reference')
 99:         .eq('id', request.type_id)
100:         .single(),
101:       supa
102:         .from('people')
103:         .select('id, name, code, email, department')
104:         .eq('id', request.requester_id)
105:         .single(),
106:       supa
107:         .from('request_approvals')
108:         .select(
109:           'id, request_id, approver_id, step_order, role_required, decision, comments, decided_at',
110:         )
111:         .eq('request_id', request.id)
112:         .order('step_order'),
113:     ]);
114: 
115:   if (!typeData || !requesterData) notFound();
116:   const type = typeData as TypeRow;
117:   const requester = requesterData as RequesterRow;
118:   const rawApprovals = (approvalRows ?? []) as RequestApproval[];
119: 
120:   // Approver names lookup
121:   const approverIds = Array.from(new Set(rawApprovals.map((a) => a.approver_id)));
122:   const approverNamesById = new Map<string, string>();
123:   if (approverIds.length > 0) {
124:     const { data: approverPeople } = await supa
125:       .from('people')
126:       .select('id, name')
127:       .in('id', approverIds);
128:     for (const p of (approverPeople ?? []) as Array<{ id: string; name: string }>) {
129:       approverNamesById.set(p.id, p.name);
130:     }
131:   }
132:   const approvals: ApprovalRow[] = rawApprovals.map((a) => ({
133:     ...a,
134:     approver_name: approverNamesById.get(a.approver_id) ?? '—',
135:   }));
136: 
137:   // Visibility: requester, hr_admin, or any approver.
138:   const isRequester = request.requester_id === me.id;
139:   const isHr = me.role === 'hr_admin';
140:   const isApprover = approvals.some((a) => a.approver_id === me.id);
141:   if (!isRequester && !isHr && !isApprover) notFound();
142: 
143:   const myPendingApprovalId = computeMyPendingApprovalId(approvals, me.id);
144: 
145:   // Detect missing supervisor step (fallback A) and Solicita Info rows.
146:   const baseChain = (type.approval_chain ?? []) as string[];
147:   const hasSolicitaInfo = approvals.some((a) => a.decision === 'Solicita Info');
148:   const baseRequiresSupervisor = baseChain.includes('supervisor_directo');
149:   const hasSupervisorRow = approvals.some(
150:     (a) => a.role_required === 'supervisor_directo',
151:   );
152:   const showFaltaSupervisor = baseRequiresSupervisor && !hasSupervisorRow;
153: 
154:   // Lookup empleado_objeto name for ACCION_PERSONAL
155:   let empleadoObjetoName: string | undefined;
