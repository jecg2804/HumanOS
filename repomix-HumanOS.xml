 33: 
 34:   return (
 35:     <div className="space-y-5 text-sm">
 36:       {changedLabels.length > 0 && (
 37:         <div className="rounded-md border border-amber-300 bg-amber-50 p-3 text-amber-900">
 38:           <p className="text-xs font-semibold uppercase tracking-wide mb-1">
 39:             Campos modificados
 40:           </p>
 41:           <p className="text-sm">{changedLabels.join(', ')}.</p>
