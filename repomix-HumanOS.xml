  8: 
  9: export type AdminTableRow = {
 10:   id: string;
 11:   request_number: string | null;
 12:   type_id: string;
 13:   type_name: string;
 14:   type_icon: string | null;
 15:   type_code: string;
 16:   requester_id: string;
 17:   requester_name: string;
 18:   requester_code: string;
 19:   status: RequestStatus;
