2532: }
2533: 
2534: export interface WizardState {
2535:   step: number;             // 1..10
2536:   validated: ValidatedContext | null;
2537:   code: string;
2538:   cedula: string;
2539:   employee_code: string;
2540:   delivery_target: string;
2541:   password: string;
2542:   emergency: {
2543:     contact_name: string;
2544:     relationship: string;
2545:     phone: string;
2546:     phone_alt: string;
2547:   };
2548:   medical: Record<string, string>;
2549:   address: {
2550:     street: string;
2551:     neighborhood: string;
2552:     city: string;
2553:     province: string;
2554:     postal_code: string;
2555:   };
2556:   ack_ethics_at: string | null;
2557:   ack_child_labor_at: string | null;
2558:   photo_path: string | null;
2559:   pausedDueToCriticalError: boolean;
2560: }
2561: 
2562: export const initialState: WizardState = {
2563:   step: 1,
2564:   validated: null,
2565:   code: '',
2566:   cedula: '',
2567:   employee_code: '',
2568:   delivery_target: '',
2569:   password: '',
2570:   emergency: { contact_name: '', relationship: '', phone: '', phone_alt: '' },
2571:   medical: {},
2572:   address: { street: '', neighborhood: '', city: '', province: '', postal_code: '' },
2573:   ack_ethics_at: null,
2574:   ack_child_labor_at: null,
2575:   photo_path: null,
2576:   pausedDueToCriticalError: false,
2577: };
2578: 
2579: export type WizardAction =
2580:   | { type: 'SET_FIELD'; key: keyof WizardState; value: WizardState[keyof WizardState] }
2581:   | { type: 'SET_NESTED'; section: 'emergency' | 'address' | 'medical'; key: string; value: string }
2582:   | { type: 'VALIDATED'; payload: ValidatedContext; code: string; cedula: string; employee_code: string; delivery_target: string }
2583:   | { type: 'NEXT_STEP' }
2584:   | { type: 'PREV_STEP' }
2585:   | { type: 'GO_TO'; step: number }
2586:   | { type: 'SET_PHOTO'; path: string }
2587:   | { type: 'ACK'; key: 'ack_ethics_at' | 'ack_child_labor_at'; at: string }
2588:   | { type: 'PAUSE_CRITICAL_ERROR' }
2589:   | { type: 'RESET' };
2590: 
2591: export function wizardReducer(state: WizardState, action: WizardAction): WizardState {
2592:   switch (action.type) {
2593:     case 'SET_FIELD':
2594:       return { ...state, [action.key]: action.value };
2595:     case 'SET_NESTED':
2596:       return {
2597:         ...state,
2598:         [action.section]: { ...state[action.section], [action.key]: action.value },
2599:       };
2600:     case 'VALIDATED':
2601:       return {
2602:         ...state,
2603:         validated: action.payload,
2604:         code: action.code,
2605:         cedula: action.cedula,
2606:         employee_code: action.employee_code,
2607:         delivery_target: action.delivery_target,
2608:         step: action.payload.existing_multi_app_user ? 5 : 4,
2609:       };
2610:     case 'NEXT_STEP': {
2611:       let next = state.step + 1;
2612:       if (next === 4 && state.validated?.existing_multi_app_user) next = 5;
2613:       return { ...state, step: Math.min(next, 10) };
2614:     }
2615:     case 'PREV_STEP': {
2616:       let prev = state.step - 1;
2617:       if (prev === 4 && state.validated?.existing_multi_app_user) prev = 3;
2618:       return { ...state, step: Math.max(prev, 1) };
2619:     }
2620:     case 'GO_TO':
2621:       return { ...state, step: action.step };
2622:     case 'SET_PHOTO':
2623:       return { ...state, photo_path: action.path };
2624:     case 'ACK':
2625:       return { ...state, [action.key]: action.at };
2626:     case 'PAUSE_CRITICAL_ERROR':
2627:       return { ...state, pausedDueToCriticalError: true };
2628:     case 'RESET':
2629:       return initialState;
2630:     default:
2631:       return state;
2632:   }
2633: }
2634: ```
